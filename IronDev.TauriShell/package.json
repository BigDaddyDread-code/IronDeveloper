{
  "name": "irondev-desktop",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": "24.16.0",
    "npm": "11.13.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:localtest": "vite --host 127.0.0.1 --mode localtest",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "playwright test",
    "test:localtest": "playwright test tests/localtest-manual-smoke.spec.ts",
    "test:visual-smoke": "playwright test tests/chat-visual-smoke.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "api:fetch-openapi": "node scripts/fetch-openapi-spec.mjs",
    "api:generate": "npm run api:fetch-openapi && openapi-typescript openapi/irondev-api.openapi.json -o src/api/generated/ironDevApiTypes.ts",
    "api:diagnose": "node scripts/diagnose-openapi-drift.mjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tauri-apps/cli": "^2.8.4",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "openapi-typescript": "7.13.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  }
}
