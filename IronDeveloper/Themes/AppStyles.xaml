<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        IronDeveloper App-level style overrides
        ========================================
        This file is intentionally sparse.
        Add app-specific style tweaks here only — never duplicate
        keys already defined in IronDeveloperControls.
    -->

    <Style x:Key="IronGhostButton" TargetType="ButtonBase">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ButtonBase">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IronSecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background"      Value="{StaticResource GlassControlBrush}" />
        <Setter Property="BorderBrush"     Value="{StaticResource MidBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding"         Value="22,10" />
        <Setter Property="Foreground"      Value="{StaticResource TextBrush}" />
    </Style>

    <!-- ── Sidebar dark-glass tooltip ─────────────────────────────────── -->
    <Style x:Key="IronSidebarTooltip" TargetType="ToolTip">
        <Setter Property="Placement"         Value="Right"/>
        <Setter Property="HorizontalOffset"  Value="6"/>
        <Setter Property="VerticalOffset"    Value="0"/>
        <Setter Property="HasDropShadow"     Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="#CC0F1822" CornerRadius="6"
                            BorderBrush="#3392400E" BorderThickness="1"
                            Padding="12,6" Margin="4,0,0,0">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="3" BlurRadius="8" Opacity="0.5" Color="#000000"/>
                        </Border.Effect>
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="#E0E6ED" FontSize="12"
                                   FontWeight="SemiBold" FontFamily="Segoe UI"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
