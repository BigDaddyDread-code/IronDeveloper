<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="IronDevVisualTokens.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Surface and panel styles -->
    <Style x:Key="IronDev.SurfacePanel.Base" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource IronDev.Brush.Surface.Panel}"/>
        <Setter Property="BorderBrush" Value="{StaticResource IronDev.Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="{StaticResource IronDev.Border.Thin}"/>
        <Setter Property="CornerRadius" Value="{StaticResource IronDev.Radius.Large}"/>
        <Setter Property="Padding" Value="{StaticResource IronDev.Thickness.Panel}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="IronDev.SurfacePanel.Subtle" TargetType="{x:Type Border}" BasedOn="{StaticResource IronDev.SurfacePanel.Base}">
        <Setter Property="Background" Value="{StaticResource IronDev.Brush.Surface.Subtle}"/>
    </Style>

    <Style x:Key="IronDev.SurfacePanel.Elevated" TargetType="{x:Type Border}" BasedOn="{StaticResource IronDev.SurfacePanel.Base}">
        <Setter Property="BorderBrush" Value="{StaticResource IronDev.Brush.Border.Strong}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="{StaticResource IronDev.Color.Shadow}" BlurRadius="{StaticResource IronDev.Elevation.PanelBlur}" ShadowDepth="{StaticResource IronDev.Elevation.PanelDepth}" Opacity="0.36"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Typography styles -->
    <Style x:Key="IronDev.Type.WorkspaceTitle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource IronDev.Brush.Text.Primary}"/>
        <Setter Property="FontFamily" Value="{StaticResource IronDev.Font.Family.Ui}"/>
        <Setter Property="FontSize" Value="{StaticResource IronDev.Font.Size.Display}"/>
        <Setter Property="FontWeight" Value="{StaticResource IronDev.Font.Weight.Strong}"/>
    </Style>

    <Style x:Key="IronDev.Type.Eyebrow" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource IronDev.Brush.Text.Muted}"/>
        <Setter Property="FontFamily" Value="{StaticResource IronDev.Font.Family.Ui}"/>
        <Setter Property="FontSize" Value="{StaticResource IronDev.Font.Size.Caption}"/>
        <Setter Property="FontWeight" Value="{StaticResource IronDev.Font.Weight.Strong}"/>
    </Style>

    <Style x:Key="IronDev.Type.Body" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource IronDev.Brush.Text.Secondary}"/>
        <Setter Property="FontFamily" Value="{StaticResource IronDev.Font.Family.Ui}"/>
        <Setter Property="FontSize" Value="{StaticResource IronDev.Font.Size.Body}"/>
        <Setter Property="LineHeight" Value="19"/>
    </Style>

    <!-- Button and command styles -->
    <Style x:Key="IronDev.CommandButton.Primary" TargetType="{x:Type Button}" BasedOn="{StaticResource AppButton.Primary}">
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="Padding" Value="{StaticResource IronDev.Thickness.Command}"/>
        <Setter Property="FontSize" Value="{StaticResource IronDev.Font.Size.Body}"/>
        <Setter Property="FontWeight" Value="{StaticResource IronDev.Font.Weight.Control}"/>
    </Style>

    <Style x:Key="IronDev.CommandButton.Secondary" TargetType="{x:Type Button}" BasedOn="{StaticResource AppButton.Secondary}">
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="Padding" Value="{StaticResource IronDev.Thickness.Command}"/>
        <Setter Property="FontSize" Value="{StaticResource IronDev.Font.Size.Body}"/>
    </Style>

    <Style x:Key="IronDev.CommandButton.Ghost" TargetType="{x:Type Button}" BasedOn="{StaticResource AppButton.CompactGhost}">
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="Padding" Value="12,0"/>
    </Style>

    <!-- Input styles -->
    <Style x:Key="IronDev.Input.TextBox" TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="FontFamily" Value="{StaticResource IronDev.Font.Family.Ui}"/>
        <Setter Property="FontSize" Value="{StaticResource IronDev.Font.Size.Body}"/>
        <Setter Property="Foreground" Value="{StaticResource IronDev.Brush.Text.Primary}"/>
    </Style>

    <Style x:Key="IronDev.Input.ComboBox" TargetType="{x:Type ComboBox}" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="FontSize" Value="{StaticResource IronDev.Font.Size.Body}"/>
        <Setter Property="Foreground" Value="{StaticResource IronDev.Brush.Text.Primary}"/>
    </Style>

    <!-- Status, empty, and loading styles -->
    <Style x:Key="IronDev.StatusBadge.Host" TargetType="{x:Type Border}" BasedOn="{StaticResource IronDev.SurfacePanel.Base}">
        <Setter Property="CornerRadius" Value="{StaticResource IronDev.Radius.Pill}"/>
        <Setter Property="Padding" Value="8,3"/>
    </Style>

    <Style x:Key="IronDev.EmptyState.Text" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource IronDev.Type.Body}">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="Opacity" Value="{StaticResource IronDev.State.Opacity.Muted}"/>
    </Style>

    <Style x:Key="IronDev.Loading.SkeletonBlock" TargetType="{x:Type Border}">
        <Setter Property="Height" Value="12"/>
        <Setter Property="CornerRadius" Value="{StaticResource IronDev.Radius.Small}"/>
        <Setter Property="Background" Value="{StaticResource IronDev.Brush.Surface.Interactive}"/>
        <Setter Property="Opacity" Value="{StaticResource IronDev.State.Opacity.Loading}"/>
    </Style>
</ResourceDictionary>
