<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- IronDev visual foundation tokens. App-owned aliases sit above IronDeveloperControls. -->

    <!-- Color tokens -->
    <Color x:Key="IronDev.Color.Ink.980">#070B10</Color>
    <Color x:Key="IronDev.Color.Ink.940">#0B1119</Color>
    <Color x:Key="IronDev.Color.Ink.900">#101821</Color>
    <Color x:Key="IronDev.Color.Ink.840">#151F2B</Color>
    <Color x:Key="IronDev.Color.Ink.760">#1E2B39</Color>
    <Color x:Key="IronDev.Color.Line.Subtle">#223041</Color>
    <Color x:Key="IronDev.Color.Line.Strong">#365069</Color>
    <Color x:Key="IronDev.Color.Text.Primary">#EEF4FA</Color>
    <Color x:Key="IronDev.Color.Text.Secondary">#B8C5D2</Color>
    <Color x:Key="IronDev.Color.Text.Muted">#758396</Color>
    <Color x:Key="IronDev.Color.Text.Disabled">#566273</Color>
    <Color x:Key="IronDev.Color.Accent.Command">#F58A07</Color>
    <Color x:Key="IronDev.Color.Accent.CommandHover">#FF9C2A</Color>
    <Color x:Key="IronDev.Color.Accent.CommandPressed">#D76D00</Color>
    <Color x:Key="IronDev.Color.Accent.Trace">#50B4FF</Color>
    <Color x:Key="IronDev.Color.Status.Success">#34D399</Color>
    <Color x:Key="IronDev.Color.Status.Warning">#FBBF24</Color>
    <Color x:Key="IronDev.Color.Status.Danger">#F87171</Color>
    <Color x:Key="IronDev.Color.Status.Info">#60A5FA</Color>
    <Color x:Key="IronDev.Color.Shadow">#000000</Color>

    <!-- Brush tokens -->
    <SolidColorBrush x:Key="IronDev.Brush.Background.App" Color="{StaticResource IronDev.Color.Ink.980}"/>
    <SolidColorBrush x:Key="IronDev.Brush.Background.Shell" Color="{StaticResource IronDev.Color.Ink.940}"/>
    <SolidColorBrush x:Key="IronDev.Brush.Surface.Panel" Color="{StaticResource IronDev.Color.Ink.900}"/>
    <SolidColorBrush x:Key="IronDev.Brush.Surface.Subtle" Color="{StaticResource IronDev.Color.Ink.840}"/>
    <SolidColorBrush x:Key="IronDev.Brush.Surface.Interactive" Color="{StaticResource IronDev.Color.Ink.760}"/>
    <SolidColorBrush x:Key="IronDev.Brush.Border.Subtle" Color="{StaticResource IronDev.Color.Line.Subtle}"/>
    <SolidColorBrush x:Key="IronDev.Brush.Border.Strong" Color="{StaticResource IronDev.Color.Line.Strong}"/>
    <SolidColorBrush x:Key="IronDev.Brush.Text.Primary" Color="{StaticResource IronDev.Color.Text.Primary}"/>
    <SolidColorBrush x:Key="IronDev.Brush.Text.Secondary" Color="{StaticResource IronDev.Color.Text.Secondary}"/>
    <SolidColorBrush x:Key="IronDev.Brush.Text.Muted" Color="{StaticResource IronDev.Color.Text.Muted}"/>
    <SolidColorBrush x:Key="IronDev.Brush.Text.Disabled" Color="{StaticResource IronDev.Color.Text.Disabled}"/>
    <SolidColorBrush x:Key="IronDev.Brush.Accent.Command" Color="{StaticResource IronDev.Color.Accent.Command}"/>
    <SolidColorBrush x:Key="IronDev.Brush.Accent.CommandHover" Color="{StaticResource IronDev.Color.Accent.CommandHover}"/>
    <SolidColorBrush x:Key="IronDev.Brush.Accent.Trace" Color="{StaticResource IronDev.Color.Accent.Trace}"/>
    <SolidColorBrush x:Key="IronDev.Brush.Status.Success" Color="{StaticResource IronDev.Color.Status.Success}"/>
    <SolidColorBrush x:Key="IronDev.Brush.Status.Warning" Color="{StaticResource IronDev.Color.Status.Warning}"/>
    <SolidColorBrush x:Key="IronDev.Brush.Status.Danger" Color="{StaticResource IronDev.Color.Status.Danger}"/>
    <SolidColorBrush x:Key="IronDev.Brush.Status.Info" Color="{StaticResource IronDev.Color.Status.Info}"/>

    <!-- Typography tokens -->
    <FontFamily x:Key="IronDev.Font.Family.Ui">Segoe UI</FontFamily>
    <FontFamily x:Key="IronDev.Font.Family.Mono">Cascadia Mono, Consolas, Lucida Console</FontFamily>
    <sys:Double x:Key="IronDev.Font.Size.Display">26</sys:Double>
    <sys:Double x:Key="IronDev.Font.Size.Title">18</sys:Double>
    <sys:Double x:Key="IronDev.Font.Size.Body">13</sys:Double>
    <sys:Double x:Key="IronDev.Font.Size.Small">12</sys:Double>
    <sys:Double x:Key="IronDev.Font.Size.Caption">11</sys:Double>
    <FontWeight x:Key="IronDev.Font.Weight.Strong">SemiBold</FontWeight>
    <FontWeight x:Key="IronDev.Font.Weight.Control">SemiBold</FontWeight>

    <!-- Spacing tokens -->
    <sys:Double x:Key="IronDev.Space.1">4</sys:Double>
    <sys:Double x:Key="IronDev.Space.2">8</sys:Double>
    <sys:Double x:Key="IronDev.Space.3">12</sys:Double>
    <sys:Double x:Key="IronDev.Space.4">16</sys:Double>
    <sys:Double x:Key="IronDev.Space.5">20</sys:Double>
    <sys:Double x:Key="IronDev.Space.6">24</sys:Double>
    <sys:Double x:Key="IronDev.Space.8">32</sys:Double>
    <Thickness x:Key="IronDev.Thickness.Workspace">20,16,20,18</Thickness>
    <Thickness x:Key="IronDev.Thickness.Panel">16</Thickness>
    <Thickness x:Key="IronDev.Thickness.Panel.Dense">12</Thickness>
    <Thickness x:Key="IronDev.Thickness.Command">14,0</Thickness>

    <!-- Radius tokens -->
    <CornerRadius x:Key="IronDev.Radius.None">0</CornerRadius>
    <CornerRadius x:Key="IronDev.Radius.Small">6</CornerRadius>
    <CornerRadius x:Key="IronDev.Radius.Medium">8</CornerRadius>
    <CornerRadius x:Key="IronDev.Radius.Large">10</CornerRadius>
    <CornerRadius x:Key="IronDev.Radius.Pill">999</CornerRadius>

    <!-- Border, elevation, opacity, and icon tokens -->
    <Thickness x:Key="IronDev.Border.Thin">1</Thickness>
    <sys:Double x:Key="IronDev.Elevation.None">0</sys:Double>
    <sys:Double x:Key="IronDev.Elevation.PanelBlur">18</sys:Double>
    <sys:Double x:Key="IronDev.Elevation.PanelDepth">3</sys:Double>
    <sys:Double x:Key="IronDev.State.Opacity.Disabled">0.45</sys:Double>
    <sys:Double x:Key="IronDev.State.Opacity.Loading">0.62</sys:Double>
    <sys:Double x:Key="IronDev.State.Opacity.Muted">0.74</sys:Double>
    <sys:Double x:Key="IronDev.Icon.Size.Small">14</sys:Double>
    <sys:Double x:Key="IronDev.Icon.Size.Default">16</sys:Double>
    <sys:Double x:Key="IronDev.Icon.Size.Large">20</sys:Double>
</ResourceDictionary>
