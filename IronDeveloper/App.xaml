<Application x:Class="IronDev.Agent.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wf="clr-namespace:IronDev.Agent.ViewModels.Workflow"
             xmlns:ws="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             xmlns:vwf="clr-namespace:IronDev.Agent.Views.Workflow"
             xmlns:vws="clr-namespace:IronDev.Agent.Views.Workspaces"
             xmlns:cvt="clr-namespace:IronDev.Agent.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!-- ── IronDeveloperControls design system (canonical entry point) ── -->
                <ResourceDictionary Source="pack://application:,,,/IronDeveloperControls;component/Themes/Generic.xaml"/>

                <!-- ── IronDeveloper app-level overrides (empty for now) ── -->
                <ResourceDictionary Source="Themes/AppStyles.xaml"/>

            </ResourceDictionary.MergedDictionaries>

            <!-- ── Shared converters ───────────────────────────────────── -->
            <cvt:WorkspaceActiveConverter x:Key="WorkspaceActiveConverter"/>
            <cvt:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <cvt:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
            <cvt:RoleToDisplayNameConverter x:Key="RoleToDisplayNameConverter"/>
            <cvt:RoleToInitialConverter x:Key="RoleToInitialConverter"/>
            <cvt:StringToInitialsConverter x:Key="StringToInitialsConverter"/>

            <!-- InverseBoolConverter: IsEnabled="{Binding IsBusy, Converter=...}" -->
            <cvt:InverseBoolConverter x:Key="InverseBoolConverter"/>

            <!-- StringToVisibilityConverter: show element only when string is non-empty -->
            <cvt:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>

            <cvt:InverseVisibilityConverter x:Key="InverseVisibilityConverter"/>
            <cvt:LoginButtonTextConverter x:Key="LoginButtonTextConverter"/>
            <cvt:BoolToStringConverter x:Key="BoolToStringConverter"/>
            <cvt:BoolToColorConverter x:Key="BoolToColorConverter"/>
            <cvt:ValueToVisConverter x:Key="ValueToVis"/>

            <!-- ── DataTemplates: VM → View ───────────────────────────── -->
            <!--  The ContentControl in MainWindow binds CurrentView (object/VM).
                  WPF resolves the template here — ShellViewModel never touches views. -->

            <DataTemplate DataType="{x:Type wf:LoginViewModel}">
                <vwf:LoginView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type wf:ProjectHubViewModel}">
                <vwf:ProjectHubView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type wf:CreateProjectViewModel}">
                <vwf:CreateProjectView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type wf:ProjectOverviewViewModel}">
                <vwf:ProjectOverviewView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type ws:KnowledgeCompilerViewModel}">
                <vws:KnowledgeCompilerView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type ws:ChatWorkspaceViewModel}">
                <vws:ChatWorkspaceView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type ws:TicketsWorkspaceViewModel}">
                <vws:TicketsWorkspaceView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type ws:TestingCompanionViewModel}">
                <vws:TestingCompanionView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type ws:ImplementationPlansWorkspaceViewModel}">
                <vws:ImplementationPlansWorkspaceView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type ws:DecisionsWorkspaceViewModel}">
                <vws:DecisionsWorkspaceView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type ws:DocumentsWorkspaceViewModel}">
                <vws:DocumentsWorkspaceView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type ws:SettingsWorkspaceViewModel}">
                <vws:SettingsWorkspaceView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type ws:BuilderWorkspaceViewModel}">
                <vws:BuilderWorkspaceView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type ws:ProjectProfileViewModel}">
                <vws:ProjectProfileView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type ws:PromptPlaygroundViewModel}">
                <vws:PromptPlaygroundView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type ws:LlmConsoleViewModel}">
                <vws:LlmConsoleView/>
            </DataTemplate>

            <cvt:StatusToBrushConverter x:Key="StatusToBrushConverter"/>
            <!-- Strips markdown from Summary for compact list row previews -->
            <cvt:MarkdownPreviewConverter x:Key="MarkdownPreviewConverter"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>
