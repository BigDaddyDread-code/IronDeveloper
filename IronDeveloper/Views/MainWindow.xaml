<Window x:Class="IronDev.Agent.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Shell"
        xmlns:conv="clr-namespace:IronDev.Agent.Converters"
        mc:Ignorable="d"
        Title="IronDev Architect" 
        Height="860" Width="1300"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <conv:WorkspaceActiveConverter x:Key="WorkspaceActiveConverter"/>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Border CornerRadius="14" ClipToBounds="True" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1">
        <Grid Background="{StaticResource AppBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ TITLE BAR ══════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    Background="{StaticResource MetalBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <!-- macOS style traffic lights -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                        <Ellipse Width="10" Height="10" Fill="#FF5F57" Margin="0,0,7,0"/>
                        <Ellipse Width="10" Height="10" Fill="#FFBD2E" Margin="0,0,7,0"/>
                        <Ellipse Width="10" Height="10" Fill="#27C93F"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="IronDev Architect" FontWeight="Bold" 
                                   Foreground="{StaticResource TextBrush}" FontSize="12" Opacity="0.6"/>
                        <TextBlock Text="  ·  " Foreground="{StaticResource TextBrush}" FontSize="12" Opacity="0.3"/>
                        <TextBlock Text="{Binding CurrentTenant.Name}" Foreground="{StaticResource AccentBrush}" 
                                   FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Opacity="0.8"/>
                    </StackPanel>

                    <Button Content="✕" Style="{StaticResource IronGhostButton}"
                            Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="32" Height="32"
                            Foreground="{StaticResource TextBrush}" Opacity="0.4"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- ══ SIDEBAR ════════════════════════════════════════════════════ -->
            <Border Grid.Row="1" Grid.Column="0" Width="92"
                    Visibility="{Binding ShowSidebar, Converter={StaticResource BoolToVisibilityConverter}}"
                    Margin="12,12,0,12"
                    Style="{StaticResource IronMetalPanel}">

                <StackPanel HorizontalAlignment="Center" Margin="0,18,0,0">

                    <!-- Hub / Home button -->
                    <Button Margin="0,0,0,10" Width="56" Height="56"
                            Command="{Binding NavigateWorkspaceCommand}" CommandParameter="ProjectHub"
                            ToolTip="Project Hub">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource IronSidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentShellMode}" Value="ProjectHub">
                                        <Setter Property="Tag" Value="Active"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE80F;" FontSize="22"/>
                    </Button>

                    <!-- Project-active navigation buttons -->
                    <StackPanel Visibility="{Binding HasActiveProject, Converter={StaticResource BoolToVisibilityConverter}}">

                        <!-- Overview -->
                        <Button Margin="0,0,0,10" Width="56" Height="56"
                                Command="{Binding NavigateWorkspaceCommand}" CommandParameter="Overview"
                                ToolTip="Project Overview">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IronSidebarButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentWorkspace, Converter={StaticResource WorkspaceActiveConverter}, ConverterParameter=Overview}" Value="True">
                                            <Setter Property="Tag" Value="Active"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71D;" FontSize="22"/>
                        </Button>

                        <!-- Chat -->
                        <Button Margin="0,0,0,10" Width="56" Height="56"
                                Command="{Binding NavigateWorkspaceCommand}" CommandParameter="Chat"
                                ToolTip="Chat Architect">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IronSidebarButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentWorkspace, Converter={StaticResource WorkspaceActiveConverter}, ConverterParameter=Chat}" Value="True">
                                            <Setter Property="Tag" Value="Active"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8BD;" FontSize="22"/>
                        </Button>

                        <!-- Tickets -->
                        <Button Margin="0,0,0,10" Width="56" Height="56"
                                Command="{Binding NavigateWorkspaceCommand}" CommandParameter="Tickets"
                                ToolTip="Tickets">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IronSidebarButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentWorkspace, Converter={StaticResource WorkspaceActiveConverter}, ConverterParameter=Tickets}" Value="True">
                                            <Setter Property="Tag" Value="Active"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEA37;" FontSize="22"/>
                        </Button>

                        <!-- Decisions -->
                        <Button Margin="0,0,0,10" Width="56" Height="56"
                                Command="{Binding NavigateWorkspaceCommand}" CommandParameter="Decisions"
                                ToolTip="Decisions">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IronSidebarButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentWorkspace, Converter={StaticResource WorkspaceActiveConverter}, ConverterParameter=Decisions}" Value="True">
                                            <Setter Property="Tag" Value="Active"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D2;" FontSize="22"/>
                        </Button>

                    </StackPanel>

                    <!-- Settings — always shown when authenticated -->
                    <Button Width="56" Height="56"
                            Command="{Binding NavigateWorkspaceCommand}" CommandParameter="Settings"
                            ToolTip="Settings">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource IronSidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentWorkspace, Converter={StaticResource WorkspaceActiveConverter}, ConverterParameter=Settings}" Value="True">
                                        <Setter Property="Tag" Value="Active"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="22"/>
                    </Button>

                </StackPanel>
            </Border>

            <!-- ══ WORKSPACE AREA ══════════════════════════════════════════════ -->
            <Grid Grid.Row="1" Grid.Column="1" Margin="24,14,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- PROJECT CONTEXT STRIP -->
                <Border Grid.Row="0" Margin="0,0,0,20" Padding="20,14"
                        Background="#0F1822" CornerRadius="10"
                        BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1"
                        Visibility="{Binding ShowHeader, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="PROJECT" Style="{StaticResource IronMetaLabel}"/>
                            <TextBlock Text="{Binding ActiveProjectName}" Style="{StaticResource IronMetaValue}"
                                       FontSize="15" FontWeight="Bold"/>

                            <TextBlock Text="PATH"    Style="{StaticResource IronMetaLabel}"/>
                            <TextBlock Text="{Binding ActiveProjectPath}" Style="{StaticResource IronMetaValue}"
                                       TextTrimming="CharacterEllipsis" MaxWidth="350"/>

                            <TextBlock Text="MODEL"   Style="{StaticResource IronMetaLabel}"/>
                            <TextBlock Text="{Binding ActiveModel}" Style="{StaticResource IronMetaValue}"
                                       Foreground="{StaticResource FocusBorderBrush}" FontWeight="Bold"/>

                            <TextBlock Text="STATUS"  Style="{StaticResource IronMetaLabel}"/>
                            
                            <!-- Actionable status pill -->
                            <ToggleButton x:Name="StatusPill" IsChecked="{Binding IsStatusPopupOpen}"
                                          Style="{StaticResource IronGhostButton}" Padding="8,4" Margin="8,0,0,0">
                                <TextBlock Text="{Binding ActiveStatus}" Foreground="{StaticResource StatusReadyBrush}"
                                           FontSize="12" FontWeight="Bold"/>
                            </ToggleButton>
                        </StackPanel>

                        <!-- Status Popup -->
                        <Popup IsOpen="{Binding IsStatusPopupOpen}"
                               PlacementTarget="{Binding ElementName=StatusPill}"
                               Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                            <Border Style="{StaticResource IronMetalPanel}" Padding="16" Margin="0,8,0,0" Width="200">
                                <StackPanel>
                                    <TextBlock Text="Workflow Actions" Style="{StaticResource IronEyebrow}" Margin="0,0,0,12"/>
                                    
                                    <Button Content="Index Now" Command="{Binding IndexNowCommand}" 
                                            Style="{StaticResource IronPrimaryButton}" Margin="0,0,0,8"
                                            Visibility="{Binding StatusNeedsIndex, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    
                                    <Button Content="Open Overview" Command="{Binding OpenOverviewCommand}"
                                            Style="{StaticResource IronSecondaryButton}"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Border>

                <!-- DYNAMIC CONTENT HOST -->
                <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
