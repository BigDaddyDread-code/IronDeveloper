<Window x:Class="IronDev.Agent.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Shell"
        xmlns:conv="clr-namespace:IronDev.Agent.Converters"
        xmlns:coreModels="clr-namespace:IronDev.Core.Models;assembly=IronDev.Core"
        xmlns:controls="http://schemas.irondeveloper.com/controls"
        mc:Ignorable="d"
        x:Name="RootWindow"
        Title="{x:Static coreModels:AppBuildInfo.WindowTitle}"
        Height="860" Width="1300"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="{StaticResource Background/App}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="38" 
                      GlassFrameThickness="0" 
                      CornerRadius="0" 
                      ResizeBorderThickness="4"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Window Command Buttons Style -->
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#20FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WindowCloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="14" ClipToBounds="True" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1">
        <Grid Background="{StaticResource Background/App}">
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ TITLE BAR ══════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    Background="{StaticResource MetalBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <!-- Branding & Tenant (Left) -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                        <Image Source="pack://application:,,,/IronDeveloperControls;component/Icons/logo.png" 
                               Width="18" Height="18" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="{x:Static coreModels:AppBuildInfo.DisplayName}"
                                   Foreground="{StaticResource Text/Secondary}" 
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        
                        <StackPanel Orientation="Horizontal" Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border Background="{StaticResource Background/Interactive}" Padding="6,2" CornerRadius="4" Margin="12,0,0,0">
                                <TextBlock Text="PREVIEW" Foreground="{StaticResource Accent/Primary}" FontSize="9" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="  ·  " Foreground="{StaticResource TextBrush}" FontSize="12" Opacity="0.3" Margin="10,0"/>
                            <TextBlock Foreground="{StaticResource Accent/Primary}" 
                                       FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Opacity="0.8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding CurrentTenant.Name}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasActiveProject}" Value="True">
                                                <Setter Property="Text" Value="{Binding ActiveProjectName}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- User Menu & Window Controls (Right) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        
                        <!-- User Menu Dropdown -->
                        <Grid Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}"
                               Margin="0,0,10,0" VerticalAlignment="Center">
                            <ToggleButton x:Name="UserMenuButton"
                                          Padding="8,4"
                                          Cursor="Hand"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          FocusVisualStyle="{x:Null}"
                                          WindowChrome.IsHitTestVisibleInChrome="True">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border x:Name="Bd"
                                                            Background="{TemplateBinding Background}"
                                                            BorderThickness="0"
                                                            CornerRadius="6"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background"
                                                                    Value="{StaticResource Background/Interactive}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Bd" Property="Background"
                                                                    Value="{StaticResource Background/Interactive}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource Icon.Nav.Settings}" Fill="{StaticResource Text/Secondary}"
                                          Width="14" Height="14" Margin="0,0,8,0" Stretch="Uniform" Opacity="0.7"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CurrentUser.DisplayName}"
                                                   Foreground="{StaticResource Text/Secondary}"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CurrentUser.Email}"
                                                   Foreground="{StaticResource Text/Muted}"
                                                   FontSize="10" Opacity="0.7"/>
                                    </StackPanel>
                                </StackPanel>
                            </ToggleButton>

                            <Popup IsOpen="{Binding IsChecked, ElementName=UserMenuButton}" 
                                   PlacementTarget="{Binding ElementName=UserMenuButton}"
                                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                                <Border Style="{StaticResource IronMetalPanel}" Padding="8" Margin="0,8,0,0" Width="220">
                                    <StackPanel>
                                        <!-- Identity header -->
                                        <Border Padding="12,10,12,10"
                                                BorderBrush="{StaticResource Border/Subtle}" BorderThickness="0,0,0,1"
                                                Margin="0,0,0,4">
                                            <StackPanel>
                                                <TextBlock Text="SIGNED IN AS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,6"/>
                                                <TextBlock Text="{Binding CurrentUser.DisplayName}"
                                                           Foreground="{StaticResource Text/Primary}"
                                                           FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding CurrentUser.Email, FallbackValue='Email not available'}"
                                                           Foreground="{StaticResource Text/Muted}"
                                                           FontSize="11" Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding CurrentTenant.Name, FallbackValue='No tenant'}"
                                                           Foreground="{StaticResource Accent/Primary}"
                                                           FontSize="10" Margin="0,4,0,0" Opacity="0.8"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Actions -->
                                        <Button Content="My Account" Command="{Binding OpenMyAccountCommand}" 
                                                Style="{StaticResource AppButton.Ghost}" HorizontalContentAlignment="Left" Padding="12,8"/>
                                        <Button Content="Settings" Command="{Binding OpenSettingsCommand}" 
                                                Style="{StaticResource AppButton.Ghost}" HorizontalContentAlignment="Left" Padding="12,8"/>
                                        <Separator Background="{StaticResource DarkBorderBrush}" Margin="4,4"/>
                                        <Button Content="Switch Project" Command="{Binding NavigateWorkspaceCommand}" CommandParameter="SwitchProject"
                                                Style="{StaticResource AppButton.Ghost}" HorizontalContentAlignment="Left" Padding="12,8"/>
                                        <Button Content="Sign out" Command="{Binding SignOutCommand}" 
                                                Style="{StaticResource AppButton.Ghost}" HorizontalContentAlignment="Left" Padding="12,8"
                                                Foreground="{StaticResource StatusErrorBrush}"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- Window Controls -->
                        <Button Style="{StaticResource WindowControlButton}" Click="MinimizeButton_Click">
                            <Path Data="{StaticResource Icon.Window.Minimize}" Fill="{StaticResource Text/Secondary}" Width="10" Height="10" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource WindowControlButton}" Click="MaximizeButton_Click">
                            <Path Data="{StaticResource Icon.Window.Maximize}" Fill="{StaticResource Text/Secondary}" Width="10" Height="10" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource WindowCloseButton}" Click="CloseButton_Click">
                            <Path Data="{StaticResource Icon.Window.Close}" Fill="{StaticResource Text/Secondary}" Width="10" Height="10" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Margin="18,14,24,24"
                            Content="{Binding CurrentView}"
                            Visibility="{Binding ShowHeader, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

            <controls:ProjectWorkspaceFrame Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Margin="10,12,24,24"
                                            ProjectName="{Binding ActiveProjectName}"
                                            ProjectPath="{Binding ActiveProjectPath}"
                                            ModelName="{Binding ActiveModel}"
                                            ProjectStatusText="{Binding ActiveStatus}"
                                            Visibility="{Binding ShowHeader, Converter={StaticResource BoolToVisibilityConverter}}">
                <controls:ProjectWorkspaceFrame.MainContent>
                    <ContentControl Content="{Binding CurrentView}"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"/>
                </controls:ProjectWorkspaceFrame.MainContent>

                <controls:ProjectWorkspaceFrame.LeftNavigationContent>
                    <controls:AppNavRail>
                        <controls:AppNavRail.HeaderContent>
                            <controls:NavRailItem IconData="{StaticResource Icon.Nav.Projects}"
                                                  Command="{Binding DataContext.NavigateWorkspaceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="ProjectHub"
                                                  ToolTip="Project Hub"/>
                        </controls:AppNavRail.HeaderContent>

                        <controls:AppNavRail.ItemsSource>
                            <x:Array Type="{x:Type controls:NavRailItem}">
                                <controls:NavRailItem IconData="{StaticResource Icon.Nav.Branch}"
                                                      Command="{Binding DataContext.NavigateWorkspaceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="Overview"
                                                      ToolTip="Dashboard"
                                                      IsActive="{Binding DataContext.CurrentWorkspace, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource WorkspaceActiveConverter}, ConverterParameter=Overview}"/>
                                <controls:NavRailItem IconData="{StaticResource Icon.Nav.Chat}"
                                                      Command="{Binding DataContext.NavigateWorkspaceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="Chat"
                                                      ToolTip="Chat"
                                                      IsActive="{Binding DataContext.CurrentWorkspace, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource WorkspaceActiveConverter}, ConverterParameter=Chat}"/>
                                <controls:NavRailItem IconData="{StaticResource Icon.Nav.Tickets}"
                                                      Command="{Binding DataContext.NavigateWorkspaceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="Tickets"
                                                      ToolTip="Tickets"
                                                      IsActive="{Binding DataContext.CurrentWorkspace, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource WorkspaceActiveConverter}, ConverterParameter=Tickets}"/>
                                <controls:NavRailItem IconData="{StaticResource Icon.Action.Build}"
                                                      Command="{Binding DataContext.NavigateWorkspaceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="Builder"
                                                      ToolTip="Builder"
                                                      IsActive="{Binding DataContext.CurrentWorkspace, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource WorkspaceActiveConverter}, ConverterParameter=Builder}"/>
                                <controls:NavRailItem IconData="{StaticResource Icon.Nav.Decisions}"
                                                      Command="{Binding DataContext.NavigateWorkspaceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="Decisions"
                                                      ToolTip="Memory"
                                                      IsActive="{Binding DataContext.CurrentWorkspace, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource WorkspaceActiveConverter}, ConverterParameter=Decisions}"/>
                                <controls:NavRailItem IconData="{StaticResource Icon.Nav.Search}"
                                                      Command="{Binding DataContext.NavigateWorkspaceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="Settings"
                                                      ToolTip="Trace"
                                                      IsActive="{Binding DataContext.CurrentWorkspace, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource WorkspaceActiveConverter}, ConverterParameter=Settings}"/>
                            </x:Array>
                        </controls:AppNavRail.ItemsSource>

                        <controls:AppNavRail.FooterContent>
                            <controls:NavRailItem IconData="{StaticResource Icon.Nav.Settings}"
                                                  Command="{Binding DataContext.NavigateWorkspaceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="ProjectProfile"
                                                  ToolTip="Project Profile"
                                                  IsActive="{Binding DataContext.CurrentWorkspace, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource WorkspaceActiveConverter}, ConverterParameter=ProjectProfile}"/>
                        </controls:AppNavRail.FooterContent>
                    </controls:AppNavRail>
                </controls:ProjectWorkspaceFrame.LeftNavigationContent>

                <controls:ProjectWorkspaceFrame.ProjectActions>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Index Now"
                                Command="{Binding DataContext.IndexNowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                Style="{StaticResource AppButton.CompactGhost}"
                                Margin="0,0,6,0"
                                Visibility="{Binding DataContext.StatusCanIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <Button Content="Overview"
                                Command="{Binding DataContext.OpenOverviewCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                Style="{StaticResource AppButton.CompactGhost}"/>
                    </StackPanel>
                </controls:ProjectWorkspaceFrame.ProjectActions>
            </controls:ProjectWorkspaceFrame>
        </Grid>
    </Border>
</Window>

