<Window x:Class="IronDev.Agent.Views.CodeWorkbenchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:IronDev.Agent.ViewModels"
        mc:Ignorable="d"
        Title="Code Workbench Sandbox" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=viewmodels:CodeWorkbenchViewModel, IsDesignTimeCreatable=False}">
    
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Ticket & Plan -->
        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="Target Outline" Style="{StaticResource CardTitleStyle}" />
                
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Loaded Ticket Info -->
                        <Border Background="{StaticResource SoftPanelBrush}" BorderBrush="{StaticResource BorderSoftBrush}"
                                BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Loaded Ticket" FontSize="11" FontWeight="Bold" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding LoadedTicket.Title}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,8" />
                                <TextBlock Text="{Binding LoadedTicket.Problem}" Style="{StaticResource BodyTextStyle}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- Implementation Plan Details -->
                        <Border Background="{StaticResource SoftPanelBrush}" BorderBrush="{StaticResource BorderSoftBrush}"
                                BorderThickness="1" CornerRadius="12" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Implementation Plan" FontSize="11" FontWeight="Bold" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                
                                <TextBlock Text="Target Block:" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedTargetFilePath}" Style="{StaticResource ModernTextBoxStyle}" MinHeight="36" IsReadOnly="True" Margin="0,0,0,10"/>
                                
                                <TextBlock Text="Strategy Summary:" Style="{StaticResource LabelStyle}" />
                                <TextBlock Text="{Binding ImplementationPlan.Summary}" Style="{StaticResource BodyTextStyle}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
                
                <Button Grid.Row="2" Content="Generate Plan" Command="{Binding GeneratePlanCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" MinHeight="40" Margin="0,10,0,0" />
            </Grid>
        </Border>

        <!-- Center Panel: Draft Editors -->
        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Draft Workbench" Style="{StaticResource CardTitleStyle}" />

                <TabControl Grid.Row="1" Margin="0,0,0,12" Background="Transparent" BorderThickness="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Padding" Value="15,8" />
                            <Setter Property="FontSize" Value="14" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0,0,0,2" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="#2563EB" />
                                    <Setter Property="BorderBrush" Value="#2563EB" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Resources>
                    
                    <TabItem Header="Code Draft">
                        <Border Background="#F8FAFC" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                            <TextBox Text="{Binding GeneratedCode, UpdateSourceTrigger=PropertyChanged}" 
                                     AcceptsReturn="True" AcceptsTab="True" 
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="13" Background="Transparent" BorderThickness="0" />
                        </Border>
                    </TabItem>
                    <TabItem Header="Test Draft">
                        <Border Background="#F8FAFC" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                            <TextBox Text="{Binding GeneratedTestCode, UpdateSourceTrigger=PropertyChanged}" 
                                     AcceptsReturn="True" AcceptsTab="True" 
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="13" Background="Transparent" BorderThickness="0" />
                        </Border>
                    </TabItem>
                </TabControl>
                
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Draft Code" Command="{Binding GenerateCodeDraftCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" MinWidth="130" Margin="0,0,10,0" />
                    <Button Content="Draft Test" Command="{Binding GenerateTestDraftCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" MinWidth="130" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Panel: Validation Log -->
        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Console &amp; Validation" Style="{StaticResource CardTitleStyle}" />
                
                <Border Grid.Row="1" Background="#1E293B" CornerRadius="12" Padding="12" Margin="0,0,0,10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding OutputLog}" FontFamily="Consolas" FontSize="12" Foreground="#E2E8F0" TextWrapping="Wrap" />
                    </ScrollViewer>
                </Border>
                
                <Button Grid.Row="2" Content="Clear Console" Command="{Binding ClearLogCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" MinHeight="40" />
            </Grid>
        </Border>
        
        <!-- Loading Overlay -->
        <Border Grid.ColumnSpan="3" Background="#80FFFFFF" Panel.ZIndex="100">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Background="#2563EB" CornerRadius="12" Padding="30,20" HorizontalAlignment="Center" VerticalAlignment="Center" Effect="{StaticResource CardShadow}">
                <TextBlock Text="AI IS THINKING..." Foreground="White" FontWeight="Bold" FontSize="16" />
            </Border>
        </Border>
    </Grid>
</Window>
