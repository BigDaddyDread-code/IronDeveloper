<UserControl x:Class="IronDev.Agent.Views.Workspaces.DocumentsWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="http://schemas.irondeveloper.com/controls"
             xmlns:primitives="clr-namespace:IronDeveloperControls.Primitives;assembly=IronDeveloperControls"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ───────────────────────────────────────────────── -->
        <controls:WorkspaceHeader Grid.Row="0"
                                  Eyebrow="PROJECT DOCUMENTS"
                                  Title="Documents"
                                  Subtitle="Versioned Markdown project artefacts">
            <controls:WorkspaceHeader.Actions>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource AppButton.CompactGhost}"/>
                </StackPanel>
            </controls:WorkspaceHeader.Actions>
        </controls:WorkspaceHeader>

        <!-- ── Three-column body ────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290" MinWidth="240"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="260" MinWidth="220"/>
            </Grid.ColumnDefinitions>

            <!-- ── Col 0: Document list ─────────────────────────────── -->
            <Border Grid.Column="0"
                    Style="{StaticResource SurfacePanel.Subtle}"
                    Padding="12"
                    Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Section label -->
                    <TextBlock Grid.Row="0"
                               Text="DOCUMENTS"
                               Style="{StaticResource Typography.Eyebrow}"
                               Margin="0,0,0,10"/>

                    <!-- Type filter chips -->
                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{x:Static local:DocumentsWorkspaceViewModel.DocumentTypes}"
                                  Margin="0,0,0,10"
                                  xmlns:local="clr-namespace:IronDev.Agent.ViewModels.Workspaces">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}"
                                        Command="{Binding DataContext.SetFilterTypeCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource AppButton.CompactGhost}"
                                        Margin="0,0,4,4"
                                        Padding="8,3"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Document list -->
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Documents}"
                             SelectedItem="{Binding SelectedDocument, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource AppListBoxItem.Compact}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,5">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0">
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding LastUpdatedLabel}"
                                                   Foreground="{StaticResource Text/Muted}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{StaticResource Text/Primary}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>

                                    <StackPanel Grid.Row="1"
                                                Orientation="Horizontal"
                                                Margin="0,3,0,0">
                                        <primitives:StatusBadge Text="{Binding TypeLabel}"
                                                                Status="Info"
                                                                Margin="0,0,6,0"/>
                                        <primitives:StatusBadge Text="{Binding Status}"
                                                                Status="Ready"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                        <!-- Empty state -->
                        <ListBox.Style>
                            <Style TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDocuments}" Value="False">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate>
                                                    <StackPanel HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Margin="0,40,0,0">
                                                        <TextBlock Text="No documents yet"
                                                                   Foreground="{StaticResource Text/Muted}"
                                                                   FontSize="13"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Save a chat discussion as a document to get started."
                                                                   Foreground="{StaticResource Text/Muted}"
                                                                   FontSize="11"
                                                                   TextWrapping="Wrap"
                                                                   TextAlignment="Center"
                                                                   Margin="0,6,0,0"
                                                                   MaxWidth="200"/>
                                                    </StackPanel>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ── Col 1: Viewer / Editor ───────────────────────────── -->
            <Border Grid.Column="1"
                    Style="{StaticResource SurfacePanel.Subtle}"
                    Padding="0"
                    Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Document header -->
                    <Border Grid.Row="0"
                            Padding="16,14,16,12"
                            BorderBrush="{StaticResource Surface/Border}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding SelectedDocument.Title, FallbackValue='Select a document'}"
                                           Foreground="{StaticResource Text/Primary}"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <DockPanel Margin="0,5,0,0">
                                    <primitives:StatusBadge DockPanel.Dock="Left"
                                                            Text="{Binding SelectedDocument.TypeLabel, FallbackValue=''}"
                                                            Status="Info"
                                                            Margin="0,0,8,0"/>
                                    <primitives:StatusBadge DockPanel.Dock="Left"
                                                            Text="{Binding SelectedVersion.VersionLabel, FallbackValue=''}"
                                                            Status="Ready"
                                                            Margin="0,0,8,0"/>
                                    <primitives:StatusBadge DockPanel.Dock="Left"
                                                            Text="{Binding SelectedVersion.Status, FallbackValue=''}"
                                                            Status="ReviewRequired"/>
                                </DockPanel>
                            </StackPanel>

                            <!-- Toolbar -->
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <!-- View mode buttons -->
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding IsViewMode,
                                                         Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button Content="Edit"
                                            Command="{Binding StartEditingCommand}"
                                            Style="{StaticResource AppButton.CompactGhost}"
                                            Margin="0,0,6,0"
                                            IsEnabled="{Binding HasSelectedVersion}"/>
                                    <Button Content="Archive"
                                            Command="{Binding ArchiveDocumentCommand}"
                                            Style="{StaticResource AppButton.CompactGhost}"
                                            IsEnabled="{Binding HasSelectedDocument}"/>
                                </StackPanel>

                                <!-- Edit mode buttons -->
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding IsEditing,
                                                         Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button Content="Cancel"
                                            Command="{Binding CancelEditingCommand}"
                                            Style="{StaticResource AppButton.CompactGhost}"
                                            Margin="0,0,6,0"/>
                                    <Button Content="Save New Version"
                                            Command="{Binding SaveNewVersionCommand}"
                                            Style="{StaticResource AppButton.Primary}"
                                            IsEnabled="{Binding CanSaveVersion}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- VIEW MODE: WebView2 Markdown renderer -->
                    <Grid Grid.Row="1"
                          Visibility="{Binding IsViewMode,
                                       Converter={StaticResource BoolToVisibilityConverter}}">

                        <!-- Empty state when no document selected -->
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding HasSelectedDocument,
                                                 Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <TextBlock Text="Select a document"
                                       Foreground="{StaticResource Text/Muted}"
                                       FontSize="15"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Choose a document from the list to view its content."
                                       Foreground="{StaticResource Text/Muted}"
                                       FontSize="12"
                                       Margin="0,8,0,0"
                                       TextAlignment="Center"
                                       MaxWidth="260"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- WebView2 for rendered Markdown -->
                        <wv2:WebView2 x:Name="MarkdownViewer"
                                      Visibility="{Binding HasSelectedDocument,
                                                   Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>

                    <!-- EDIT MODE: Raw Markdown editor -->
                    <Grid Grid.Row="1"
                          Visibility="{Binding IsEditing,
                                       Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0"
                                 x:Name="MarkdownEditor"
                                 Text="{Binding EditorMarkdown, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Cascadia Code, Consolas, monospace"
                                 FontSize="13"
                                 Foreground="{StaticResource Text/Primary}"
                                 Background="#0B0F14"
                                 BorderThickness="0"
                                 Padding="16"/>

                        <!-- Change summary bar -->
                        <Border Grid.Row="1"
                                Background="#0D1117"
                                Padding="14,10"
                                BorderBrush="{StaticResource Surface/Border}"
                                BorderThickness="0,1,0,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left"
                                           Text="Change summary:"
                                           Foreground="{StaticResource Text/Muted}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           FontSize="12"/>
                                <TextBox Text="{Binding EditorChangeSummary, UpdateSourceTrigger=PropertyChanged}"
                                         Foreground="{StaticResource Text/Primary}"
                                         Background="Transparent"
                                         BorderThickness="0,0,0,1"
                                         Padding="4,2"
                                         FontSize="12"
                                         VerticalAlignment="Center"
                                         MaxLength="300"/>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <!-- Status bar -->
                    <Border Grid.Row="2"
                            Padding="14,8"
                            Background="#0B0F14"
                            BorderBrush="{StaticResource Surface/Border}"
                            BorderThickness="0,1,0,0"
                            Visibility="{Binding HasStatusText,
                                         Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource Text/Secondary}"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── Col 2: Version history ────────────────────────────── -->
            <Border Grid.Column="2"
                    Style="{StaticResource SurfacePanel.Subtle}"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="VERSION HISTORY"
                               Style="{StaticResource Typography.Eyebrow}"
                               Margin="0,0,0,10"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding VersionHistory}"
                             SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource AppListBoxItem.Compact}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4,6">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <DockPanel Grid.Row="0">
                                            <primitives:StatusBadge DockPanel.Dock="Right"
                                                                    Text="{Binding Status}"
                                                                    Status="Info"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding VersionLabel}"
                                                           Foreground="{StaticResource Text/Primary}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           Margin="0,0,8,0"/>
                                                <!-- Current marker -->
                                                <TextBlock Text="● CURRENT"
                                                           Foreground="{StaticResource Accent/Primary}"
                                                           FontSize="9"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCurrent}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DockPanel>

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding ChangeSummary}"
                                                   Foreground="{StaticResource Text/Secondary}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0"/>

                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding DateLabel}"
                                                   Foreground="{StaticResource Text/Muted}"
                                                   FontSize="10"
                                                   Margin="0,3,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
