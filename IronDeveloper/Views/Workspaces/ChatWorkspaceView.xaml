<UserControl x:Class="IronDev.Agent.Views.Workspaces.ChatWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             xmlns:controls="http://schemas.irondeveloper.com/controls"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1100"
             d:DataContext="{d:DesignInstance Type=vm:ChatWorkspaceViewModel, IsDesignTimeCreatable=False}">

    <Grid Background="{StaticResource Background/App}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" MinWidth="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ LEFT: CHAT HISTORY ══ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource Background/Panel}"
                    BorderBrush="{StaticResource Border/Subtle}" BorderThickness="0,0,1,1"
                    Padding="14,10,10,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="CHATS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,1"/>
                        <TextBlock Text="Conversations"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text/Primary}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="+ New"
                            Command="{Binding NewChatCommand}"
                            Style="{StaticResource AppButton.Primary}"
                            Height="26" Padding="10,0" FontSize="11"
                            VerticalAlignment="Center" Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <!-- Search -->
            <Border Grid.Row="1"
                    Background="{StaticResource Background/Panel}"
                    BorderBrush="{StaticResource Border/Subtle}" BorderThickness="0,0,1,1"
                    Padding="10,6">
                <Border Background="{StaticResource Background/App}"
                        BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1"
                        CornerRadius="5" Padding="8,4">
                    <Grid>
                        <TextBlock Text="⌕  Search conversations…"
                                   Foreground="{StaticResource Text/Muted}"
                                   FontSize="11" VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                        <TextBox Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource Text/Primary}" FontSize="11"
                                 VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Border>

            <!-- Session list with grouping -->
            <Border Grid.Row="2"
                    Background="{StaticResource Background/Panel}"
                    BorderBrush="{StaticResource Border/Subtle}" BorderThickness="0,0,1,0">
                <ListBox ItemsSource="{Binding GroupedSessions}"
                         SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         Padding="0,4,0,8" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border Padding="14,10,14,4" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource Typography.Eyebrow}"
                                                   Opacity="0.6"/>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Row"
                                                Padding="14,9,12,9"
                                                BorderThickness="3,0,0,0"
                                                BorderBrush="Transparent"
                                                Background="Transparent"
                                                Cursor="Hand">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Row" Property="Background" Value="{StaticResource Background/Interactive}"/>
                                                <Setter TargetName="Row" Property="BorderBrush" Value="{StaticResource Accent/Primary}"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                    <Condition Property="IsSelected" Value="False"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="Row" Property="Background" Value="{StaticResource Background/Surface}"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- Title + smart time -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Title, FallbackValue='New Chat'}"
                                               Foreground="{StaticResource Text/Primary}"
                                               FontWeight="SemiBold" FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SmartTime}"
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="10" VerticalAlignment="Top"
                                               Margin="8,1,0,0"/>
                                </Grid>
                                <!-- Preview summary -->
                                <TextBlock Grid.Row="1"
                                           Text="{Binding Summary, FallbackValue=''}"
                                           Foreground="{StaticResource Text/Muted}"
                                           FontSize="11" Margin="0,3,0,0"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="32" Opacity="0.75">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Summary}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Summary}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>

        <!-- ══ RIGHT: ACTIVE CONVERSATION ══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Conversation header -->
            <Border Grid.Row="0" Padding="24,12,20,10"
                    BorderBrush="{StaticResource Border/Subtle}" BorderThickness="0,0,0,1"
                    Visibility="{Binding HasSelectedSession, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Normal title view -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="{Binding IsRenamingTitle, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding SelectedSession.Title, FallbackValue='New Conversation'}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text/Primary}" VerticalAlignment="Center"/>
                        <Button Content="Rename" Command="{Binding StartRenameCommand}"
                                Style="{StaticResource AppButton.Ghost}"
                                FontSize="11" Margin="10,0,0,0"
                                Foreground="{StaticResource Text/Muted}"/>
                    </StackPanel>
                    <!-- Rename edit mode -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="{Binding IsRenamingTitle, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBox Text="{Binding EditingTitle, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                 FontSize="16" FontWeight="SemiBold" Background="Transparent"
                                 Foreground="{StaticResource Text/Primary}"
                                 BorderThickness="0,0,0,1" BorderBrush="{StaticResource Accent/Primary}"
                                 MinWidth="260" x:Name="RenameBox"/>
                        <Button Content="Save" Command="{Binding SaveTitleCommand}"
                                Style="{StaticResource AppButton.Primary}"
                                Height="26" Padding="14,0" FontSize="11" Margin="10,0,6,0"/>
                        <Button Content="Cancel" Command="{Binding CancelRenameCommand}"
                                Style="{StaticResource AppButton.Ghost}"
                                Height="26" Padding="10,0" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Messages / Empty states -->
            <Grid Grid.Row="1">
                <!-- No session selected -->
                <controls:EmptyResultsState
                    Title="IronDev Command Centre"
                    Description="Select a conversation or start a new one to begin."
                    ActionText="New Chat" ActionCommand="{Binding NewChatCommand}"
                    Visibility="{Binding HasSelectedSession, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                <!-- Session with no messages -->
                <controls:EmptyResultsState
                    Title="Start the conversation"
                    Description="Ask about code, tickets, decisions, or implementation plans.">
                    <controls:EmptyResultsState.Style>
                        <Style TargetType="controls:EmptyResultsState">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasSelectedSession}" Value="True"/>
                                        <Condition Binding="{Binding Messages.Count}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </controls:EmptyResultsState.Style>
                </controls:EmptyResultsState>

                <!-- Message thread -->
                <ScrollViewer x:Name="MessagesScroller" VerticalScrollBarVisibility="Auto"
                              Padding="28,20,28,16">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,20">
                                    <!-- Bubble row -->
                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="user">
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto" MaxWidth="660"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- AI avatar -->
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                                                Background="{StaticResource Background/Panel}"
                                                BorderBrush="{StaticResource Accent/Primary}" BorderThickness="1"
                                                VerticalAlignment="Top" Margin="0,2,10,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Role}" Value="user">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="AI" FontSize="8" FontWeight="Bold"
                                                       Foreground="{StaticResource Accent/Primary}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Bubble -->
                                        <Border Grid.Column="1" CornerRadius="10" Padding="14,10" MaxWidth="640">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource Background/Panel}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource Border/Subtle}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Role}" Value="user">
                                                            <Setter Property="Background" Value="{StaticResource Accent/Primary}"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding MessageText}"
                                                           TextWrapping="Wrap" FontSize="13" LineHeight="21">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource Text/Primary}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Role}" Value="user">
                                                                    <Setter Property="Foreground" Value="#0D1117"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- Context used — only for assistant -->
                                                <TextBlock Text="{Binding ContextHeader}"
                                                           FontSize="10" Opacity="0.5"
                                                           Foreground="{StaticResource Text/Muted}"
                                                           Margin="0,6,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasContext}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- Timestamp -->
                                                <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm'}"
                                                           FontSize="10" Opacity="0.4"
                                                           Margin="0,5,0,0" HorizontalAlignment="Right">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource Text/Muted}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Role}" Value="user">
                                                                    <Setter Property="Foreground" Value="#0D1117"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <!-- User avatar -->
                                        <Border Grid.Column="2" Width="28" Height="28" CornerRadius="14"
                                                Background="{StaticResource Accent/Primary}"
                                                VerticalAlignment="Top" Margin="10,2,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Role}" Value="user">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="ME" FontSize="8" FontWeight="Bold"
                                                       Foreground="#0D1117"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                    <!-- Action strip — assistant only -->
                                    <WrapPanel Margin="38,4,0,0" HorizontalAlignment="Left">
                                        <WrapPanel.Style>
                                            <Style TargetType="WrapPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="assistant">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </WrapPanel.Style>
                                        <Button Content="Plan"
                                                Command="{Binding DataContext.CreatePlanCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource AppButton.Ghost}"
                                                Height="22" Padding="9,0" FontSize="10" Margin="0,0,3,0"
                                                ToolTip="Create Implementation Plan"/>
                                        <Button Content="Ticket"
                                                Command="{Binding DataContext.CreateTicketCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource AppButton.Ghost}"
                                                Height="22" Padding="9,0" FontSize="10" Margin="0,0,3,0"
                                                ToolTip="Create Ticket"/>
                                        <Button Content="Decision"
                                                Command="{Binding DataContext.SaveDecisionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource AppButton.Ghost}"
                                                Height="22" Padding="9,0" FontSize="10" Margin="0,0,3,0"
                                                ToolTip="Save as Decision"/>
                                        <Button Content="Summary"
                                                Command="{Binding DataContext.SaveSummaryFromMessageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource AppButton.Ghost}"
                                                Height="22" Padding="9,0" FontSize="10" Margin="0,0,3,0"
                                                ToolTip="Save as Project Summary"/>
                                        <Button Content="Copy"
                                                Command="{Binding DataContext.CopyMessageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource AppButton.Ghost}"
                                                Height="22" Padding="9,0" FontSize="10"
                                                ToolTip="Copy to clipboard"/>
                                    </WrapPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ══ COMPOSER ══ -->
            <Border Grid.Row="2"
                    Background="{StaticResource Background/Panel}"
                    BorderBrush="{StaticResource Border/Subtle}" BorderThickness="0,1,0,0"
                    Padding="16,8,16,10">
                <StackPanel>

                    <!-- Thinking indicator -->
                    <Border Margin="0,0,0,5"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="5" Height="5" Fill="{StaticResource Accent/Primary}"
                                     Margin="0,0,5,0" Opacity="0.9"/>
                            <TextBlock Text="IronDev is thinking…" FontSize="11" FontStyle="Italic"
                                       Foreground="{StaticResource Accent/Primary}" Opacity="0.8"/>
                        </StackPanel>
                    </Border>

                    <!-- Context chips row -->
                    <Border Margin="0,0,0,6"
                            Visibility="{Binding HasContextChips, Converter={StaticResource BoolToVisibilityConverter}}">
                        <WrapPanel>
                            <TextBlock Text="Context:" Foreground="{StaticResource Text/Muted}"
                                       FontSize="10" Margin="0,3,6,0" VerticalAlignment="Center"/>
                            <ItemsControl ItemsSource="{Binding ContextChips}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource Background/Surface}"
                                                BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1"
                                                CornerRadius="4" Padding="7,2" Margin="0,0,4,0">
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{StaticResource Text/Muted}"
                                                       FontSize="10" FontFamily="Consolas"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </WrapPanel>
                    </Border>

                    <!-- Input row -->
                    <controls:ComposerBar
                        Text="{Binding PromptText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Placeholder="Ask about code, tickets, decisions, or implementation plans…"
                        SendCommand="{Binding SendMessageCommand}"/>

                    <!-- Model · status inline strip -->
                    <TextBlock Margin="2,4,2,0" FontSize="10"
                               Foreground="{StaticResource Text/Muted}"
                               TextTrimming="CharacterEllipsis">
                        <Run Text="{Binding ActiveModel, FallbackValue='gpt-4o'}" Foreground="{StaticResource Accent/Primary}" FontWeight="SemiBold"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding StatusMessage, FallbackValue='Ready'}"/>
                    </TextBlock>

                    <!-- Quick actions -->
                    <WrapPanel Margin="0,5,0,0"
                               Visibility="{Binding HasSelectedSession, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button Content="Create Plan"
                                Command="{Binding NavigateToPlanCommand}"
                                Style="{StaticResource AppButton.Ghost}"
                                Height="24" Padding="10,0" FontSize="11" Margin="0,0,4,0"/>
                        <Button Content="New Ticket"
                                Command="{Binding NavigateToTicketCommand}"
                                Style="{StaticResource AppButton.Ghost}"
                                Height="24" Padding="10,0" FontSize="11" Margin="0,0,4,0"/>
                        <Button Content="New Decision"
                                Command="{Binding NavigateToDecisionCommand}"
                                Style="{StaticResource AppButton.Ghost}"
                                Height="24" Padding="10,0" FontSize="11"/>
                    </WrapPanel>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
