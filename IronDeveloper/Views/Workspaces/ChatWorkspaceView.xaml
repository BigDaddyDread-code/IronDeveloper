<UserControl x:Class="IronDev.Agent.Views.Workspaces.ChatWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             xmlns:controls="http://schemas.irondeveloper.com/controls"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1100"
             d:DataContext="{d:DesignInstance Type=vm:ChatWorkspaceViewModel, IsDesignTimeCreatable=False}">

    <Grid Background="{StaticResource Background/App}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding ChatListColumnWidth}" MinWidth="44"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <controls:CollapsibleSidePane Grid.Column="0"
                                      Eyebrow="CHATS"
                                      Title="Conversations"
                                      IsCollapsed="{Binding IsChatListCollapsed}"
                                      CollapseCommand="{Binding ToggleChatListCommand}">
            <controls:CollapsibleSidePane.HeaderActions>
                <Button Content="+ New"
                        Command="{Binding NewChatCommand}"
                        Style="{StaticResource AppButton.CompactGhost}"
                        VerticalAlignment="Center"/>
            </controls:CollapsibleSidePane.HeaderActions>

            <controls:CollapsibleSidePane.SearchContent>
                <Border Background="{StaticResource Background/App}"
                        BorderBrush="{StaticResource Border/Subtle}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="8,4">
                    <Grid>
                        <TextBlock Text="Search conversations..."
                                   Foreground="{StaticResource Text/Muted}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                        <TextBox Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource Text/Primary}"
                                 FontSize="11"
                                 VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </controls:CollapsibleSidePane.SearchContent>

            <controls:CollapsibleSidePane.PaneContent>
                <ListBox ItemsSource="{Binding GroupedSessions}"
                         SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0,4,0,8"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border Padding="14,10,14,4" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource Typography.Eyebrow}"
                                                   Opacity="0.6"/>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource AppListBoxItem.Compact}"/>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Title, FallbackValue='New Chat'}"
                                               Foreground="{StaticResource Text/Primary}"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SmartTime}"
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="10"
                                               VerticalAlignment="Top"
                                               Margin="8,1,0,0"/>
                                </Grid>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding Summary, FallbackValue=''}"
                                           Foreground="{StaticResource Text/Muted}"
                                           FontSize="11"
                                           Margin="0,3,0,0"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="32"
                                           Opacity="0.75">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Summary}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Summary}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </controls:CollapsibleSidePane.PaneContent>

            <controls:CollapsibleSidePane.CollapsedActions>
                <Button Content="+"
                        Command="{Binding NewChatCommand}"
                        Style="{StaticResource AppButton.HeaderIcon}"
                        ToolTip="New chat"/>
            </controls:CollapsibleSidePane.CollapsedActions>
        </controls:CollapsibleSidePane>

        <!-- RIGHT: ACTIVE CONVERSATION -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <controls:WorkspaceHeader Grid.Row="0"
                                      Title="{Binding SelectedSession.Title, FallbackValue='New Conversation'}"
                                      Visibility="{Binding HasSelectedSession, Converter={StaticResource BoolToVisibilityConverter}}">
                <controls:WorkspaceHeader.Style>
                    <Style TargetType="controls:WorkspaceHeader">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRenamingTitle}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </controls:WorkspaceHeader.Style>
                <controls:WorkspaceHeader.Actions>
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding StartRenameCommand}"
                                Style="{StaticResource AppButton.HeaderIcon}"
                                ToolTip="Rename conversation">
                            <Path Data="{StaticResource Icon.Action.Edit}"
                                  Fill="{StaticResource Text/Muted}"
                                  Width="13" Height="13"
                                  Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource AppButton.HeaderIcon}"
                                ToolTip="More conversation actions"
                                Margin="4,0,0,0">
                            <Path Data="{StaticResource Icon.Action.More}"
                                  Fill="{StaticResource Text/Muted}"
                                  Width="14" Height="14"
                                  Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </controls:WorkspaceHeader.Actions>
            </controls:WorkspaceHeader>

            <Border Grid.Row="0"
                    Padding="20,12"
                    BorderBrush="{StaticResource Border/Subtle}"
                    BorderThickness="0,0,0,1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding HasSelectedSession}" Value="True"/>
                                    <Condition Binding="{Binding IsRenamingTitle}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox Text="{Binding EditingTitle, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                             FontSize="16"
                             FontWeight="SemiBold"
                             Background="Transparent"
                             Foreground="{StaticResource Text/Primary}"
                             BorderThickness="0,0,0,1"
                             BorderBrush="{StaticResource Accent/Primary}"
                             MinWidth="260"
                             x:Name="RenameBox"/>
                    <Button Content="Save"
                            Command="{Binding SaveTitleCommand}"
                            Style="{StaticResource AppButton.CompactGhost}"
                            Margin="10,0,6,0"/>
                    <Button Content="Cancel"
                            Command="{Binding CancelRenameCommand}"
                            Style="{StaticResource AppButton.CompactGhost}"/>
                </StackPanel>
            </Border>

            <!-- Messages / Empty states -->
            <Grid Grid.Row="1">
                <!-- No session selected -->
                <controls:EmptyResultsState
                    Title="IronDev Command Centre"
                    Description="Select a conversation or start a new one to begin."
                    ActionText="New Chat" ActionCommand="{Binding NewChatCommand}"
                    Visibility="{Binding HasSelectedSession, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                <!-- Session with no messages -->
                <controls:EmptyResultsState
                    Title="Start the conversation"
                    Description="Ask about code, tickets, decisions, or implementation plans.">
                    <controls:EmptyResultsState.Style>
                        <Style TargetType="controls:EmptyResultsState">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasSelectedSession}" Value="True"/>
                                        <Condition Binding="{Binding Messages.Count}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </controls:EmptyResultsState.Style>
                </controls:EmptyResultsState>

                <!-- Message thread -->
                <ScrollViewer x:Name="MessagesScroller" VerticalScrollBarVisibility="Auto"
                              Padding="24,18,24,16">
                    <ItemsControl ItemsSource="{Binding Messages}"
                                  HorizontalAlignment="Stretch"
                                  Width="{Binding ViewportWidth, ElementName=MessagesScroller}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Bubble row -->
                                    <Grid Grid.Row="0">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="user">
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- AI avatar -->
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                                                Background="{StaticResource Background/Panel}"
                                                BorderBrush="{StaticResource Accent/Primary}" BorderThickness="1"
                                                VerticalAlignment="Top" Margin="0,2,10,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="AI" FontSize="8" FontWeight="Bold"
                                                       Foreground="{StaticResource Accent/Primary}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Message card -->
                                        <Grid Grid.Column="1">
                                                        <Border Padding="0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Role}" Value="user">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <controls:AssistantResponseCard Text="{Binding MessageText}"
                                                                               ShowSavedState="{Binding HasPersistedMessage}"
                                                                               SavedText="Response saved"
                                                                               UseChrome="False"/>
                                            </Border>

                                            <Border CornerRadius="8" Padding="12,9" MaxWidth="560"
                                                    Background="{StaticResource Accent/Primary}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Role}" Value="user">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding MessageText}"
                                                               TextWrapping="Wrap"
                                                               FontSize="13"
                                                               LineHeight="20"
                                                               Foreground="#0D1117"/>
                                                    <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm'}"
                                                               FontSize="10"
                                                               Opacity="0.45"
                                                               Margin="0,5,0,0"
                                                               Foreground="#0D1117"
                                                               HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- User avatar -->
                                        <Border Grid.Column="2" Width="28" Height="28" CornerRadius="14"
                                                Background="{StaticResource Accent/Primary}"
                                                VerticalAlignment="Top" Margin="10,2,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Role}" Value="user">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="ME" FontSize="8" FontWeight="Bold"
                                                       Foreground="#0D1117"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                    <!-- Action strip - assistant only -->
                                                    <controls:MessageActionStrip Grid.Row="1"
                                                                                 Margin="0,6,0,0"
                                                                 CommandParameter="{Binding}"
                                                                 PlanCommand="{Binding DataContext.CreatePlanCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                 TicketCommand="{Binding DataContext.CreateTicketCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                 DecisionCommand="{Binding DataContext.SaveDecisionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                 DocumentCommand="{Binding DataContext.CreateDocumentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                 SummaryCommand="{Binding DataContext.SaveSummaryFromMessageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                 CopyCommand="{Binding DataContext.CopyMessageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                 UsefulCommand="{Binding DataContext.BeginFeedbackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                 WeakCommand="{Binding DataContext.BeginFeedbackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                 FeedbackSaved="{Binding FeedbackSaved}">
                                        <controls:MessageActionStrip.Style>
                                            <Style TargetType="controls:MessageActionStrip">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="assistant">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </controls:MessageActionStrip.Style>
                                    </controls:MessageActionStrip>


                                    <!-- Reason picker - shown when AwaitingReason is true -->
                                    <Border Grid.Row="2"
                                            Margin="38,4,0,0" Padding="8,5"
                                            Background="{StaticResource Background/Surface}"
                                            BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1"
                                            CornerRadius="5">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AwaitingReason}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="Why?" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Text/Muted}" Margin="0,0,0,4"/>
                                            <WrapPanel>
                                                <!-- Useful reasons -->
                                                <WrapPanel>
                                                    <WrapPanel.Style>
                                                        <Style TargetType="WrapPanel">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FeedbackRating}" Value="Useful">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </WrapPanel.Style>
                                                    <Button Content="Good file grounding" Height="20" Padding="7,0" FontSize="10" Margin="0,0,3,3"
                                                            Command="{Binding DataContext.SubmitFeedbackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="Useful|Good file grounding"
                                                            Style="{StaticResource AppButton.Ghost}"/>
                                                    <Button Content="Clear answer" Height="20" Padding="7,0" FontSize="10" Margin="0,0,3,3"
                                                            Command="{Binding DataContext.SubmitFeedbackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="Useful|Clear answer"
                                                            Style="{StaticResource AppButton.Ghost}"/>
                                                    <Button Content="Good ticket detail" Height="20" Padding="7,0" FontSize="10" Margin="0,0,3,3"
                                                            Command="{Binding DataContext.SubmitFeedbackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="Useful|Good ticket detail"
                                                            Style="{StaticResource AppButton.Ghost}"/>
                                                    <Button Content="Good implementation guidance" Height="20" Padding="7,0" FontSize="10" Margin="0,0,3,3"
                                                            Command="{Binding DataContext.SubmitFeedbackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="Useful|Good implementation guidance"
                                                            Style="{StaticResource AppButton.Ghost}"/>
                                                    <Button Content="Other" Height="20" Padding="7,0" FontSize="10" Margin="0,0,0,3"
                                                            Command="{Binding DataContext.SubmitFeedbackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="Useful|Other"
                                                            Style="{StaticResource AppButton.Ghost}"/>
                                                </WrapPanel>
                                                <!-- Weak reasons -->
                                                <WrapPanel>
                                                    <WrapPanel.Style>
                                                        <Style TargetType="WrapPanel">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FeedbackRating}" Value="Weak">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </WrapPanel.Style>
                                                    <Button Content="Too generic" Height="20" Padding="7,0" FontSize="10" Margin="0,0,3,3"
                                                            Command="{Binding DataContext.SubmitFeedbackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="Weak|Too generic"
                                                            Style="{StaticResource AppButton.Ghost}"/>
                                                    <Button Content="Wrong files/classes" Height="20" Padding="7,0" FontSize="10" Margin="0,0,3,3"
                                                            Command="{Binding DataContext.SubmitFeedbackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="Weak|Wrong files/classes"
                                                            Style="{StaticResource AppButton.Ghost}"/>
                                                    <Button Content="Missed project context" Height="20" Padding="7,0" FontSize="10" Margin="0,0,3,3"
                                                            Command="{Binding DataContext.SubmitFeedbackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="Weak|Missed project context"
                                                            Style="{StaticResource AppButton.Ghost}"/>
                                                    <Button Content="Too verbose" Height="20" Padding="7,0" FontSize="10" Margin="0,0,3,3"
                                                            Command="{Binding DataContext.SubmitFeedbackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="Weak|Too verbose"
                                                            Style="{StaticResource AppButton.Ghost}"/>
                                                    <Button Content="Not actionable" Height="20" Padding="7,0" FontSize="10" Margin="0,0,3,3"
                                                            Command="{Binding DataContext.SubmitFeedbackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="Weak|Not actionable"
                                                            Style="{StaticResource AppButton.Ghost}"/>
                                                    <Button Content="Other" Height="20" Padding="7,0" FontSize="10" Margin="0,0,0,3"
                                                            Command="{Binding DataContext.SubmitFeedbackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="Weak|Other"
                                                            Style="{StaticResource AppButton.Ghost}"/>
                                                </WrapPanel>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- COMPOSER -->
            <Border Grid.Row="2"
                    Background="{StaticResource Background/Panel}"
                    BorderBrush="{StaticResource Border/Subtle}" BorderThickness="0,1,0,0"
                    Padding="16,8,16,10">
                <StackPanel>

                    <!-- Thinking indicator -->
                    <Border Margin="0,0,0,5"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="5" Height="5" Fill="{StaticResource Accent/Primary}"
                                     Margin="0,0,5,0" Opacity="0.9"/>
                            <TextBlock Text="IronDev is thinking..." FontSize="11" FontStyle="Italic"
                                       Foreground="{StaticResource Accent/Primary}" Opacity="0.8"/>
                        </StackPanel>
                    </Border>

                    <controls:InfoBanner Title="{Binding StatusMessage}"
                                         BadgeText="CHAT"
                                         Margin="0,0,0,7"
                                         Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <controls:ChatStatusStrip ProjectText="{Binding ActiveProjectName, StringFormat='Project: {0}'}"
                                              IndexText="Index: Ready"
                                              ContextText="{Binding ChatContextStatusText, StringFormat='Context: {0}'}"
                                              DraftText="Draft ticket: Available"
                                              ContextItems="{Binding ContextChips}"
                                              Margin="0,0,0,7"/>

                    <!-- Input row -->
                    <controls:ComposerBar
                        Text="{Binding PromptText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Placeholder="Ask about code, tickets, decisions, or implementation plans..."
                        SendCommand="{Binding SendMessageCommand}"/>

                    <!-- Quick actions -->
                    <WrapPanel Margin="0,5,0,0"
                               Visibility="{Binding HasSelectedSession, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button Content="Create Plan"
                                Command="{Binding NavigateToPlanCommand}"
                                Style="{StaticResource AppButton.CompactGhost}"
                                Margin="0,0,4,0"/>
                        <Button Content="New Ticket"
                                Command="{Binding NavigateToTicketCommand}"
                                Style="{StaticResource AppButton.CompactGhost}"
                                Margin="0,0,4,0"/>
                        <Button Content="New Decision"
                                Command="{Binding NavigateToDecisionCommand}"
                                Style="{StaticResource AppButton.CompactGhost}"/>
                    </WrapPanel>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
