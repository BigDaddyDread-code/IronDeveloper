<UserControl x:Class="IronDev.Agent.Views.Workspaces.ProjectProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             xmlns:controls="http://schemas.irondeveloper.com/controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ProjectProfileViewModel, IsDesignTimeCreatable=False}">

    <ScrollViewer Background="{StaticResource Background/App}">
        <StackPanel Margin="28,24,28,28" MaxWidth="980" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="PROJECT SETTINGS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
            <TextBlock Text="Project Profile" Style="{StaticResource Typography.ScreenTitle}" Margin="0,0,0,28"/>

            <Border Background="{StaticResource Background/Panel}"
                    BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1"
                    CornerRadius="{StaticResource Radius/Large}" Padding="22">
                <StackPanel>
                    
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="GENERAL SETTINGS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <CheckBox IsChecked="{Binding IsExternalProject}" Content="This is an external sandbox project" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Auto-Detect" Command="{Binding AutoDetectCommand}" 
                                Style="{StaticResource AppButton.Secondary}" Height="32" Padding="12,0"/>
                    </Grid>

                    <UniformGrid Columns="2" Margin="0,0,0,24">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Application Type" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding ApplicationTypes}" 
                                      SelectedValue="{Binding SelectedApplicationType}"
                                      SelectedValuePath="Value" DisplayMemberPath="DisplayName"/>
                        </StackPanel>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Primary Language" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding PrimaryLanguages}" 
                                      SelectedValue="{Binding SelectedPrimaryLanguage}"
                                      SelectedValuePath="Value" DisplayMemberPath="DisplayName"/>
                        </StackPanel>
                    </UniformGrid>

                    <UniformGrid Columns="2" Margin="0,0,0,24">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Framework / Runtime" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Frameworks}" 
                                      SelectedValue="{Binding SelectedFramework}"
                                      SelectedValuePath="Value" DisplayMemberPath="DisplayName"/>
                        </StackPanel>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Database Engine" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding DatabaseEngines}" 
                                      SelectedValue="{Binding SelectedDatabaseEngine}"
                                      SelectedValuePath="Value" DisplayMemberPath="DisplayName"/>
                        </StackPanel>
                    </UniformGrid>

                    <UniformGrid Columns="2" Margin="0,0,0,24">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Data Access Style" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding DataAccessStyles}" 
                                      SelectedValue="{Binding SelectedDataAccessStyle}"
                                      SelectedValuePath="Value" DisplayMemberPath="DisplayName"/>
                        </StackPanel>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Test Framework" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding TestFrameworks}" 
                                      SelectedValue="{Binding SelectedTestFramework}"
                                      SelectedValuePath="Value" DisplayMemberPath="DisplayName"/>
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock Text="Solution File Path" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding SolutionFile}" Margin="0,0,0,24" FontFamily="Consolas"/>

                    <TextBlock Text="Safe Write Root" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding SafeWriteRoot}" Margin="0,0,0,24" FontFamily="Consolas"/>

                    <TextBlock Text="BUILD &amp; TEST COMMANDS" Style="{StaticResource Typography.Eyebrow}" Margin="0,12,0,12"/>
                    
                    <TextBlock Text="Default Build Command" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding BuildCommandText}" Margin="0,0,0,16" FontFamily="Consolas"/>

                    <TextBlock Text="Default Test Command" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding TestCommandText}" Margin="0,0,0,24" FontFamily="Consolas"/>

                    <TextBlock Text="PERMISSIONS" Style="{StaticResource Typography.Eyebrow}" Margin="0,12,0,12"/>
                    <StackPanel Margin="0,0,0,24">
                        <CheckBox IsChecked="{Binding AllowBuilderApply}" Content="Allow AI Builder to apply changes automatically" Margin="0,0,0,8"/>
                        <CheckBox IsChecked="{Binding AllowWritesOutsideProjectRoot}" Content="Allow writes outside of project root (HIGH RISK)" Foreground="{StaticResource StatusErrorBrush}"/>
                    </StackPanel>

                    <TextBlock Text="Profile Notes" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding ProfileNotes}" AcceptsReturn="True" MinHeight="80" TextWrapping="Wrap" Margin="0,0,0,32"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="{StaticResource Accent/Primary}"/>
                        <Button Content="SAVE PROFILE" Command="{Binding SaveCommand}" 
                                Style="{StaticResource AppButton.Primary}" Width="150" Height="40"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <controls:SurfacePanel Variant="Subtle" Margin="0,24,0,0" Padding="16">
                <StackPanel>
                    <TextBlock Text="SECURITY NOTE" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8" Foreground="{StaticResource Warning}"/>
                    <TextBlock Text="Safe Write Root restricts where the AI Builder can modify files. For external projects, this should usually be set to the project's own folder. Allowing writes outside the root can expose your system to unexpected modifications." 
                               FontSize="12" Foreground="{StaticResource Text/Muted}" TextWrapping="Wrap"/>
                </StackPanel>
            </controls:SurfacePanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
