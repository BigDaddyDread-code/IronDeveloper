<UserControl x:Class="IronDev.Agent.Views.Workspaces.KnowledgeCompilerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="http://schemas.irondeveloper.com/controls"
             xmlns:primitives="clr-namespace:IronDeveloperControls.Primitives;assembly=IronDeveloperControls"
             Background="Transparent">
    <Grid Background="{StaticResource IronDev.Brush.Background.App}"
          AutomationProperties.AutomationId="memory.workspace">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:WorkspaceHeader Grid.Row="0"
                                  Eyebrow="PROJECT KNOWLEDGE"
                                  Title="Documents / Memory"
                                  Subtitle="{Binding ActiveProjectName}"
                                  AutomationProperties.AutomationId="memory.header">
            <controls:WorkspaceHeader.Actions>
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource IronDev.StatusBadge.Host}"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding DiscussionCountText}"
                                   Foreground="{StaticResource IronDev.Brush.Text.Secondary}"
                                   FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Border Style="{StaticResource IronDev.StatusBadge.Host}"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding KnowledgeCurrentnessText}"
                                   Foreground="{StaticResource IronDev.Brush.Accent.Trace}"
                                   FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource IronDev.CommandButton.Ghost}"
                            Margin="0,0,8,0"
                            ToolTip="Reload discussion documents."/>
                    <Button Content="Apply Selected"
                            Command="{Binding ApplySelectedProposalsCommand}"
                            Style="{StaticResource IronDev.CommandButton.Primary}"
                            ToolTipService.ShowOnDisabled="True"
                            ToolTip="Apply selected decisions, documents, tickets, and other artefact proposals."/>
                </StackPanel>
            </controls:WorkspaceHeader.Actions>
        </controls:WorkspaceHeader>

        <primitives:InfoBanner Grid.Row="1"
                               Title="{Binding BannerTitle}"
                               Message="{Binding BannerMessage}"
                               Status="{Binding BannerStatus}"
                               BadgeText="STATE"
                               Margin="0,14,0,14"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="300"/>
                <ColumnDefinition Width="*" MinWidth="500"/>
                <ColumnDefinition Width="320" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <controls:WorkspaceListPane Grid.Column="0"
                                        Eyebrow="KNOWLEDGE QUEUE"
                                        Title="Discussions"
                                        Margin="0,0,12,0"
                                        ItemsSource="{Binding DiscussionDocuments}"
                                        SelectedItem="{Binding SelectedDiscussion, Mode=TwoWay}">
                <controls:WorkspaceListPane.SearchField>
                    <StackPanel>
                        <TextBlock Text="PROJECT SUMMARY"
                                   Style="{StaticResource Typography.Eyebrow}"
                                   Margin="0,0,0,8"/>
                        <TextBox Text="{Binding ProjectSummaryText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="92"
                                 MaxHeight="120"
                                 Style="{StaticResource IronDev.Input.TextBox}"
                                 Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,14">
                            <Button Content="Generate"
                                    Command="{Binding GenerateDiscussionsCommand}"
                                    Style="{StaticResource IronDev.CommandButton.Primary}"
                                    Margin="0,0,8,0"
                                    ToolTipService.ShowOnDisabled="True"
                                    ToolTip="Generate discussion documents from the project summary."/>
                            <Button Content="Save Selected"
                                    Command="{Binding SaveSelectedDiscussionsCommand}"
                                    Style="{StaticResource IronDev.CommandButton.Ghost}"
                                    ToolTipService.ShowOnDisabled="True"
                                    ToolTip="Save selected draft discussions into IronDev project memory."/>
                        </StackPanel>

                        <TextBlock Text="SEMANTIC SEARCH"
                                   Style="{StaticResource Typography.Eyebrow}"
                                   Margin="0,0,0,8"/>
                        <DockPanel LastChildFill="True"
                                   AutomationProperties.AutomationId="memory.search">
                            <Button DockPanel.Dock="Right"
                                    Content="Search"
                                    Command="{Binding RunSemanticSearchCommand}"
                                    Style="{StaticResource IronDev.CommandButton.Ghost}"
                                    Margin="8,0,0,0"
                                    AutomationProperties.AutomationId="memory.command.search"
                                    ToolTipService.ShowOnDisabled="True"
                                    ToolTip="Search project memory through the semantic index."/>
                            <controls:SearchField Text="{Binding SemanticSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SearchCommand="{Binding RunSemanticSearchCommand}"
                                                  IsBusy="{Binding IsSemanticMemoryBusy}"
                                                  Placeholder="Search related project memory"/>
                        </DockPanel>
                        <TextBlock Text="{Binding SemanticSearchStatusText}"
                                   Foreground="{StaticResource Text/Muted}"
                                   FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"/>
                        <ListBox ItemsSource="{Binding SemanticSearchResults}"
                                 SelectedItem="{Binding SelectedSemanticSearchResult, Mode=TwoWay}"
                                 ItemContainerStyle="{StaticResource AppListBoxItem.Compact}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MaxHeight="180"
                                 Margin="0,8,0,0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 AutomationProperties.AutomationId="memory.resultList">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="2,6"
                                                AutomationProperties.AutomationId="memory.resultRow">
                                        <DockPanel LastChildFill="True">
                                            <StackPanel DockPanel.Dock="Right"
                                                        Orientation="Horizontal"
                                                        Margin="8,0,0,0">
                                                <controls:StatusBadge Text="{Binding StaleText}"
                                                                      Status="Info"
                                                                      Margin="0,0,6,0"/>
                                                <controls:StatusBadge Text="{Binding ScoreText}"
                                                                      Status="ReviewRequired"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource Text/Primary}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                        <StackPanel AutomationProperties.AutomationId="memory.result.detail">
                                            <TextBlock Text="{Binding Snippet}"
                                                       Foreground="{StaticResource Text/Secondary}"
                                                       FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="38"
                                                       Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding IndexedUtcLabel}"
                                                       Foreground="{StaticResource Text/Muted}"
                                                       FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                                       Margin="0,5,0,0"
                                                       ToolTip="{Binding IndexedUtcTooltip}"/>
                                            <Button Content="Create Ticket"
                                                    IsEnabled="False"
                                                    Style="{StaticResource IronDev.CommandButton.Ghost}"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,6,0,0"
                                                    AutomationProperties.AutomationId="memory.command.createTicketFromResult"
                                                    ToolTipService.ShowOnDisabled="True"
                                                    ToolTip="Creating tickets from memory results must go through the IronDev ticket API and is not wired here yet."/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding SimilarityText}"
                                                   Foreground="{StaticResource Text/Muted}"
                                                   FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </controls:WorkspaceListPane.SearchField>

                <controls:WorkspaceListPane.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="3"
                                    Background="{StaticResource IronDev.Brush.Accent.Trace}"
                                    CornerRadius="2"
                                    Margin="0,2,8,2">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <controls:SurfacePanel Grid.Column="1"
                                                   Padding="12,10"
                                                   CornerRadius="{StaticResource IronDev.Radius.Medium}">
                                <controls:SurfacePanel.Style>
                                    <Style TargetType="{x:Type controls:SurfacePanel}">
                                        <Setter Property="Variant" Value="Subtle"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="True">
                                                <Setter Property="Variant" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </controls:SurfacePanel.Style>
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding LastChangedLabel}"
                                                   Foreground="{StaticResource Text/Muted}"
                                                   FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                                   Margin="8,1,0,0"
                                                   ToolTip="{Binding LastChangedUtcTooltip}"/>
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{StaticResource Text/Primary}"
                                                   FontSize="{StaticResource IronDev.Font.Size.Body}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                    <TextBlock Text="{Binding PreviewText}"
                                               Foreground="{StaticResource Text/Secondary}"
                                               FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                               TextWrapping="Wrap"
                                               MaxHeight="38"
                                               Margin="0,0,0,8"/>
                                    <WrapPanel>
                                        <controls:StatusBadge Text="{Binding PersistenceText}" Status="Info" Margin="0,0,6,4"/>
                                        <controls:StatusBadge Text="{Binding CurrentnessText}" Status="Ready" Margin="0,0,6,4"/>
                                        <controls:StatusBadge Text="{Binding SourceLabel}" Status="Neutral" Margin="0,0,6,4"/>
                                    </WrapPanel>
                                </StackPanel>
                            </controls:SurfacePanel>
                        </Grid>
                    </DataTemplate>
                </controls:WorkspaceListPane.ItemTemplate>

                <controls:WorkspaceListPane.FooterActions>
                    <StackPanel>
                        <TextBlock Text="{Binding SemanticMemoryStatusText}"
                                   Foreground="{StaticResource Text/Secondary}"
                                   FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SemanticMemoryDetailText}"
                                   Foreground="{StaticResource Text/Muted}"
                                   FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,8"/>
                        <Button Content="Rebuild Semantic Index"
                                Command="{Binding RebuildSemanticIndexCommand}"
                                Style="{StaticResource IronDev.CommandButton.Ghost}"
                                HorizontalAlignment="Left"
                                ToolTipService.ShowOnDisabled="True"
                                ToolTip="Rebuild embeddings for active project knowledge."/>
                    </StackPanel>
                </controls:WorkspaceListPane.FooterActions>
            </controls:WorkspaceListPane>

            <controls:SurfacePanel Grid.Column="1"
                                   Variant="Subtle"
                                   Padding="0"
                                   Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="18,16"
                            BorderBrush="{StaticResource Border/Subtle}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                        Margin="0,0,16,0">
                                <TextBlock Text="SELECTED KNOWLEDGE"
                                           Style="{StaticResource Typography.Eyebrow}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedDiscussionTitle}"
                                           Foreground="{StaticResource Text/Primary}"
                                           FontSize="{StaticResource IronDev.Font.Size.Title}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding SelectedDiscussionSourceText}"
                                           Foreground="{StaticResource Text/Secondary}"
                                           FontSize="{StaticResource IronDev.Font.Size.Small}"
                                           Margin="0,4,0,0"
                                           ToolTip="{Binding SelectedDiscussionUtcTooltip}"/>
                            </StackPanel>
                            <WrapPanel Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top">
                                <controls:StatusBadge Text="{Binding KnowledgeCurrentnessText}" Status="Ready" Margin="0,0,6,6"/>
                                <controls:StatusBadge Text="{Binding ProposalCountText}" Status="Info" Margin="0,0,6,6"/>
                                <controls:StatusBadge Text="{Binding MemoryResultCountText}" Status="Neutral" Margin="0,0,0,6"/>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="14,12,14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                BorderBrush="{StaticResource Border/Subtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                Padding="12"
                                Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="BRIEF" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedDiscussion.PreviewText, FallbackValue='Select a discussion'}"
                                           Foreground="{StaticResource Text/Primary}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                BorderBrush="{StaticResource Border/Subtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                Padding="12"
                                Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="DECISIONS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding DecisionProposalCountText}" Foreground="{StaticResource Text/Primary}" FontWeight="SemiBold"/>
                                <TextBlock Foreground="{StaticResource Text/Muted}"
                                           FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                           Margin="0,3,0,0">
                                    <Run Text="Confidence: "/>
                                    <Run Text="{Binding ResolutionConfidenceScore}"/>
                                    <Run Text="/100"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                BorderBrush="{StaticResource Border/Subtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                Padding="12"
                                Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="TICKETS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding TicketProposalCountText}" Foreground="{StaticResource Text/Primary}" FontWeight="SemiBold"/>
                                <TextBlock Text="Created through IronDev ticket API when proposals are applied"
                                           Foreground="{StaticResource Text/Muted}"
                                           FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3"
                                Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                BorderBrush="{StaticResource Border/Subtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="NEXT ACTION" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding KnowledgeNextActionText}"
                                           Foreground="{StaticResource Text/Primary}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding StatusText}"
                                           Foreground="{StaticResource Text/Muted}"
                                           FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2"
                          Margin="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*"/>
                            <ColumnDefinition Width="1.15*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                BorderBrush="{StaticResource Border/Subtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                Padding="14"
                                Margin="0,0,10,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="150"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="CONTENT"
                                           Style="{StaticResource Typography.Eyebrow}"
                                           Margin="0,0,0,8"/>
                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              Margin="0,0,0,12">
                                    <controls:StructuredTextView Text="{Binding SelectedDiscussion.FullPromptText}"
                                                                 TextSize="13"/>
                                </ScrollViewer>
                                <TextBlock Grid.Row="2"
                                           Text="DISCUSSION NOTES"
                                           Style="{StaticResource Typography.Eyebrow}"
                                           Margin="0,0,0,8"/>
                                <TextBox Grid.Row="3"
                                         Text="{Binding DiscussionNotes, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Style="{StaticResource IronDev.Input.TextBox}"
                                         ToolTip="Add the current discussion outcome before resolving."/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                BorderBrush="{StaticResource Border/Subtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0"
                                           Margin="0,0,0,10">
                                    <controls:StatusBadge DockPanel.Dock="Right"
                                                          Text="{Binding ResolutionConfidenceScore, StringFormat={}{0}/100}"
                                                          Status="ReviewRequired"/>
                                    <StackPanel>
                                        <TextBlock Text="PROPOSED ARTEFACTS"
                                                   Style="{StaticResource Typography.Eyebrow}"/>
                                        <TextBlock Text="{Binding ProposalCountText}"
                                                   Foreground="{StaticResource Text/Primary}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </DockPanel>

                                <Border Grid.Row="1"
                                        Style="{StaticResource SurfacePanel.Interactive}"
                                        Padding="12"
                                        Margin="0,0,0,12"
                                        Visibility="{Binding HasResolutionSummary, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="Resolution"
                                                   Style="{StaticResource Typography.Eyebrow}"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding ResolutionSummary}"
                                                   Foreground="{StaticResource Text/Secondary}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <ScrollViewer Grid.Row="2"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Proposals}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource SurfacePanel.Interactive}"
                                                        Padding="12"
                                                        Margin="0,0,0,10">
                                                    <StackPanel>
                                                        <DockPanel LastChildFill="True">
                                                            <StackPanel DockPanel.Dock="Right"
                                                                        Orientation="Horizontal">
                                                                <controls:StatusBadge Text="{Binding ConfidenceText}"
                                                                                      Status="Info"
                                                                                      Margin="0,0,6,0"/>
                                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                          VerticalAlignment="Center"
                                                                          ToolTip="Include this artefact when applying selected proposals."/>
                                                            </StackPanel>
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding KindText}"
                                                                               Style="{StaticResource Typography.Eyebrow}"
                                                                               Foreground="{StaticResource Accent/Primary}"
                                                                               Margin="0,0,8,0"/>
                                                                    <TextBlock Text="{Binding ApplyStatusText}"
                                                                               Foreground="{StaticResource Text/Muted}"
                                                                               FontSize="{StaticResource IronDev.Font.Size.Caption}"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Title}"
                                                                           Foreground="{StaticResource Text/Primary}"
                                                                           FontWeight="SemiBold"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,4,0,0"/>
                                                            </StackPanel>
                                                        </DockPanel>

                                                        <TextBlock Text="{Binding Summary}"
                                                                   Foreground="{StaticResource Text/Secondary}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,8,0,0"/>

                                                        <Expander Header="Evidence and acceptance"
                                                                  Margin="0,10,0,0">
                                                            <StackPanel Margin="0,8,0,0">
                                                                <TextBlock Text="Detail"
                                                                           Style="{StaticResource Typography.Eyebrow}"
                                                                           Margin="0,0,0,4"/>
                                                                <controls:StructuredTextView Text="{Binding Detail}"
                                                                                             TextSize="12"/>

                                                                <TextBlock Text="Acceptance Criteria"
                                                                           Style="{StaticResource Typography.Eyebrow}"
                                                                           Margin="0,10,0,4"/>
                                                                <controls:StructuredTextView Text="{Binding AcceptanceCriteriaText}"
                                                                                             TextSize="12"/>

                                                                <TextBlock Text="Test Suggestions"
                                                                           Style="{StaticResource Typography.Eyebrow}"
                                                                           Margin="0,10,0,4"/>
                                                                <controls:StructuredTextView Text="{Binding TestSuggestionsText}"
                                                                                             TextSize="12"/>

                                                                <TextBlock Text="Grounding Warnings"
                                                                           Style="{StaticResource Typography.Eyebrow}"
                                                                           Margin="0,10,0,4"
                                                                           Visibility="{Binding HasGroundingWarnings, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                <controls:StructuredTextView Text="{Binding GroundingWarningsText}"
                                                                                             TextSize="12"
                                                                                             Visibility="{Binding HasGroundingWarnings, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                            </StackPanel>
                                                        </Expander>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <controls:EditorActionBar Grid.Row="3"
                                              Background="{StaticResource Background/Surface}"
                                              SeparatorThickness="0,1,0,0"
                                              BarPadding="16,12"
                                              StatusText="{Binding StatusText}">
                        <controls:EditorActionBar.LeftActions>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Resolve Discussion"
                                        Command="{Binding ResolveSelectedDiscussionCommand}"
                                        Style="{StaticResource IronDev.CommandButton.Primary}"
                                        Margin="0,0,8,0"
                                        ToolTipService.ShowOnDisabled="True"
                                        ToolTip="Resolve the selected saved discussion into reviewable artefacts."/>
                                <Button Content="Search Related Memory"
                                        Command="{Binding RunSemanticSearchCommand}"
                                        Style="{StaticResource IronDev.CommandButton.Secondary}"
                                        Margin="0,0,8,0"
                                        ToolTipService.ShowOnDisabled="True"
                                        ToolTip="Search memory using the current semantic search query."/>
                                <Button Content="Reload Into Chat"
                                        IsEnabled="False"
                                        Style="{StaticResource IronDev.CommandButton.Ghost}"
                                        ToolTipService.ShowOnDisabled="True"
                                        ToolTip="Reloading selected document context into Chat is not wired in this workspace yet."/>
                            </StackPanel>
                        </controls:EditorActionBar.LeftActions>

                        <controls:EditorActionBar.RightActions>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Clear Resolution"
                                        Command="{Binding ClearResolutionCommand}"
                                        Style="{StaticResource IronDev.CommandButton.Ghost}"
                                        Margin="0,0,8,0"
                                        ToolTip="Clear proposed artefacts from the current discussion."/>
                                <Button Content="Apply Selected"
                                        Command="{Binding ApplySelectedProposalsCommand}"
                                        Style="{StaticResource IronDev.CommandButton.Primary}"
                                        ToolTipService.ShowOnDisabled="True"
                                        ToolTip="Persist selected proposed artefacts through the existing IronDev workflow."/>
                            </StackPanel>
                        </controls:EditorActionBar.RightActions>
                    </controls:EditorActionBar>
                </Grid>
            </controls:SurfacePanel>

            <controls:SurfacePanel Grid.Column="2"
                                   Variant="Subtle"
                                   Padding="0"
                                   AutomationProperties.AutomationId="memory.inspector">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="16,18,16,12"
                            BorderBrush="{StaticResource Border/Subtle}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="CONTEXT INSPECTOR"
                                       Style="{StaticResource Typography.Eyebrow}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Source, memory ranking, generated artefacts, and traceability"
                                       Foreground="{StaticResource Text/Secondary}"
                                       FontSize="{StaticResource IronDev.Font.Size.Body}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="14">
                        <StackPanel>
                            <Border Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                    BorderBrush="{StaticResource Border/Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                    Padding="12"
                                    Margin="0,0,0,10"
                                    AutomationProperties.AutomationId="memory.inspector.provenance">
                                <StackPanel>
                                    <TextBlock Text="Provenance" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding SelectedDiscussionTitle}"
                                               Foreground="{StaticResource Text/Primary}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding SelectedDiscussionSourceText}"
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding SelectedDiscussionUtcMetadata}"
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"
                                               ToolTip="{Binding SelectedDiscussionUtcTooltip}"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                    BorderBrush="{StaticResource Border/Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                    Padding="12"
                                    Margin="0,0,0,10"
                                    AutomationProperties.AutomationId="memory.inspector.sourceLinks">
                                <StackPanel>
                                    <TextBlock Text="Source links" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding SelectedDiscussion.SuggestedArea, FallbackValue='No source area selected'}"
                                               Foreground="{StaticResource Text/Primary}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="External source links are not exposed for discussion documents yet."
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                    BorderBrush="{StaticResource Border/Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                    Padding="12"
                                    Margin="0,0,0,10"
                                    AutomationProperties.AutomationId="memory.inspector.relatedDecisions">
                                <StackPanel>
                                    <TextBlock Text="Related decisions" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding DecisionProposalCountText}"
                                               Foreground="{StaticResource Text/Primary}"
                                               FontWeight="SemiBold"/>
                                    <ItemsControl ItemsSource="{Binding OpenQuestions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{StaticResource Text/Muted}"
                                                           FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,5,0,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                    BorderBrush="{StaticResource Border/Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                    Padding="12"
                                    Margin="0,0,0,10"
                                    AutomationProperties.AutomationId="memory.inspector.linkedTickets">
                                <StackPanel>
                                    <TextBlock Text="Generated / linked tickets" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TicketProposalCountText}"
                                               Foreground="{StaticResource Text/Primary}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Ticket candidates become IronDev tickets only when applied through the API-backed workflow."
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                    BorderBrush="{StaticResource Border/Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                    Padding="12"
                                    Margin="0,0,0,10"
                                    AutomationProperties.AutomationId="memory.inspector.memoryEvidence">
                                <StackPanel>
                                    <TextBlock Text="Memory ranking evidence" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding SelectedMemoryEvidenceText}"
                                               Foreground="{StaticResource Text/Primary}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding SelectedMemorySourceText}"
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                               TextWrapping="Wrap"
                                               Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding SelectedMemoryUtcMetadata}"
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                               TextWrapping="Wrap"
                                               Margin="0,5,0,0"
                                               ToolTip="{Binding SelectedMemoryUtcTooltip}"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                    BorderBrush="{StaticResource Border/Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                    Padding="12"
                                    Margin="0,0,0,10"
                                    AutomationProperties.AutomationId="memory.inspector.traceLinks">
                                <StackPanel>
                                    <TextBlock Text="Trace links" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                                    <TextBlock Text="No LLM trace link is attached to the selected discussion."
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                    BorderBrush="{StaticResource Border/Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                    Padding="12"
                                    AutomationProperties.AutomationId="memory.inspector.warnings">
                                <StackPanel>
                                    <TextBlock Text="Stale / conflict warnings" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding SemanticMemoryDetailText}"
                                               Foreground="{StaticResource Text/Secondary}"
                                               FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="Currentness and stale warnings are based on UTC memory/index timestamps."
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </controls:SurfacePanel>
        </Grid>

    </Grid>
</UserControl>
