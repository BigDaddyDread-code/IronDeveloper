<UserControl x:Class="IronDev.Agent.Views.Workspaces.KnowledgeCompilerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="http://schemas.irondeveloper.com/controls"
             xmlns:primitives="clr-namespace:IronDeveloperControls.Primitives;assembly=IronDeveloperControls"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:WorkspaceHeader Grid.Row="0"
                                  Eyebrow="PROJECT DISCOVERY"
                                  Title="Knowledge Compiler"
                                  Subtitle="{Binding CompilerStatusText}">
            <controls:WorkspaceHeader.Actions>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource AppButton.CompactGhost}"
                            Margin="0,0,8,0"/>
                    <Button Content="Apply Selected"
                            Command="{Binding ApplySelectedProposalsCommand}"
                            Style="{StaticResource AppButton.Primary}"/>
                </StackPanel>
            </controls:WorkspaceHeader.Actions>
        </controls:WorkspaceHeader>

        <primitives:InfoBanner Grid.Row="1"
                               Title="{Binding BannerTitle}"
                               Message="{Binding BannerMessage}"
                               Status="{Binding BannerStatus}"
                               BadgeText="STATE"
                               Margin="0,14,0,14"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource SurfacePanel.Subtle}"
                    Padding="14"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="260"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="PROJECT SUMMARY"
                               Style="{StaticResource Typography.Eyebrow}"
                               Margin="0,0,0,8"/>

                    <TextBox Grid.Row="1"
                             Text="{Binding ProjectSummaryText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="124"
                             Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,0,0,12">
                        <Button Content="Generate"
                                Command="{Binding GenerateDiscussionsCommand}"
                                Style="{StaticResource AppButton.Primary}"
                                Margin="0,0,8,0"/>
                        <Button Content="Save Selected"
                                Command="{Binding SaveSelectedDiscussionsCommand}"
                                Style="{StaticResource AppButton.CompactGhost}"/>
                    </StackPanel>

                    <Border Grid.Row="3"
                            Style="{StaticResource SurfacePanel.Interactive}"
                            Padding="12"
                            Margin="0,0,0,12"
                            AutomationProperties.AutomationId="memory.inspector">
                        <StackPanel>
                            <DockPanel LastChildFill="False"
                                       Margin="0,0,0,8">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="SEMANTIC MEMORY"
                                           Style="{StaticResource Typography.Eyebrow}"
                                           VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right"
                                        Content="Refresh"
                                        Command="{Binding RefreshSemanticHealthCommand}"
                                        Style="{StaticResource AppButton.CompactGhost}"
                                        Margin="8,0,0,0"/>
                            </DockPanel>
                            <TextBlock Text="{Binding SemanticMemoryStatusText}"
                                       Foreground="{StaticResource Text/Primary}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SemanticMemoryDetailText}"
                                       Foreground="{StaticResource Text/Secondary}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,10"/>
                            <Button Content="Rebuild Semantic Index"
                                    Command="{Binding RebuildSemanticIndexCommand}"
                                    Style="{StaticResource AppButton.CompactGhost}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="4"
                            Style="{StaticResource SurfacePanel.Interactive}"
                            Padding="12"
                            Margin="0,0,0,12"
                            AutomationProperties.AutomationId="memory.workspace">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="SEMANTIC SEARCH"
                                       Style="{StaticResource Typography.Eyebrow}"
                                       Margin="0,0,0,8"/>
                            <DockPanel Grid.Row="1"
                                       LastChildFill="True"
                                       Margin="0,0,0,8"
                                       AutomationProperties.AutomationId="memory.search">
                                <Button DockPanel.Dock="Right"
                                        Content="Search"
                                        Command="{Binding RunSemanticSearchCommand}"
                                        Style="{StaticResource AppButton.CompactGhost}"
                                        Margin="8,0,0,0"
                                        AutomationProperties.AutomationId="memory.command.search"/>
                                <TextBox Text="{Binding SemanticSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="34"/>
                            </DockPanel>
                            <TextBlock Grid.Row="2"
                                       Text="{Binding SemanticSearchStatusText}"
                                       Foreground="{StaticResource Text/Secondary}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>
                            <ListBox Grid.Row="3"
                                     ItemsSource="{Binding SemanticSearchResults}"
                                     ItemContainerStyle="{StaticResource AppListBoxItem.Compact}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     AutomationProperties.AutomationId="memory.resultList">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2,6"
                                                    AutomationProperties.AutomationId="memory.resultRow">
                                            <DockPanel LastChildFill="True">
                                                <StackPanel DockPanel.Dock="Right"
                                                            Orientation="Horizontal"
                                                            Margin="8,0,0,0">
                                                    <primitives:StatusBadge Text="{Binding StaleText}"
                                                                            Status="Info"
                                                                            Margin="0,0,6,0"/>
                                                    <primitives:StatusBadge Text="{Binding ScoreText}"
                                                                            Status="ReviewRequired"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="{StaticResource Text/Primary}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </DockPanel>
                                            <StackPanel AutomationProperties.AutomationId="memory.result.detail">
                                                <TextBlock Text="{Binding Snippet}"
                                                           Foreground="{StaticResource Text/Secondary}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="44"
                                                           Margin="0,4,0,0"/>
                                                <Button Content="Create Ticket"
                                                        IsEnabled="False"
                                                        Style="{StaticResource AppButton.CompactGhost}"
                                                        HorizontalAlignment="Left"
                                                        Margin="0,6,0,0"
                                                        AutomationProperties.AutomationId="memory.command.createTicketFromResult"
                                                        ToolTipService.ShowOnDisabled="True"
                                                        ToolTip="Creating tickets from memory results must go through the IronDev ticket API and is not wired here yet."/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding SimilarityText}"
                                                       Foreground="{StaticResource Text/Muted}"
                                                       FontSize="10"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="DISCUSSION DOCUMENTS"
                                   Style="{StaticResource Typography.Eyebrow}"
                                   Margin="0,0,0,8"/>
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding DiscussionDocuments}"
                                 SelectedItem="{Binding SelectedDiscussion, Mode=TwoWay}"
                                 ItemContainerStyle="{StaticResource AppListBoxItem.Compact}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  VerticalAlignment="Top"
                                                  Margin="0,2,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <DockPanel LastChildFill="True">
                                                <primitives:StatusBadge DockPanel.Dock="Right"
                                                                        Text="{Binding PersistenceText}"
                                                                        Status="Info"
                                                                        Margin="8,0,0,0"/>
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="{StaticResource Text/Primary}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </DockPanel>
                                            <TextBlock Text="{Binding PreviewText}"
                                                       Foreground="{StaticResource Text/Secondary}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="44"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="360"/>
                    <RowDefinition Height="360" MinHeight="280"/>
                </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource SurfacePanel.Subtle}"
                    Padding="16"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="160"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="0,0,0,10">
                        <primitives:StatusBadge DockPanel.Dock="Right"
                                                Text="{Binding SelectedDiscussion.PersistenceText, FallbackValue=No discussion}"
                                                Status="Info"/>
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedDiscussion.Title, FallbackValue=Select a discussion}"
                                       Foreground="{StaticResource Text/Primary}"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedDiscussion.SuggestedArea}"
                                       Foreground="{StaticResource Text/Secondary}"
                                       FontSize="11"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </DockPanel>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="0,0,0,12">
                        <controls:StructuredTextView Text="{Binding SelectedDiscussion.FullPromptText}"
                                                     TextSize="13"/>
                    </ScrollViewer>

                    <TextBlock Grid.Row="2"
                               Text="DISCUSSION NOTES"
                               Style="{StaticResource Typography.Eyebrow}"
                               Margin="0,0,0,8"/>

                    <TextBox Grid.Row="3"
                             Text="{Binding DiscussionNotes, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="140"/>

                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                        <Button Content="Clear Resolution"
                                Command="{Binding ClearResolutionCommand}"
                                Style="{StaticResource AppButton.CompactGhost}"
                                Margin="0,0,8,0"/>
                        <Button Content="Resolve Discussion"
                                Command="{Binding ResolveSelectedDiscussionCommand}"
                                Style="{StaticResource AppButton.Primary}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource SurfacePanel.Subtle}"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="0,0,0,10">
                        <primitives:StatusBadge DockPanel.Dock="Right"
                                                Text="{Binding ResolutionConfidenceScore, StringFormat={}{0}/100}"
                                                Status="ReviewRequired"/>
                        <StackPanel>
                            <TextBlock Text="PROPOSAL REVIEW"
                                       Style="{StaticResource Typography.Eyebrow}"/>
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{StaticResource Text/Primary}"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Style="{StaticResource SurfacePanel.Interactive}"
                            Padding="12"
                            Margin="0,0,0,12"
                            Visibility="{Binding HasResolutionSummary, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Resolution"
                                       Style="{StaticResource Typography.Eyebrow}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding ResolutionSummary}"
                                       Foreground="{StaticResource Text/Secondary}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Proposals}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SurfacePanel.Interactive}"
                                            Padding="12"
                                            Margin="0,0,0,10">
                                        <StackPanel>
                                            <DockPanel LastChildFill="True">
                                                <StackPanel DockPanel.Dock="Right"
                                                            Orientation="Horizontal">
                                                    <primitives:StatusBadge Text="{Binding ConfidenceText}"
                                                                            Status="Info"
                                                                            Margin="0,0,6,0"/>
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding KindText}"
                                                                   Style="{StaticResource Typography.Eyebrow}"
                                                                   Foreground="{StaticResource Accent/Primary}"
                                                                   Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding ApplyStatusText}"
                                                                   Foreground="{StaticResource Text/Muted}"
                                                                   FontSize="10"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="{StaticResource Text/Primary}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </DockPanel>

                                            <TextBlock Text="{Binding Summary}"
                                                       Foreground="{StaticResource Text/Secondary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,8,0,0"/>

                                            <Expander Header="Details"
                                                      Margin="0,10,0,0">
                                                <StackPanel Margin="0,8,0,0">
                                                    <TextBlock Text="Detail"
                                                               Style="{StaticResource Typography.Eyebrow}"
                                                               Margin="0,0,0,4"/>
                                                    <controls:StructuredTextView Text="{Binding Detail}"
                                                                                 TextSize="12"/>

                                                    <TextBlock Text="Acceptance Criteria"
                                                               Style="{StaticResource Typography.Eyebrow}"
                                                               Margin="0,10,0,4"/>
                                                    <controls:StructuredTextView Text="{Binding AcceptanceCriteriaText}"
                                                                                 TextSize="12"/>

                                                    <TextBlock Text="Test Suggestions"
                                                               Style="{StaticResource Typography.Eyebrow}"
                                                               Margin="0,10,0,4"/>
                                                    <controls:StructuredTextView Text="{Binding TestSuggestionsText}"
                                                                                 TextSize="12"/>

                                                    <TextBlock Text="Grounding Warnings"
                                                               Style="{StaticResource Typography.Eyebrow}"
                                                               Margin="0,10,0,4"
                                                               Visibility="{Binding HasGroundingWarnings, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <controls:StructuredTextView Text="{Binding GroundingWarningsText}"
                                                                                 TextSize="12"
                                                                                 Visibility="{Binding HasGroundingWarnings, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </Expander>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
