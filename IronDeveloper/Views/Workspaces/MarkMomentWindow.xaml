<Window x:Class="IronDev.Agent.Views.Workspaces.MarkMomentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="http://schemas.irondeveloper.com/controls"
        Title="Mark Moment"
        Width="1440"
        Height="900"
        MinWidth="980"
        MinHeight="680"
        ResizeMode="CanResize"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Background/App}">
    <Border BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="680"/>
                <ColumnDefinition Width="420" MinWidth="360"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,14">
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding CapturedText}"
                           Foreground="{StaticResource Text/Muted}"
                           VerticalAlignment="Center"/>
                <StackPanel>
                    <TextBlock Text="Mark Moment"
                               Foreground="{StaticResource Text/Primary}"
                               FontSize="22"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Draw one rectangle around the problem area. Resize or maximize this window if the target is too small."
                               Foreground="{StaticResource Text/Secondary}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Style="{StaticResource SurfacePanel.Subtle}"
                    Padding="10"
                    Margin="0,0,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="ZOOM"
                                   Style="{StaticResource Typography.Eyebrow}"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding ScreenshotZoom, StringFormat={}{0:P0}}"
                                   Foreground="{StaticResource Text/Muted}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                        <Slider Minimum="0.35"
                                Maximum="2.5"
                                TickFrequency="0.25"
                                IsSnapToTickEnabled="False"
                                Value="{Binding ScreenshotZoom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>

                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="Transparent">
                        <Grid x:Name="ScreenshotHost"
                              Background="Transparent"
                              MouseLeftButtonDown="ScreenshotHost_MouseLeftButtonDown"
                              MouseMove="ScreenshotHost_MouseMove"
                              MouseLeftButtonUp="ScreenshotHost_MouseLeftButtonUp">
                            <Grid.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding ScreenshotZoom}"
                                                ScaleY="{Binding ScreenshotZoom}"/>
                            </Grid.LayoutTransform>
                            <Image x:Name="ScreenshotImage"
                                   Source="{Binding ScreenshotPath}"
                                   Stretch="None"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <Canvas x:Name="AnnotationCanvas"
                                    IsHitTestVisible="False">
                                <Rectangle x:Name="SelectionRectangle"
                                           Stroke="Red"
                                           StrokeThickness="3"
                                           Visibility="Collapsed"/>
                            </Canvas>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Style="{StaticResource SurfacePanel.Subtle}"
                    Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="TYPE"
                                   Style="{StaticResource Typography.Eyebrow}"
                                   Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding MomentTypes}"
                                  SelectedItem="{Binding MomentType}"
                                  Margin="0,0,0,12"/>

                        <TextBlock Text="SEVERITY"
                                   Style="{StaticResource Typography.Eyebrow}"
                                   Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding Severities}"
                                  SelectedItem="{Binding Severity}"
                                  Margin="0,0,0,12"/>

                        <TextBlock Text="WHAT WERE YOU TRYING TO DO?"
                                   Style="{StaticResource Typography.Eyebrow}"
                                   Margin="0,0,0,8"/>
                        <TextBox Text="{Binding UserTextNote, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="86"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="EXPECTED"
                                   Style="{StaticResource Typography.Eyebrow}"
                                   Margin="0,0,0,8"/>
                        <TextBox Text="{Binding ExpectedBehavior, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="70"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="ACTUAL"
                                   Style="{StaticResource Typography.Eyebrow}"
                                   Margin="0,0,0,8"/>
                        <TextBox Text="{Binding ActualBehavior, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="70"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="SUSPECTED AREA"
                                   Style="{StaticResource Typography.Eyebrow}"
                                   Margin="0,0,0,8"/>
                        <TextBox Text="{Binding SuspectedArea, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,14,0,0">
                <Button Content="Cancel"
                        Click="Cancel_Click"
                        Style="{StaticResource AppButton.CompactGhost}"
                        Margin="0,0,8,0"/>
                <Button Content="Save Moment"
                        Click="Save_Click"
                        Style="{StaticResource AppButton.Primary}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
