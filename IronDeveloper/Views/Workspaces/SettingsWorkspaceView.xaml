<UserControl x:Class="IronDev.Agent.Views.Workspaces.SettingsWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             xmlns:controls="http://schemas.irondeveloper.com/controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsWorkspaceViewModel, IsDesignTimeCreatable=False}">

    <ScrollViewer Background="{StaticResource Background/App}">
        <StackPanel Margin="28,24,28,28" MaxWidth="980">

            <!-- Header -->
            <TextBlock Text="WORKSPACE" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
            <TextBlock Text="Settings" Style="{StaticResource IronSectionTitle}" Margin="0,0,0,28"/>

            <!-- Help / About -->
            <controls:SurfacePanel Variant="Subtle" Margin="0,0,0,16" Padding="22">
                <StackPanel>
                    <TextBlock Text="HELP / ABOUT" Style="{StaticResource IronEyebrow}" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding ProductDisplayName}" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource Text/Primary}" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding ProductWorkflowName}" Style="{StaticResource IronMetaLabel}"
                               Opacity="0.78" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Version" Style="{StaticResource IronMetaLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding ProductVersion}" Style="{StaticResource IronMetaValue}"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource Border/Subtle}" Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding ProductSafetyModel}" FontWeight="SemiBold" FontSize="14"
                               Foreground="{StaticResource Text/Primary}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding AlphaScopeSummary}" Style="{StaticResource IronMetaLabel}"
                               Opacity="0.78" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding AlphaLimitations}" Style="{StaticResource IronMetaLabel}"
                               Opacity="0.62" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding AlphaTesterPrompt}" Style="{StaticResource IronMetaLabel}"
                               Opacity="0.78" TextWrapping="Wrap"/>
                </StackPanel>
            </controls:SurfacePanel>

            <!-- AI Model section -->
            <controls:SurfacePanel Variant="Subtle" Margin="0,0,0,16" Padding="22">
                <StackPanel>
                    <TextBlock Text="AI MODEL" Style="{StaticResource IronEyebrow}" Margin="0,0,0,10"/>
                    <TextBlock Text="Active Model" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding AvailableModels}"
                               SelectedItem="{Binding SelectedModel}"/>

                    <TextBlock Text="API Endpoint" Style="{StaticResource IronMetaLabel}" Margin="0,16,0,6"/>
                    <TextBox Text="{Binding ApiEndpoint, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </controls:SurfacePanel>

            <!-- Behaviour toggles -->
            <controls:SurfacePanel Variant="Subtle" Margin="0,0,0,16" Padding="22">
                <StackPanel>
                    <TextBlock Text="BEHAVIOUR" Style="{StaticResource IronEyebrow}" Margin="0,0,0,14"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Stream Responses" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource Text/Primary}"/>
                            <TextBlock Text="Show tokens as they arrive rather than waiting for completion."
                                       Style="{StaticResource IronMetaLabel}" Opacity="0.65" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding StreamResponses}"
                                       VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Auto-Index on Open -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Auto-Index on Open" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource Text/Primary}"/>
                            <TextBlock Text="Automatically re-index the project when it is opened."
                                       Style="{StaticResource IronMetaLabel}" Opacity="0.65" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding AutoIndex}"
                                       VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Trace LLM Calls -->
                    <Border Height="1" Background="{StaticResource Border/Subtle}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Trace LLM Calls" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource Text/Primary}"/>
                            <TextBlock Text="Capture prompts, responses, warnings, and errors in the LLM Console."
                                       Style="{StaticResource IronMetaLabel}" Opacity="0.65" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding IsLlmTracingEnabled}"
                                       VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Context Agent (Agentic RAG) -->
                    <Border Height="1" Background="{StaticResource Border/Subtle}" Margin="0,12,0,12"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Context Agent (Agentic RAG)" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource Text/Primary}"/>
                            <TextBlock Text="Run a sufficiency check and optional code-search expansion before answering. Default: OFF. Enable only when testing the agentic pipeline."
                                       Style="{StaticResource IronMetaLabel}" Opacity="0.65" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding UseContextAgent}"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Builder approval -->
                    <Border Height="1" Background="{StaticResource Border/Subtle}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Require Builder Apply Approval" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource Text/Primary}"/>
                            <TextBlock Text="Ask before applying proposal files and running the build/test cycle."
                                       Style="{StaticResource IronMetaLabel}" Opacity="0.65" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding RequireBuilderApplyApproval}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </controls:SurfacePanel>


            <!-- Developer Tools -->
            <controls:SurfacePanel Variant="Subtle" Margin="0,0,0,16" Padding="0">
                <StackPanel>

                    <!-- Expand / Collapse toggle -->
                    <Button Command="{Binding ToggleDevToolsCommand}"
                            Background="Transparent" BorderThickness="0"
                            Padding="22,14" HorizontalContentAlignment="Stretch"
                            Cursor="Hand">
                        <Grid>
                            <TextBlock Text="DEVELOPER TOOLS" Style="{StaticResource IronEyebrow}"
                                       VerticalAlignment="Center"/>
                            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="12" Opacity="0.45"
                                       Foreground="{StaticResource Text/Primary}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="â–¶  Show Developer Tools"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDevToolsExpanded}" Value="True">
                                                <Setter Property="Text" Value="â–¼  Hide Developer Tools"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>

                    <!-- Developer Tools Host -->
                    <TabControl
                                Background="Transparent" BorderThickness="0,1,0,0"
                                BorderBrush="{StaticResource Border/Subtle}"
                                ItemContainerStyle="{StaticResource AppTabItem.Workspace}"
                                Visibility="{Binding IsDevToolsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TabItem Header="PROMPT PLAYGROUND">
                            <ContentControl Content="{Binding PromptPlayground}"/>
                        </TabItem>
                        <TabItem Header="LLM CONSOLE">
                            <ContentControl Content="{Binding LlmConsole}"/>
                        </TabItem>
                    </TabControl>

                </StackPanel>
            </controls:SurfacePanel>

            <!-- Note -->
            <TextBlock Text="Settings are saved on this machine."
                       Style="{StaticResource IronMetaLabel}" HorizontalAlignment="Center"
                       Opacity="0.4" Margin="0,4,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
