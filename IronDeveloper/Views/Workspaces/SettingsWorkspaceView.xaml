<UserControl x:Class="IronDev.Agent.Views.Workspaces.SettingsWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsWorkspaceViewModel, IsDesignTimeCreatable=False}">

    <ScrollViewer Background="{StaticResource AppBackgroundBrush}">
        <StackPanel Margin="40,36,40,40" MaxWidth="900">

            <!-- Header -->
            <TextBlock Text="WORKSPACE" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
            <TextBlock Text="Settings" Style="{StaticResource IronSectionTitle}" Margin="0,0,0,28"/>

            <!-- AI Model section -->
            <Border Style="{StaticResource IronCard}" Margin="0,0,0,16" Padding="22">
                <StackPanel>
                    <TextBlock Text="AI MODEL" Style="{StaticResource IronEyebrow}" Margin="0,0,0,10"/>
                    <TextBlock Text="Active Model" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding AvailableModels}"
                               SelectedItem="{Binding SelectedModel}"/>

                    <TextBlock Text="API Endpoint" Style="{StaticResource IronMetaLabel}" Margin="0,16,0,6"/>
                    <TextBox Text="{Binding ApiEndpoint, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Border>

            <!-- Behaviour toggles -->
            <Border Style="{StaticResource IronCard}" Margin="0,0,0,16" Padding="22">
                <StackPanel>
                    <TextBlock Text="BEHAVIOUR" Style="{StaticResource IronEyebrow}" Margin="0,0,0,14"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Stream Responses" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="Show tokens as they arrive rather than waiting for completion."
                                       Style="{StaticResource IronMetaLabel}" Opacity="0.65" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding StreamResponses}"
                                       VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Auto-Index on Open -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Auto-Index on Open" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="Automatically re-index the project when it is opened."
                                       Style="{StaticResource IronMetaLabel}" Opacity="0.65" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding AutoIndex}"
                                       VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Trace LLM Calls -->
                    <Border Height="1" Background="#10FFFFFF" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Trace LLM Calls" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="Capture prompts, responses, warnings, and errors in the LLM Console."
                                       Style="{StaticResource IronMetaLabel}" Opacity="0.65" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding IsLlmTracingEnabled}"
                                       VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Context Agent (Agentic RAG) -->
                    <Border Height="1" Background="#10FFFFFF" Margin="0,12,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Context Agent (Agentic RAG)" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="Run a sufficiency check and optional code-search expansion before answering. Default: OFF. Enable only when testing the agentic pipeline."
                                       Style="{StaticResource IronMetaLabel}" Opacity="0.65" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding UseContextAgent}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>


            <!-- Developer Tools -->
            <Border Style="{StaticResource IronCard}" Margin="0,0,0,16" Padding="0">
                <StackPanel>

                    <!-- Expand / Collapse toggle -->
                    <Button x:Name="DevToolsToggleBtn"
                            Command="{Binding ToggleDevToolsCommand}"
                            Background="Transparent" BorderThickness="0"
                            Padding="22,14" HorizontalContentAlignment="Stretch"
                            Cursor="Hand">
                        <Grid>
                            <TextBlock Text="DEVELOPER TOOLS" Style="{StaticResource IronEyebrow}"
                                       VerticalAlignment="Center"/>
                            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="12" Opacity="0.45"
                                       Foreground="{StaticResource TextBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="▶  Show Developer Tools"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDevToolsExpanded}" Value="True">
                                                <Setter Property="Text" Value="▼  Hide Developer Tools"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>

                    <!-- Developer Tools Host -->
                    <TabControl x:Name="DevToolsTabs"
                                Background="Transparent" BorderThickness="0,1,0,0"
                                BorderBrush="{StaticResource DarkBorderBrush}"
                                Visibility="{Binding IsDevToolsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="HeaderTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="12" FontWeight="SemiBold" Margin="4,2"/>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="Border" Padding="22,12" Background="Transparent" BorderThickness="0,0,0,2">
                                            <ContentPresenter ContentSource="Header"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#10FFFFFF"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource FocusBorderBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#05FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <TabItem Header="PROMPT PLAYGROUND">
                            <ContentControl Content="{Binding PromptPlayground}"/>
                        </TabItem>
                        <TabItem Header="LLM CONSOLE">
                            <ContentControl Content="{Binding LlmConsole}"/>
                        </TabItem>
                    </TabControl>

                </StackPanel>
            </Border>

            <!-- Note -->
            <TextBlock Text="Settings are stored in memory only in this preview build."
                       Style="{StaticResource IronMetaLabel}" HorizontalAlignment="Center"
                       Opacity="0.4" Margin="0,4,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
