<UserControl x:Class="IronDev.Agent.Views.Workspaces.PromptPlaygroundView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             xmlns:controls="http://schemas.irondeveloper.com/controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:PromptPlaygroundViewModel, IsDesignTimeCreatable=False}">

    <!--
        PromptPlaygroundView Ã¢â‚¬â€ Developer-only diagnostic tool.

        This view is hosted inside SettingsWorkspaceView's ScrollViewer via a
        ContentControl + DataTemplate (App.xaml). Therefore:
          Ã¢â‚¬Â¢ No outer ScrollViewer here (would create a nested, unconstrained scroller).
          Ã¢â‚¬Â¢ DataContext is set automatically by WPF via the DataTemplate Ã¢â‚¬â€ never null.
          Ã¢â‚¬Â¢ All global resources (BoolToVisibilityConverter, StringToVisibilityConverter,
            shared controls and theme tokens are available via App.xaml merged dictionaries.
    -->

    <StackPanel Margin="24,0,24,32">

        <!-- Ã¢â€â‚¬Ã¢â€â‚¬ Header Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ -->
        <TextBlock Text="DEVELOPER TOOLS" Style="{StaticResource IronEyebrow}" Margin="0,20,0,4"/>
        <TextBlock Text="Prompt Playground" Style="{StaticResource IronSectionTitle}" Margin="0,0,0,6"/>
        <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.55"
                   Foreground="{StaticResource Text/Primary}" Margin="0,0,0,20">
            Inspect what PromptContextBuilder generates and send it to the configured AI.
            Select a grounding test case, click Run Grounding Test to build the prompt, query the AI, and evaluate the response.
        </TextBlock>

        <!-- Ã¢â€â‚¬Ã¢â€â‚¬ Input Card Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ -->
        <controls:SurfacePanel Variant="Subtle" Margin="0,0,0,12" Padding="22">
            <StackPanel>
                <TextBlock Text="INPUT" Style="{StaticResource IronEyebrow}" Margin="0,0,0,14"/>

                <TextBlock Text="Grounding Test Case" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                <ComboBox
                          ItemsSource="{Binding TestCases}"
                          SelectedItem="{Binding SelectedTestCase, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          MinWidth="500"
                          MinHeight="42"
                          Margin="0,0,0,6"/>



                <TextBlock Text="User Message" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                <TextBox
                         Text="{Binding SampleUserMessage, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap" MinHeight="68" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,18"/>

                <StackPanel Orientation="Horizontal">
                    <!-- PRIMARY: Run Grounding Test -->
                    <Button
                            Content="Ã¢â€“Â¶  Run Grounding Test"
                            Command="{Binding RunGroundingTestCommand}"
                            Style="{StaticResource AppButton.Primary}"
                            IsEnabled="{Binding IsRunningTest, Converter={StaticResource InverseBoolConverter}}"
                            MinWidth="180" Margin="0,0,10,0"/>
                    <!-- SECONDARY: Build Prompt only -->
                    <Button
                            Content="Ã¢Å¡Â¡  Build Prompt"
                            Command="{Binding BuildPromptCommand}"
                            Style="{StaticResource AppButton.CompactGhost}"
                            IsEnabled="{Binding IsBuilding, Converter={StaticResource InverseBoolConverter}}"
                            MinWidth="140" Margin="0,0,10,0"/>
                    <Button
                            Content="Copy Prompt"
                            Command="{Binding CopyPromptCommand}"
                            Style="{StaticResource AppButton.CompactGhost}"
                            MinWidth="110" Margin="0,0,10,0"/>
                    <Button
                            Content="Clear"
                            Command="{Binding ClearAllCommand}"
                            Style="{StaticResource AppButton.CompactGhost}"
                            MinWidth="80"/>
                </StackPanel>
            </StackPanel>
        </controls:SurfacePanel>


        <!-- Ã¢â€â‚¬Ã¢â€â‚¬ Expected Behaviour Panel Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ -->
        <controls:SurfacePanel Variant="Subtle" Margin="0,0,0,12" Padding="22"
                Visibility="{Binding SelectedTestCase, Converter={StaticResource ValueToVis}}">
            <StackPanel>
                <TextBlock Text="EXPECTED BEHAVIOUR" Style="{StaticResource IronEyebrow}" Margin="0,0,0,14"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Expected Intent -->
                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,16,12">
                        <TextBlock Text="Expected Intent" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding ExpectedIntent, FallbackValue='(not set)'}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text/Primary}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Must Include Any (Expected Files/Classes) -->
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Expected Files / Classes" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding ExpectedFilesClasses, FallbackValue='Ã¢â‚¬â€'}"
                                   FontSize="12" Foreground="{StaticResource Text/Primary}"
                                   Opacity="0.8" TextWrapping="Wrap"
                                   FontFamily="Consolas, Courier New"/>
                    </StackPanel>

                    <!-- Must NOT Lead With -->
                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,16,12">
                        <TextBlock Text="Must NOT Lead With" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding MustNotLeadWith, FallbackValue='Ã¢â‚¬â€'}"
                                   FontSize="12" Foreground="#FFCC6666"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas, Courier New"/>
                    </StackPanel>

                    <!-- Must Mention -->
                    <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,0,12">
                        <TextBlock Text="Must Mention" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding MustMention, FallbackValue='Ã¢â‚¬â€'}"
                                   FontSize="12" Foreground="{StaticResource Text/Primary}"
                                   Opacity="0.75" TextWrapping="Wrap"
                                   FontFamily="Consolas, Courier New"/>
                    </StackPanel>

                    <!-- Must NOT Mention -->
                    <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,16,0">
                        <TextBlock Text="Must NOT Mention" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding MustNotMention, FallbackValue='Ã¢â‚¬â€'}"
                                   FontSize="12" Foreground="#FFCC6666"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas, Courier New"/>
                    </StackPanel>

                    <!-- Pass / Fail rules -->
                    <StackPanel Grid.Column="1" Grid.Row="2">
                        <TextBlock Text="Pass / Fail Rule" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock FontSize="12" TextWrapping="Wrap"
                                   Foreground="{StaticResource Text/Primary}" Opacity="0.75">
                            <Run Text="Ã¢Å“â€¦ " Foreground="#FF66BB66"/>
                            <Run Text="{Binding PassRule, FallbackValue='Ã¢â‚¬â€'}"/>
                        </TextBlock>
                        <TextBlock FontSize="12" TextWrapping="Wrap" Margin="0,3,0,0"
                                   Foreground="{StaticResource Text/Primary}" Opacity="0.75">
                                <Run Text="Ã¢ÂÅ’ " Foreground="#FFCC6666"/>
                                <Run Text="{Binding FailRule, FallbackValue='Ã¢â‚¬â€'}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </controls:SurfacePanel>

        <!-- Ã¢â€â‚¬Ã¢â€â‚¬ Result / Status Row Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ -->
        <controls:SurfacePanel Variant="Subtle" Margin="0,0,0,12" Padding="22"
                Visibility="{Binding SelectedTestCase, Converter={StaticResource ValueToVis}}">
            <StackPanel>
                <!-- Row 1: Intent + Result badge -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="DETECTED INTENT" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding DetectedIntent, FallbackValue='Ã¢â‚¬â€'}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text/Primary}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                        <TextBlock Text="INTENT MATCH" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding IntentMatchBadge, FallbackValue='Ã¢â‚¬â€'}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text/Primary}"/>
                    </StackPanel>

                    <!-- PASS / WARNING / FAIL badge -->
                    <Border Grid.Column="2" CornerRadius="6" Padding="16,8" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#22FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ResultStatus}" Value="Ã¢Å“â€¦ PASS">
                                        <Setter Property="Background" Value="#2266BB66"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ResultStatus}" Value="Ã¢ÂÅ’ FAIL">
                                        <Setter Property="Background" Value="#22BB4444"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ResultStatus}" Value="Ã¢ÂÅ’ FAIL Ã¢â‚¬â€ wrong context leads">
                                        <Setter Property="Background" Value="#22BB4444"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ResultStatus}" Value="Ã¢ÂÅ’ FAIL Ã¢â‚¬â€ no project + intent mismatch">
                                        <Setter Property="Background" Value="#22BB4444"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ResultStatus, FallbackValue='Ã¢â‚¬â€'}"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource Text/Primary}"/>
                    </Border>
                </Grid>

                <!-- Separator -->
                <Border Height="1" Background="#14FFFFFF" Margin="0,0,0,12"
                        Visibility="{Binding ProjectIndexStatus, Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Row 2: Project Index + Context Retrieved + Quality (compact, only when populated) -->
                <Grid Visibility="{Binding ProjectIndexStatus, Converter={StaticResource StringToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="PROJECT INDEX" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ProjectIndexStatus}"
                                   FontSize="13" Foreground="{StaticResource Text/Primary}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                        <TextBlock Text="CONTEXT RETRIEVED" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ContextRetrievalStatus}"
                                   FontSize="13" Foreground="{StaticResource Text/Primary}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Inline quality pill (compact) -->
                    <Border Grid.Column="2" CornerRadius="4" Padding="10,4" VerticalAlignment="Center"
                            Visibility="{Binding ContextQualityBadge, Converter={StaticResource StringToVisibilityConverter}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#1AFFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ContextPolluted}" Value="True">
                                        <Setter Property="Background" Value="#33BB4444"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="11" Foreground="{StaticResource Text/Primary}" Opacity="0.7"
                                           Text="{Binding FilteredMemoryCount, StringFormat='Filtered: {0}'}"/>
                                <TextBlock Text="  Ã‚Â·  " FontSize="11" Foreground="{StaticResource Text/Primary}" Opacity="0.4"/>
                                <TextBlock FontSize="11" Foreground="{StaticResource Text/Primary}" Opacity="0.7"
                                           Text="{Binding IncludedMemoryCount, StringFormat='Included: {0}'}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding PollutedTermsSummary, StringFormat='Poison: {0}'}"
                                       FontSize="10" Foreground="#FFCC5555"
                                       FontFamily="Consolas, Courier New"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding PollutedTermsSummary, Converter={StaticResource StringToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </controls:SurfacePanel>

        <!-- Ã¢â€â‚¬Ã¢â€â‚¬ Error Banner Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ -->
        <Border CornerRadius="6" Padding="14,10" Margin="0,0,0,12"
                Background="#33FF4444"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FFDD6666"
                       FontSize="13" TextWrapping="Wrap"/>
        </Border>

        <!-- Ã¢â€â‚¬Ã¢â€â‚¬ Running indicator Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ -->
        <Border Padding="14,8" CornerRadius="6" Margin="0,0,0,12"
                Background="#22FFFFFF"
                Visibility="{Binding IsRunningTest, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Ã¢â€“Â¶ " Foreground="{StaticResource Text/Primary}" FontSize="13"/>
                <TextBlock Text="{Binding RunStatusMessage}" FontSize="13" Opacity="0.75"
                           Foreground="{StaticResource Text/Primary}"/>
            </StackPanel>
        </Border>

        <!-- Ã¢â€â‚¬Ã¢â€â‚¬ Building indicator Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ -->
        <Border Padding="14,8" CornerRadius="6" Margin="0,0,0,12"
                Background="#22FFFFFF"
                Visibility="{Binding IsBuilding, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Building promptÃ¢â‚¬Â¦" FontSize="13" Opacity="0.6"
                       Foreground="{StaticResource Text/Primary}"/>
        </Border>

        <!-- Ã¢â€â‚¬Ã¢â€â‚¬ Expanded Search Queries Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ -->
        <controls:SurfacePanel Variant="Subtle" Margin="0,0,0,12" Padding="22"
                Visibility="{Binding ExpandedQueries, Converter={StaticResource StringToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="EXPANDED SEARCH QUERIES" Style="{StaticResource IronEyebrow}" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding ExpandedQueries}"
                           FontFamily="Consolas, Courier New" FontSize="12"
                           Foreground="{StaticResource Text/Primary}" Opacity="0.85"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </controls:SurfacePanel>


        <!-- Ã¢â€â‚¬Ã¢â€â‚¬ Retrieval Diagnostics Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ -->
        <controls:SurfacePanel Variant="Subtle" Margin="0,0,0,12" Padding="22"
                Visibility="{Binding HasDiagnostics, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="RETRIEVAL DIAGNOSTICS" Style="{StaticResource IronEyebrow}" Margin="0,0,0,10"/>

                <!-- Row 1: ProjectId / TenantId / ProjectFiles / CodeIndexEntries -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Project ID" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding RetrievalProjectId}" FontSize="13"
                                   FontFamily="Consolas, Courier New"
                                   Foreground="{StaticResource Text/Primary}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Tenant ID" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding RetrievalTenantId}" FontSize="13"
                                   FontFamily="Consolas, Courier New"
                                   Foreground="{StaticResource Text/Primary}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Text="ProjectFiles" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,2"/>
                        <TextBlock FontSize="13" Foreground="{StaticResource Text/Primary}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding ProjectFilesCount}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ProjectFilesCount}" Value="-1">
                                            <Setter Property="Text" Value="Ã¢â‚¬â€"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Retrieved" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding RetrievedSnippetCount}" FontSize="13"
                                   Foreground="{StaticResource Text/Primary}"/>
                    </StackPanel>
                </Grid>

                <!-- Row 2: Expanded queries / distinct files / sources -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Queries" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding ExpandedQueryCount}" FontSize="13"
                                   Foreground="{StaticResource Text/Primary}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Distinct Files" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding RetrievedFileCount}" FontSize="13"
                                   Foreground="{StaticResource Text/Primary}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Sources" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding RetrievalSources, FallbackValue='Ã¢â‚¬â€'}" FontSize="12"
                                   Foreground="{StaticResource Text/Primary}" Opacity="0.8"
                                   FontFamily="Consolas, Courier New" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <!-- Empty reason (only when no snippets) -->
                <Border Margin="0,10,0,0" Padding="10,6" CornerRadius="4" Background="#18FFAA00"
                        Visibility="{Binding RetrievalEmptyReason, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock FontSize="12" Foreground="#FFDDAA44" TextWrapping="Wrap">
                        <Run Text="Ã¢Å¡Â Ã¯Â¸Â "/><Run Text="{Binding RetrievalEmptyReason}"/>
                    </TextBlock>
                </Border>

                <!-- Inconsistency banner: Ready but 0 ProjectFiles -->
                <Border Margin="0,10,0,0" Padding="12,8" CornerRadius="4" Background="#33FF4444"
                        Visibility="{Binding IndexInconsistent, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#FFDD6666" TextWrapping="Wrap">
                            <Run Text="Ã¢ÂÅ’ Index Inconsistency Detected"/>
                        </TextBlock>
                        <TextBlock FontSize="12" Foreground="#FFDD6666" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Text="{Binding IndexInconsistencyReason}"/>
                        <TextBlock FontSize="12" Foreground="#FFDD6666" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Text="Action: Open Project Overview Ã¢â€ â€™ click Index Project to rebuild."/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </controls:SurfacePanel>

        <!-- Ã¢â€â‚¬Ã¢â€â‚¬ Retrieved Context Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ -->
        <!-- Only shown once retrieved items are populated -->
        <controls:SurfacePanel Variant="Subtle" Margin="0,0,0,12" Padding="22"
                Visibility="{Binding HasRetrievedItems, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="RETRIEVED CONTEXT" Style="{StaticResource IronEyebrow}" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding RetrievedItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,4" Padding="10,6"
                                    Background="#0AFFFFFF" CornerRadius="4">
                                <StackPanel>
                                    <TextBlock FontFamily="Consolas, Courier New" FontSize="12"
                                               Foreground="{StaticResource Text/Primary}" FontWeight="SemiBold">
                                        <Run Text="{Binding FilePath}"/>
                                        <Run Text="  Ã¢â€ â€™  " Foreground="#60FFFFFF"/>
                                        <Run Text="{Binding SymbolName}" Foreground="#FFB8C4D8"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Preview}"
                                               FontFamily="Consolas, Courier New" FontSize="11"
                                               Foreground="{StaticResource Text/Primary}" Opacity="0.45"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Margin="0,6,0,0"
                           Text="{Binding RetrievalEmptyReason, FallbackValue='(no context retrieved Ã¢â‚¬â€ project may not be indexed)'}"
                           FontSize="12" Opacity="0.5"
                           Foreground="#FFDDAA44"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RetrievedItems.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </controls:SurfacePanel>

        <!-- Ã¢â€â‚¬Ã¢â€â‚¬ AI Response Result Panel Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ -->
        <controls:SurfacePanel Variant="Subtle" Margin="0,0,0,12" Padding="22"
                Visibility="{Binding AiResponse, Converter={StaticResource StringToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="AI RESPONSE" Style="{StaticResource IronEyebrow}" Margin="0,0,0,10"/>

                <!-- Provider badge -->
                <TextBlock Margin="0,0,0,8" FontSize="12" Opacity="0.5"
                           Foreground="{StaticResource Text/Primary}"
                           Visibility="{Binding ProviderInfo, Converter={StaticResource StringToVisibilityConverter}}">
                    <Run Text="Provider: "/><Run Text="{Binding ProviderInfo}"/>
                </TextBlock>

                <!-- Full response text -->
                <TextBox Text="{Binding AiResponse, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         MinHeight="120" MaxHeight="400"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="13" Padding="10"
                         Margin="0,0,0,16"/>

                <!-- Evaluation grid -->
                <TextBlock Text="EVALUATION" Style="{StaticResource IronEyebrow}" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Expected files / classes -->
                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,16,10">
                        <TextBlock Text="Expected Files / Classes" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding ExpectedFilesStatus, FallbackValue='Ã¢â‚¬â€'}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text/Primary}"/>
                    </StackPanel>

                    <!-- Must mention -->
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Must Mention" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding MustMentionStatus, FallbackValue='Ã¢â‚¬â€'}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text/Primary}"/>
                    </StackPanel>

                    <!-- Must NOT mention -->
                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,16,10">
                        <TextBlock Text="Must NOT Mention" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding MustNotMentionStatus, FallbackValue='Ã¢â‚¬â€'}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text/Primary}"/>
                    </StackPanel>

                    <!-- Final result -->
                    <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,0,10">
                        <TextBlock Text="FINAL RESULT" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding ResultStatus, FallbackValue='Ã¢â‚¬â€'}"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource Text/Primary}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </controls:SurfacePanel>

        <!-- Ã¢â€â‚¬Ã¢â€â‚¬ Full Generated Prompt (collapsed by default) Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ -->
        <controls:SurfacePanel Variant="Subtle" Margin="0,0,0,12" Padding="0"
                Visibility="{Binding PromptText, Converter={StaticResource StringToVisibilityConverter}}">
            <Expander IsExpanded="False" Padding="22,14">
                <Expander.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="FULL GENERATED PROMPT"
                                   Style="{StaticResource IronEyebrow}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PromptCharCount}"
                                   FontSize="11" Opacity="0.4"
                                   Foreground="{StaticResource Text/Primary}"
                                   VerticalAlignment="Center" Margin="12,0,12,0"/>
                        <Button Grid.Column="2"
                                Content="Copy"
                                Command="{Binding CopyPromptCommand}"
                                Style="{StaticResource AppButton.CompactGhost}"
                                Padding="10,4"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Expander.Header>
                <TextBox Text="{Binding PromptText, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         MinHeight="80" MaxHeight="480"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas, Courier New"
                         FontSize="12" Padding="10"
                         Margin="0,10,0,0"/>
            </Expander>
        </controls:SurfacePanel>

    </StackPanel>
</UserControl>

