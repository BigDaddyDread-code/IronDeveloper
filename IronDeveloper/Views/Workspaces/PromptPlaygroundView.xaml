<UserControl x:Class="IronDev.Agent.Views.Workspaces.PromptPlaygroundView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:PromptPlaygroundViewModel, IsDesignTimeCreatable=False}">

    <!--
        PromptPlaygroundView — Developer-only diagnostic tool.

        This view is hosted inside SettingsWorkspaceView's ScrollViewer via a
        ContentControl + DataTemplate (App.xaml). Therefore:
          • No outer ScrollViewer here (would create a nested, unconstrained scroller).
          • DataContext is set automatically by WPF via the DataTemplate — never null.
          • All global resources (BoolToVisibilityConverter, StringToVisibilityConverter,
            IronCard, TextBrush, etc.) are available via App.xaml merged dictionaries.
    -->

    <StackPanel Margin="24,0,24,32">

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <TextBlock Text="DEVELOPER TOOLS" Style="{StaticResource IronEyebrow}" Margin="0,20,0,4"/>
        <TextBlock Text="Prompt Playground" Style="{StaticResource IronSectionTitle}" Margin="0,0,0,6"/>
        <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.55"
                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,20">
            Inspect what PromptContextBuilder generates and send it to the configured AI.
            Select a grounding test case, click Run Grounding Test to build the prompt, query the AI, and evaluate the response.
        </TextBlock>

        <!-- ── Input Card ──────────────────────────────────────────────────── -->
        <Border Style="{StaticResource IronCard}" Margin="0,0,0,12" Padding="22">
            <StackPanel>
                <TextBlock Text="INPUT" Style="{StaticResource IronEyebrow}" Margin="0,0,0,14"/>

                <TextBlock Text="Grounding Test Case" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>

                <!--
                    Local dark-theme ComboBox for Prompt Playground.
                    Does NOT use SelectionField (deferred) nor Style="{x:Null}" (bare Windows chrome).
                    Uses an inline ControlTemplate so:
                      • the global pill-switch ToggleButton style cannot clobber PART_ToggleButton
                      • the popup is dark glass matching IronDev theme
                      • DisplayMemberPath="DisplayName" renders "2 — Delete old chat sessions"
                -->
                <ComboBox x:Name="TestCaseCombo"
                          ItemsSource="{Binding TestCases}"
                          SelectedItem="{Binding SelectedTestCase, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          Margin="0,0,0,6">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Setter Property="Foreground"            Value="{StaticResource TextBrush}"/>
                            <Setter Property="Background"            Value="{StaticResource GlassControlBrush}"/>
                            <Setter Property="BorderBrush"           Value="{StaticResource DarkBorderBrush}"/>
                            <Setter Property="BorderThickness"       Value="1"/>
                            <Setter Property="FontSize"              Value="14"/>
                            <Setter Property="MinHeight"             Value="42"/>
                            <Setter Property="MinWidth"              Value="500"/>
                            <Setter Property="Padding"               Value="14,0,44,0"/>
                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                            <Setter Property="FocusVisualStyle"      Value="{x:Null}"/>
                            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBox">
                                        <Grid SnapsToDevicePixels="True">

                                            <!-- Dark glass border -->
                                            <Border x:Name="Outer"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="8"/>

                                            <!-- Selected item text -->
                                            <ContentPresenter x:Name="ContentSite"
                                                              Margin="{TemplateBinding Padding}"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Left"
                                                              Content="{TemplateBinding SelectionBoxItem}"
                                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                              IsHitTestVisible="False"/>

                                            <!-- Arrow chevron -->
                                            <Border x:Name="ArrowBox"
                                                    Width="34" Margin="0,6,8,6"
                                                    HorizontalAlignment="Right"
                                                    CornerRadius="6"
                                                    Background="#18FFFFFF"
                                                    BorderBrush="#33FFFFFF"
                                                    BorderThickness="1"
                                                    IsHitTestVisible="False">
                                                <Path x:Name="Arrow"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Fill="{StaticResource TextBrush}"
                                                      Data="M 0 0 L 4 4 L 8 0"
                                                      Stroke="{StaticResource TextBrush}"
                                                      StrokeThickness="1.5"
                                                      Width="10" Height="6"
                                                      Stretch="Uniform"/>
                                            </Border>

                                            <!--
                                                PART_ToggleButton — transparent click surface.
                                                Style="{x:Null}" + OverridesDefaultStyle="True" prevents
                                                the global implicit ToggleButton pill-switch style from
                                                replacing the inline Template below.
                                            -->
                                            <ToggleButton x:Name="PART_ToggleButton"
                                                          Style="{x:Null}"
                                                          OverridesDefaultStyle="True"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Focusable="False"
                                                          ClickMode="Press"
                                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="Transparent"/>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>

                                            <!-- Dark popup -->
                                            <Popup x:Name="PART_Popup"
                                                   Placement="Bottom"
                                                   AllowsTransparency="True"
                                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                                   StaysOpen="False"
                                                   PopupAnimation="Fade">
                                                <Border Margin="0,4,0,0"
                                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                                        CornerRadius="10"
                                                        Background="{StaticResource Background/Panel}"
                                                        BorderBrush="{StaticResource MidBorderBrush}"
                                                        BorderThickness="1"
                                                        Padding="6">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="4" Opacity="0.4"/>
                                                    </Border.Effect>
                                                    <ScrollViewer SnapsToDevicePixels="True" MaxHeight="340">
                                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                    </ScrollViewer>
                                                </Border>
                                            </Popup>

                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Outer" Property="BorderBrush" Value="{StaticResource MidBorderBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsDropDownOpen" Value="True">
                                                <Setter TargetName="Outer" Property="BorderBrush" Value="{StaticResource FocusBorderBrush}"/>
                                                <Setter TargetName="Arrow" Property="Data" Value="M 0 4 L 4 0 L 8 4"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.45"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>

                <!-- Diagnostic: count and selection (keep until global style verified) -->
                <TextBlock Text="{Binding TestCases.Count, StringFormat='Cases loaded: {0}'}"
                           FontSize="12" Opacity="0.45"
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,2"/>
                <TextBlock Text="{Binding SelectedTestCase.DisplayName, StringFormat='Selected: {0}', FallbackValue='Selected: (none)'}"
                           FontSize="12" Opacity="0.45"
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,16"/>

                <TextBlock Text="User Message" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                <TextBox x:Name="UserMessageBox"
                         Text="{Binding SampleUserMessage, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap" MinHeight="68" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,18"/>

                <StackPanel Orientation="Horizontal">
                    <!-- PRIMARY: Run Grounding Test -->
                    <Button x:Name="RunGroundingTestBtn"
                            Content="▶  Run Grounding Test"
                            Command="{Binding RunGroundingTestCommand}"
                            Style="{StaticResource IronPrimaryButton}"
                            IsEnabled="{Binding IsRunningTest, Converter={StaticResource InverseBoolConverter}}"
                            MinWidth="180" Margin="0,0,10,0"/>
                    <!-- SECONDARY: Build Prompt only -->
                    <Button x:Name="BuildPromptBtn"
                            Content="⚡  Build Prompt"
                            Command="{Binding BuildPromptCommand}"
                            Style="{StaticResource IronSecondaryButton}"
                            IsEnabled="{Binding IsBuilding, Converter={StaticResource InverseBoolConverter}}"
                            MinWidth="140" Margin="0,0,10,0"/>
                    <Button x:Name="CopyPromptBtn"
                            Content="Copy Prompt"
                            Command="{Binding CopyPromptCommand}"
                            Style="{StaticResource IronSecondaryButton}"
                            MinWidth="110" Margin="0,0,10,0"/>
                    <Button x:Name="ClearBtn"
                            Content="Clear"
                            Command="{Binding ClearAllCommand}"
                            Style="{StaticResource IronSecondaryButton}"
                            MinWidth="80"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Prompt Context Quality Diagnostics (Fix 2) ────────────────── -->
        <Border Style="{StaticResource IronCard}" Margin="0,0,0,12" Padding="18,14"
                Visibility="{Binding ContextQualityBadge, Converter={StaticResource StringToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="PROMPT CONTEXT QUALITY"
                           Style="{StaticResource IronEyebrow}" VerticalAlignment="Center" Margin="0,0,20,0"/>

                <!-- Badge: Clean / Polluted -->
                <TextBlock Grid.Column="1"
                           Text="{Binding ContextQualityBadge}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>

                <!-- Filtered count pill -->
                <Border Grid.Column="2" CornerRadius="4" Padding="10,4" Margin="12,0,0,0"
                        VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#1AFFFFFF"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ContextPolluted}" Value="True">
                                    <Setter Property="Background" Value="#33BB4444"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="11" Foreground="{StaticResource TextBrush}" Opacity="0.7">
                            <Run Text="Filtered: "/>
                            <Run Text="{Binding FilteredMemoryCount}"/>
                        </TextBlock>
                        <TextBlock Text="  ·  " FontSize="11" Foreground="{StaticResource TextBrush}" Opacity="0.4"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource TextBrush}" Opacity="0.7">
                            <Run Text="Included: "/>
                            <Run Text="{Binding IncludedMemoryCount}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Polluted terms -->
                <TextBlock Grid.Column="3"
                           Text="{Binding PollutedTermsSummary, StringFormat='Poison terms: {0}'}"
                           FontSize="11" Foreground="#FFCC5555" Opacity="0.85"
                           VerticalAlignment="Center" Margin="12,0,0,0" FontFamily="Consolas, Courier New"
                           Visibility="{Binding PollutedTermsSummary, Converter={StaticResource StringToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <!-- ── Expected Behaviour Panel ───────────────────────────────────── -->
        <Border Style="{StaticResource IronCard}" Margin="0,0,0,12" Padding="22">
            <StackPanel>
                <TextBlock Text="EXPECTED BEHAVIOUR" Style="{StaticResource IronEyebrow}" Margin="0,0,0,14"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Expected Intent -->
                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,16,12">
                        <TextBlock Text="Expected Intent" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding ExpectedIntent, FallbackValue='(not set)'}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Must Include Any (Expected Files/Classes) -->
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Expected Files / Classes" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding ExpectedFilesClasses, FallbackValue='—'}"
                                   FontSize="12" Foreground="{StaticResource TextBrush}"
                                   Opacity="0.8" TextWrapping="Wrap"
                                   FontFamily="Consolas, Courier New"/>
                    </StackPanel>

                    <!-- Must NOT Lead With -->
                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,16,12">
                        <TextBlock Text="Must NOT Lead With" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding MustNotLeadWith, FallbackValue='—'}"
                                   FontSize="12" Foreground="#FFCC6666"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas, Courier New"/>
                    </StackPanel>

                    <!-- Must Mention -->
                    <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,0,12">
                        <TextBlock Text="Must Mention" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding MustMention, FallbackValue='—'}"
                                   FontSize="12" Foreground="{StaticResource TextBrush}"
                                   Opacity="0.75" TextWrapping="Wrap"
                                   FontFamily="Consolas, Courier New"/>
                    </StackPanel>

                    <!-- Must NOT Mention -->
                    <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,16,0">
                        <TextBlock Text="Must NOT Mention" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding MustNotMention, FallbackValue='—'}"
                                   FontSize="12" Foreground="#FFCC6666"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas, Courier New"/>
                    </StackPanel>

                    <!-- Pass / Fail rules -->
                    <StackPanel Grid.Column="1" Grid.Row="2">
                        <TextBlock Text="Pass / Fail Rule" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock FontSize="12" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextBrush}" Opacity="0.75">
                            <Run Text="✅ " Foreground="#FF66BB66"/>
                            <Run Text="{Binding PassRule, FallbackValue='—'}"/>
                        </TextBlock>
                        <TextBlock FontSize="12" TextWrapping="Wrap" Margin="0,3,0,0"
                                   Foreground="{StaticResource TextBrush}" Opacity="0.75">
                            <Run Text="❌ " Foreground="#FFCC6666"/>
                            <Run Text="{Binding FailRule, FallbackValue='—'}"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Result / Status Row ────────────────────────────────────────── -->
        <Border Style="{StaticResource IronCard}" Margin="0,0,0,12" Padding="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="DETECTED INTENT" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding DetectedIntent, FallbackValue='—'}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                    <TextBlock Text="INTENT MATCH" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding IntentMatchBadge, FallbackValue='—'}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,16,0">
                    <TextBlock Text="INDEX STATUS" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
                    <TextBlock FontSize="13" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap">
                        <Run Text="{Binding ProjectIndexStatus, FallbackValue='—'}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding ContextQuality}"/>
                    </TextBlock>
                </StackPanel>

                <!-- PASS / WARNING / FAIL badge -->
                <Border Grid.Column="3" CornerRadius="6" Padding="16,8" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#22FFFFFF"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ResultStatus}" Value="✅ PASS">
                                    <Setter Property="Background" Value="#2266BB66"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ResultStatus}" Value="❌ FAIL">
                                    <Setter Property="Background" Value="#22BB4444"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ResultStatus}" Value="❌ FAIL — wrong context leads">
                                    <Setter Property="Background" Value="#22BB4444"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ResultStatus}" Value="❌ FAIL — no project + intent mismatch">
                                    <Setter Property="Background" Value="#22BB4444"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ResultStatus, FallbackValue='—'}"
                               FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"/>
                </Border>
            </Grid>
        </Border>

        <!-- ── Error Banner ───────────────────────────────────────────────── -->
        <Border CornerRadius="6" Padding="14,10" Margin="0,0,0,12"
                Background="#33FF4444"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FFDD6666"
                       FontSize="13" TextWrapping="Wrap"/>
        </Border>

        <!-- ── Running indicator ────────────────────────────────────────── -->
        <Border Padding="14,8" CornerRadius="6" Margin="0,0,0,12"
                Background="#22FFFFFF"
                Visibility="{Binding IsRunningTest, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="▶ " Foreground="{StaticResource TextBrush}" FontSize="13"/>
                <TextBlock Text="{Binding RunStatusMessage}" FontSize="13" Opacity="0.75"
                           Foreground="{StaticResource TextBrush}"/>
            </StackPanel>
        </Border>

        <!-- ── Building indicator ───────────────────────────────────────── -->
        <Border Padding="14,8" CornerRadius="6" Margin="0,0,0,12"
                Background="#22FFFFFF"
                Visibility="{Binding IsBuilding, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Building prompt…" FontSize="13" Opacity="0.6"
                       Foreground="{StaticResource TextBrush}"/>
        </Border>

        <!-- ── Expanded Search Queries ────────────────────────────────────── -->
        <Border Style="{StaticResource IronCard}" Margin="0,0,0,12" Padding="22">
            <StackPanel>
                <TextBlock Text="EXPANDED SEARCH QUERIES" Style="{StaticResource IronEyebrow}" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding ExpandedQueries, FallbackValue='(run Build Prompt to populate)'}"
                           FontFamily="Consolas, Courier New" FontSize="12"
                           Foreground="{StaticResource TextBrush}" Opacity="0.85"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- ── Retrieved Context ───────────────────────────────────────────── -->
        <Border Style="{StaticResource IronCard}" Margin="0,0,0,12" Padding="22">
            <StackPanel>
                <TextBlock Text="RETRIEVED CONTEXT" Style="{StaticResource IronEyebrow}" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding RetrievedItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,4" Padding="10,6"
                                    Background="#0AFFFFFF" CornerRadius="4">
                                <StackPanel>
                                    <TextBlock FontFamily="Consolas, Courier New" FontSize="12"
                                               Foreground="{StaticResource TextBrush}" FontWeight="SemiBold">
                                        <Run Text="{Binding FilePath}"/>
                                        <Run Text="  →  " Foreground="#60FFFFFF"/>
                                        <Run Text="{Binding SymbolName}" Foreground="#FFB8C4D8"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Preview}"
                                               FontFamily="Consolas, Courier New" FontSize="11"
                                               Foreground="{StaticResource TextBrush}" Opacity="0.45"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Margin="0,6,0,0"
                           Text="(no context retrieved — run Build Prompt or Run Grounding Test)"
                           FontSize="12" Opacity="0.35"
                           Foreground="{StaticResource TextBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RetrievedItems.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── AI Response Result Panel ─────────────────────────────────── -->
        <Border Style="{StaticResource IronCard}" Margin="0,0,0,12" Padding="22"
                Visibility="{Binding AiResponse, Converter={StaticResource StringToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="AI RESPONSE" Style="{StaticResource IronEyebrow}" Margin="0,0,0,10"/>

                <!-- Provider badge -->
                <TextBlock Margin="0,0,0,8" FontSize="12" Opacity="0.5"
                           Foreground="{StaticResource TextBrush}"
                           Visibility="{Binding ProviderInfo, Converter={StaticResource StringToVisibilityConverter}}">
                    <Run Text="Provider: "/><Run Text="{Binding ProviderInfo}"/>
                </TextBlock>

                <!-- Full response text -->
                <TextBox Text="{Binding AiResponse, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         MinHeight="120" MaxHeight="400"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="13" Padding="10"
                         Margin="0,0,0,16"/>

                <!-- Evaluation grid -->
                <TextBlock Text="EVALUATION" Style="{StaticResource IronEyebrow}" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Expected files / classes -->
                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,16,10">
                        <TextBlock Text="Expected Files / Classes" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding ExpectedFilesStatus, FallbackValue='—'}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>

                    <!-- Must mention -->
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Must Mention" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding MustMentionStatus, FallbackValue='—'}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>

                    <!-- Must NOT mention -->
                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,16,10">
                        <TextBlock Text="Must NOT Mention" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding MustNotMentionStatus, FallbackValue='—'}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>

                    <!-- Final result -->
                    <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,0,10">
                        <TextBlock Text="FINAL RESULT" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding ResultStatus, FallbackValue='—'}"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Full Generated Prompt ─────────────────────────────────────── -->
        <Border Style="{StaticResource IronCard}" Margin="0,0,0,12" Padding="22">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="FULL GENERATED PROMPT" Style="{StaticResource IronEyebrow}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="read-only · prompt sent to AI after Build Prompt / Run Grounding Test"
                               FontSize="11" Opacity="0.35"
                               Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <TextBox Text="{Binding PromptText, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         MinHeight="240" MaxHeight="560"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas, Courier New"
                         FontSize="12" Padding="10"/>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
