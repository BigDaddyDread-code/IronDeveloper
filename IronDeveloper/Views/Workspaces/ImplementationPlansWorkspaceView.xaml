<UserControl x:Class="IronDev.Agent.Views.Workspaces.ImplementationPlansWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             xmlns:controls="http://schemas.irondeveloper.com/controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ImplementationPlansWorkspaceViewModel, IsDesignTimeCreatable=False}">

    <Grid Background="{StaticResource Background/App}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <controls:WorkspaceHeader Grid.Row="0"
                                  Eyebrow="PLANS"
                                  Title="Implementation Plans"
                                  Margin="0">
            <controls:WorkspaceHeader.Actions>
                <Button Content="+ New Plan"
                        Command="{Binding NewPlanCommand}"
                        Style="{StaticResource AppButton.Primary}"/>
            </controls:WorkspaceHeader.Actions>
        </controls:WorkspaceHeader>
        <!-- ── Master-Detail ─────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT: Plan List — WorkspaceListPane ═══ -->
            <controls:WorkspaceListPane
                Grid.Column="0"
                Title="PLANS"
                Margin="0,0,12,0"
                ItemsSource="{Binding Plans}"
                SelectedItem="{Binding SelectedPlanSummary, Mode=TwoWay}">

                <controls:WorkspaceListPane.ItemTemplate>
                    <DataTemplate>
                        <controls:WorkspaceListItem
                            Title="{Binding Title}"
                            Subtitle="{Binding Goal}"
                            Metadata="{Binding Status}"
                            IconData="{StaticResource Icon.Nav.Layers}"/>
                    </DataTemplate>
                </controls:WorkspaceListPane.ItemTemplate>

            </controls:WorkspaceListPane>

            <!-- ═══ RIGHT: Detail/Editor ═══ -->
            <Border Grid.Column="1"
                    Background="{StaticResource Background/Panel}"
                    BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1"
                    CornerRadius="{StaticResource Radius/Large}">
                <Grid>
                    <!-- Empty state: no plan selected -->
                    <controls:EmptyResultsState
                        Title="No Plan Selected"
                        Description="Select a plan or create a new one to get started."
                        Visibility="{Binding HasDetail, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                    <!-- Editor panel -->
                    <ScrollViewer Visibility="{Binding HasDetail, Converter={StaticResource BoolToVisibilityConverter}}"
                                  VerticalScrollBarVisibility="Auto" Padding="24">
                        <StackPanel>

                            <!-- Title -->
                            <TextBlock Text="TITLE" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="16" FontWeight="SemiBold" Padding="10,8"
                                     Margin="0,0,0,16"/>

                            <!-- Status -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="STATUS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding StatusOptions}"
                                          SelectedItem="{Binding EditStatus}"
                                          Width="200" HorizontalAlignment="Left"
                                          Padding="8,6"/>
                            </StackPanel>

                            <!-- Goal -->
                            <TextBlock Text="PLAN GOAL" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditGoal, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60"
                                     Padding="10,8" Margin="0,0,0,16"/>

                            <!-- Scope -->
                            <TextBlock Text="SCOPE / OBJECTIVES" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditScope, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="48"
                                     Padding="10,8" Margin="0,0,0,16"/>

                            <!-- Proposed Steps -->
                            <TextBlock Text="PROPOSED STEPS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditProposedSteps, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="100"
                                     Padding="10,8" Margin="0,0,0,16"
                                     FontFamily="Consolas" FontSize="12"/>

                            <!-- Affected Context -->
                            <TextBlock Text="AFFECTED FILES / CLASSES" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditAffectedContext, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="48"
                                     Padding="10,8" Margin="0,0,0,16"/>

                            <!-- Risks / Notes -->
                            <TextBlock Text="RISKS &amp; NOTES" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditRisksNotes, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="48"
                                     Padding="10,8" Margin="0,0,0,16"/>

                            <!-- Linked Code Context (collapsible) -->
                            <Expander Header="Linked Code Context"
                                      Foreground="{StaticResource Text/Muted}"
                                      Margin="0,0,0,16">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="LINKED FILE PATHS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditLinkedFilePaths, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36"
                                             Padding="10,8" Margin="0,0,0,12"
                                             FontSize="11" FontFamily="Consolas"/>

                                    <TextBlock Text="LINKED SYMBOLS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditLinkedSymbols, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36"
                                             Padding="10,8"
                                             FontSize="11" FontFamily="Consolas"/>
                                </StackPanel>
                            </Expander>

                            <!-- Actions -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Content="Save Plan"
                                        Command="{Binding SavePlanCommand}"
                                        Style="{StaticResource AppButton.Primary}"
                                        Padding="24,8" Margin="0,0,8,0"
                                        IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"/>
                                <Button Grid.Column="1" Content="Cancel"
                                        Command="{Binding CancelEditCommand}"
                                        Style="{StaticResource AppButton.Ghost}"
                                        Padding="16,8" Margin="0,0,8,0"/>

                                <TextBlock Grid.Column="3" Text="{Binding SaveStatus}"
                                           Foreground="{StaticResource StatusReadyBrush}"
                                           VerticalAlignment="Center" FontSize="12"/>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
