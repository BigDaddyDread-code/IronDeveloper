<UserControl x:Class="IronDev.Agent.Views.Workspaces.DecisionsWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             xmlns:controls="http://schemas.irondeveloper.com/controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:DecisionsWorkspaceViewModel, IsDesignTimeCreatable=False}">

    <Grid Background="{StaticResource Background/App}" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="PROJECT MEMORY" Style="{StaticResource Typography.Eyebrow}"/>
                <TextBlock Text="Summary and Context Documents" Style="{StaticResource Typography.ScreenTitle}"/>
            </StackPanel>
            <Button Grid.Column="1" Content="+ New Document"
                    Command="{Binding NewDocumentCommand}"
                    Style="{StaticResource AppButton.Primary}"
                    Padding="20,8" VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource Background/Panel}"
                        BorderBrush="{StaticResource Border/Subtle}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="PROJECT SUMMARY" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding ProjectSummary, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="110"
                                 Padding="10,8"
                                 Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="Save Summary"
                                    Command="{Binding SaveSummaryCommand}"
                                    Style="{StaticResource AppButton.Primary}"
                                    Padding="16,8"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SummarySaveStatus}"
                                       Foreground="{StaticResource StatusReadyBrush}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <controls:WorkspaceListPane
                    Grid.Row="1"
                    Title="CONTEXT DOCUMENTS"
                    ItemsSource="{Binding Documents}"
                    SelectedItem="{Binding SelectedDocument, Mode=TwoWay}">

                    <controls:WorkspaceListPane.SearchField>
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="TYPE" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding DocumentTypeFilterOptions}"
                                      SelectedItem="{Binding FilterDocumentType}"
                                      Margin="0,0,0,8"/>
                            <TextBlock Text="STATUS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding StatusFilterOptions}"
                                      SelectedItem="{Binding FilterStatus}"/>
                        </StackPanel>
                    </controls:WorkspaceListPane.SearchField>

                    <controls:WorkspaceListPane.ItemTemplate>
                        <DataTemplate>
                            <controls:WorkspaceListItem
                                Title="{Binding Title}"
                                Subtitle="{Binding Summary}"
                                Metadata="{Binding AuthorityLevel}"
                                IconData="{StaticResource Icon.Nav.Decisions}"/>
                        </DataTemplate>
                    </controls:WorkspaceListPane.ItemTemplate>
                </controls:WorkspaceListPane>
            </Grid>

            <Border Grid.Column="1"
                    Background="{StaticResource Background/Panel}"
                    BorderBrush="{StaticResource Border/Subtle}"
                    BorderThickness="1"
                    CornerRadius="10">

                <Grid>
                    <controls:EmptyResultsState
                        Title="No Context Document Selected"
                        Description="Select a document or create one to capture a decision, standard, fact, recommendation, or open question."
                        Visibility="{Binding HasDetail, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                    <ScrollViewer Visibility="{Binding HasDetail, Converter={StaticResource BoolToVisibilityConverter}}"
                                  VerticalScrollBarVisibility="Auto" Padding="24">
                        <StackPanel>
                            <TextBlock Text="TITLE" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="16"
                                     FontWeight="SemiBold"
                                     Padding="10,8"
                                     Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="TYPE" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding DocumentTypeOptions}"
                                              SelectedItem="{Binding EditDocumentType}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="AUTHORITY" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding AuthorityLevelOptions}"
                                              SelectedItem="{Binding EditAuthorityLevel}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="STATUS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding StatusOptions}"
                                              SelectedItem="{Binding EditStatus}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="SUMMARY" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditSummary, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     Padding="10,8"
                                     Margin="0,0,0,16"/>

                            <TextBlock Text="CONTENT" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="180"
                                     Padding="10,8"
                                     Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="APPLIES TO AREA" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditAppliesToArea, UpdateSourceTrigger=PropertyChanged}" Padding="10,8"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="CAPABILITY" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditAppliesToCapability, UpdateSourceTrigger=PropertyChanged}" Padding="10,8"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="TAGS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditTags, UpdateSourceTrigger=PropertyChanged}" Padding="10,8"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="SOURCE" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditSource, UpdateSourceTrigger=PropertyChanged}" Padding="10,8"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="Save Document"
                                        Command="{Binding SaveDocumentCommand}"
                                        Style="{StaticResource AppButton.Primary}"
                                        Padding="24,8"
                                        Margin="0,0,8,0"
                                        IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"/>
                                <Button Grid.Column="1"
                                        Content="Archive"
                                        Command="{Binding ArchiveDocumentCommand}"
                                        Style="{StaticResource AppButton.Ghost}"
                                        Padding="16,8"
                                        Margin="0,0,8,0"/>
                                <Button Grid.Column="2"
                                        Content="Cancel"
                                        Command="{Binding CancelEditCommand}"
                                        Style="{StaticResource AppButton.Ghost}"
                                        Padding="16,8"/>

                                <TextBlock Grid.Column="4"
                                           Text="{Binding SaveStatus}"
                                           Foreground="{StaticResource StatusReadyBrush}"
                                           VerticalAlignment="Center"
                                           FontSize="12"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
