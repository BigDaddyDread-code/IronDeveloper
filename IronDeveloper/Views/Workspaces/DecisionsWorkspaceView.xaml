<UserControl x:Class="IronDev.Agent.Views.Workspaces.DecisionsWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:DecisionsWorkspaceViewModel, IsDesignTimeCreatable=False}">

    <Grid Background="{StaticResource AppBackgroundBrush}" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="DECISIONS" Style="{StaticResource IronEyebrow}"/>
                <TextBlock Text="Decision Management" Style="{StaticResource IronSectionTitle}"/>
            </StackPanel>
            <Button Grid.Column="1" Content="＋ New Decision"
                    Command="{Binding NewDecisionCommand}"
                    Style="{StaticResource IronPrimaryButton}"
                    Padding="20,8" VerticalAlignment="Center"/>
        </Grid>

        <!-- Master-Detail -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT: Decision List ═══ -->
            <Border Grid.Column="0" Style="{StaticResource IronCard}" Margin="0,0,12,0" Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ListBox ItemsSource="{Binding Decisions}"
                             SelectedItem="{Binding SelectedDecision, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0"
                             Padding="8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" Margin="0,0,0,4" CornerRadius="6"
                                        Background="#1A222C" Cursor="Hand">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <Border Style="{StaticResource IronStatusBadge}" Margin="0,0,6,0">
                                                <TextBlock Text="{Binding Status}" FontSize="10"
                                                           Foreground="{StaticResource StatusReadyBrush}"/>
                                            </Border>
                                            <Border Style="{StaticResource IronStatusBadge}"
                                                    Visibility="{Binding Category, Converter={StaticResource StringToVisibilityConverter}}">
                                                <TextBlock Text="{Binding Category}" FontSize="10"
                                                           Foreground="{StaticResource StatusInfoBrush}"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Border" Background="Transparent"
                                                    CornerRadius="6" Padding="2">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#2563EB30"/>
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#2563EB"/>
                                                    <Setter TargetName="Border" Property="BorderThickness" Value="1"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#1E3A5F20"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </ScrollViewer>
            </Border>

            <!-- ═══ RIGHT: Detail/Editor ═══ -->
            <Border Grid.Column="1" Style="{StaticResource IronCard}" Padding="0">

                <Grid>
                    <!-- Empty state -->
                    <TextBlock Text="Select a decision or create a new one"
                               Visibility="{Binding HasDetail, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- Editor panel -->
                    <ScrollViewer Visibility="{Binding HasDetail, Converter={StaticResource BoolToVisibilityConverter}}"
                                  VerticalScrollBarVisibility="Auto" Padding="24">
                        <StackPanel>
                            <!-- Title -->
                            <TextBlock Text="TITLE" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="16" FontWeight="SemiBold" Padding="10,8"
                                     Margin="0,0,0,16"/>

                            <!-- Status / Category row -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="STATUS" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding StatusOptions}"
                                              SelectedItem="{Binding EditStatus}"
                                              Padding="8,6"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="CATEGORY" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding CategoryOptions}"
                                              SelectedItem="{Binding EditCategory}"
                                              Padding="8,6"/>
                                </StackPanel>
                            </Grid>

                            <!-- Detail / Summary -->
                            <TextBlock Text="DETAIL" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditDetail, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80"
                                     Padding="10,8" Margin="0,0,0,16"/>

                            <!-- Rationale -->
                            <TextBlock Text="RATIONALE" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditReason, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60"
                                     Padding="10,8" Margin="0,0,0,16"/>

                            <!-- Linked Context -->
                            <Expander Header="Linked Code Context" Foreground="{StaticResource MutedBrush}"
                                      Margin="0,0,0,16">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="LINKED FILE PATHS" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditLinkedFilePaths, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36"
                                             Padding="10,8" Margin="0,0,0,12"
                                             FontSize="11" FontFamily="Consolas"/>

                                    <TextBlock Text="LINKED SYMBOLS" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditLinkedSymbols, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36"
                                             Padding="10,8"
                                             FontSize="11" FontFamily="Consolas"/>
                                </StackPanel>
                            </Expander>

                            <!-- Actions -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Content="Save Decision"
                                        Command="{Binding SaveDecisionCommand}"
                                        Style="{StaticResource IronPrimaryButton}"
                                        Padding="24,8" Margin="0,0,8,0"
                                        IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"/>
                                <Button Grid.Column="1" Content="Cancel"
                                        Command="{Binding CancelEditCommand}"
                                        Padding="16,8" Margin="0,0,8,0"/>

                                <TextBlock Grid.Column="3" Text="{Binding SaveStatus}"
                                           Foreground="{StaticResource StatusReadyBrush}"
                                           VerticalAlignment="Center" FontSize="12"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
