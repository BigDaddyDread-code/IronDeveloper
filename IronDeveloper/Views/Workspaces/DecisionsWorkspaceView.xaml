<UserControl x:Class="IronDev.Agent.Views.Workspaces.DecisionsWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             xmlns:controls="http://schemas.irondeveloper.com/controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:DecisionsWorkspaceViewModel, IsDesignTimeCreatable=False}">

    <Grid Background="{StaticResource Background/App}" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:WorkspaceHeader Grid.Row="0"
                                  Eyebrow="PROJECT KNOWLEDGE"
                                  Title="Knowledge and Discussions"
                                  Margin="0,0,0,18">
            <controls:WorkspaceHeader.Actions>
                <StackPanel Orientation="Horizontal">
                    <Button Content="+ New Item"
                            Command="{Binding NewDocumentCommand}"
                            Style="{StaticResource AppButton.Primary}"/>
                </StackPanel>
            </controls:WorkspaceHeader.Actions>
        </controls:WorkspaceHeader>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="270"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,14,0">
                <controls:WorkspaceListPane
                    Title="KNOWLEDGE ITEMS"
                    ItemsSource="{Binding Documents}"
                    SelectedItem="{Binding SelectedDocument, Mode=TwoWay}">

                    <controls:WorkspaceListPane.SearchField>
                        <StackPanel Margin="0,8,0,0">
                            <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="Filter knowledge..."
                                     Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="TYPE" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding DocumentTypeFilterOptions}"
                                              SelectedItem="{Binding FilterDocumentType}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="STATUS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding StatusFilterOptions}"
                                              SelectedItem="{Binding FilterStatus}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </controls:WorkspaceListPane.SearchField>

                    <controls:WorkspaceListPane.ItemTemplate>
                        <DataTemplate>
                            <controls:WorkspaceListItem
                                Title="{Binding Title}"
                                Subtitle="{Binding Status}"
                                Metadata="{Binding DocumentType}"
                                IconData="{StaticResource Icon.Nav.Decisions}">
                                <controls:WorkspaceListItem.ToolTip>
                                    <ToolTip MaxWidth="420">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource Text/Primary}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Foreground="{StaticResource Accent/Primary}"
                                                       FontSize="11"
                                                       Margin="0,4,0,8">
                                                <Run Text="{Binding DocumentType}"/>
                                                <Run Text=" / "/>
                                                <Run Text="{Binding Status}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Summary}"
                                                       Foreground="{StaticResource Text/Secondary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8"/>
                                            <TextBlock Text="{Binding Content}"
                                                       Foreground="{StaticResource Text/Primary}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="150"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Border BorderBrush="{StaticResource Border/Subtle}"
                                                    BorderThickness="0,1,0,0"
                                                    Margin="0,10,0,8"/>
                                            <TextBlock Foreground="{StaticResource Text/Muted}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap">
                                                <Run Text="Source: "/>
                                                <Run Text="{Binding Source}"/>
                                            </TextBlock>
                                            <TextBlock Foreground="{StaticResource Text/Muted}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap">
                                                <Run Text="Area: "/>
                                                <Run Text="{Binding AppliesToArea}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </controls:WorkspaceListItem.ToolTip>
                            </controls:WorkspaceListItem>
                        </DataTemplate>
                    </controls:WorkspaceListPane.ItemTemplate>
                </controls:WorkspaceListPane>
            </Grid>

            <Border Grid.Column="1"
                    Background="{StaticResource Background/Panel}"
                    BorderBrush="{StaticResource Border/Subtle}"
                    BorderThickness="1"
                    CornerRadius="8">

                <Grid>
                    <controls:EmptyResultsState
                        Title="No Knowledge Item Selected"
                        Description="Select a discussion, decision, standard, fact, recommendation, or open question to preview it here."
                        Visibility="{Binding HasDetail, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                    <Grid Visibility="{Binding HasDetail, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="24">
                            <StackPanel>
                                <Grid Margin="0,0,0,14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Background="{StaticResource Background/Interactive}"
                                                BorderBrush="{StaticResource Border/Subtle}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="8,3"
                                                Margin="0,0,6,0">
                                            <TextBlock Text="{Binding EditDocumentType}"
                                                       Foreground="{StaticResource Accent/Primary}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Background="{StaticResource Background/Interactive}"
                                                BorderBrush="{StaticResource Border/Subtle}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="8,3">
                                            <TextBlock Text="{Binding EditStatus}"
                                                       Foreground="{StaticResource Text/Secondary}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1"
                                               Text="{Binding EditTitle}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Text/Primary}"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="2"
                                               Text="{Binding SelectedDocumentMeta}"
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="11"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap"/>
                                </Grid>

                                <Border BorderBrush="{StaticResource Border/Subtle}"
                                        BorderThickness="0,1,0,0"
                                        Margin="0,4,0,14"/>

                                <TextBlock Text="CONTENT"
                                           Style="{StaticResource Typography.Eyebrow}"
                                           Margin="0,0,0,10"/>

                                <controls:StructuredTextView Text="{Binding SelectedDocumentBody}"
                                                             TextSize="15"/>

                                <StackPanel Visibility="{Binding IsEditingDocument, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border BorderBrush="{StaticResource Border/Subtle}"
                                            BorderThickness="0,1,0,0"
                                            Margin="0,22,0,14"/>

                                    <TextBlock Text="EDIT KNOWLEDGE ITEM"
                                               Style="{StaticResource Typography.Eyebrow}"
                                               Margin="0,0,0,12"/>

                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <controls:FormField Grid.Column="0" Label="TYPE">
                                            <ComboBox ItemsSource="{Binding DocumentTypeOptions}"
                                                      SelectedItem="{Binding EditDocumentType}"/>
                                        </controls:FormField>
                                        <controls:FormField Grid.Column="2" Label="AUTHORITY">
                                            <ComboBox ItemsSource="{Binding AuthorityLevelOptions}"
                                                      SelectedItem="{Binding EditAuthorityLevel}"/>
                                        </controls:FormField>
                                        <controls:FormField Grid.Column="4" Label="STATUS">
                                            <ComboBox ItemsSource="{Binding StatusOptions}"
                                                      SelectedItem="{Binding EditStatus}"/>
                                        </controls:FormField>
                                    </Grid>

                                    <controls:FormField Label="TITLE">
                                        <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="15"
                                                 FontWeight="SemiBold"/>
                                    </controls:FormField>

                                    <controls:FormField Label="SUMMARY">
                                        <TextBox Text="{Binding EditSummary, UpdateSourceTrigger=PropertyChanged}"
                                                 TextWrapping="Wrap"
                                                 MinHeight="48"/>
                                    </controls:FormField>

                                    <controls:FormField Label="CONTENT">
                                        <TextBox Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 MinHeight="150"/>
                                    </controls:FormField>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <controls:FormField Grid.Column="0" Label="APPLIES TO AREA">
                                            <TextBox Text="{Binding EditAppliesToArea, UpdateSourceTrigger=PropertyChanged}"/>
                                        </controls:FormField>
                                        <controls:FormField Grid.Column="2" Label="CAPABILITY">
                                            <TextBox Text="{Binding EditAppliesToCapability, UpdateSourceTrigger=PropertyChanged}"/>
                                        </controls:FormField>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <controls:FormField Grid.Column="0" Label="TAGS">
                                            <TextBox Text="{Binding EditTags, UpdateSourceTrigger=PropertyChanged}"/>
                                        </controls:FormField>
                                        <controls:FormField Grid.Column="2" Label="SOURCE">
                                            <TextBox Text="{Binding EditSource, UpdateSourceTrigger=PropertyChanged}"/>
                                        </controls:FormField>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="1"
                                BorderBrush="{StaticResource Border/Subtle}"
                                BorderThickness="0,1,0,0"
                                Padding="16,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <WrapPanel Grid.Column="0"
                                           VerticalAlignment="Center">
                                    <Border Background="{StaticResource Background/Interactive}"
                                            BorderBrush="{StaticResource Border/Subtle}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8,3"
                                            Margin="0,0,6,0">
                                        <TextBlock Foreground="{StaticResource Text/Secondary}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold">
                                            <Run Text="Document "/>
                                            <Run Text="{Binding EditId}"/>
                                        </TextBlock>
                                    </Border>
                                    <Border Background="{StaticResource Background/Interactive}"
                                            BorderBrush="{StaticResource Border/Subtle}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8,3"
                                            Margin="0,0,6,0">
                                        <TextBlock Text="{Binding EditAuthorityLevel}"
                                                   Foreground="{StaticResource Text/Secondary}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                    <Border Background="{StaticResource Background/Interactive}"
                                            BorderBrush="{StaticResource Border/Subtle}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8,3"
                                            Margin="0,0,6,0">
                                        <TextBlock Text="{Binding EditSource}"
                                                   Foreground="{StaticResource Text/Secondary}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                    <Border Background="{StaticResource Background/Interactive}"
                                            BorderBrush="{StaticResource Border/Subtle}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8,3"
                                            Margin="0,0,6,0"
                                            Visibility="{Binding EditAppliesToArea, Converter={StaticResource StringToVisibilityConverter}}">
                                        <TextBlock Foreground="{StaticResource Text/Secondary}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold">
                                            <Run Text="Area "/>
                                            <Run Text="{Binding EditAppliesToArea}"/>
                                        </TextBlock>
                                    </Border>
                                    <Border Background="{StaticResource Background/Interactive}"
                                            BorderBrush="{StaticResource Border/Subtle}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8,3"
                                            Visibility="{Binding EditTags, Converter={StaticResource StringToVisibilityConverter}}">
                                        <TextBlock Foreground="{StaticResource Text/Secondary}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold">
                                            <Run Text="Tags "/>
                                            <Run Text="{Binding EditTags}"/>
                                        </TextBlock>
                                    </Border>
                                </WrapPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Content="Discuss in Chat"
                                            Command="{Binding DiscussSelectedDocumentCommand}"
                                            Style="{StaticResource AppButton.CompactGhost}"
                                            Height="24"
                                            Padding="8,2"
                                            FontSize="11"
                                            Margin="8,0,0,0"/>
                                    <Button Content="Edit"
                                            Command="{Binding EditSelectedDocumentCommand}"
                                            Style="{StaticResource AppButton.CompactGhost}"
                                            Height="24"
                                            Padding="8,2"
                                            FontSize="11"
                                            Margin="6,0,0,0"/>
                                    <Button Content="Archive"
                                            Command="{Binding ArchiveDocumentCommand}"
                                            Style="{StaticResource AppButton.CompactGhost}"
                                            Height="24"
                                            Padding="8,2"
                                            FontSize="11"
                                            Margin="6,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <controls:EditorActionBar Grid.Row="2"
                                                  Visibility="{Binding IsEditingDocument, Converter={StaticResource BoolToVisibilityConverter}}"
                                                  Background="{StaticResource Background/Surface}"
                                                  SeparatorThickness="0,1,0,0"
                                                  BarPadding="16,12"
                                                  StatusText="{Binding SaveStatus}">
                            <controls:EditorActionBar.LeftActions>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Save Document"
                                            Command="{Binding SaveDocumentCommand}"
                                            Style="{StaticResource AppButton.Primary}"
                                            Margin="0,0,8,0"
                                            IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"/>
                                    <Button Content="Archive"
                                            Command="{Binding ArchiveDocumentCommand}"
                                            Style="{StaticResource AppButton.CompactGhost}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="Cancel"
                                            Command="{Binding CancelEditCommand}"
                                            Style="{StaticResource AppButton.CompactGhost}"/>
                                </StackPanel>
                            </controls:EditorActionBar.LeftActions>
                        </controls:EditorActionBar>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
