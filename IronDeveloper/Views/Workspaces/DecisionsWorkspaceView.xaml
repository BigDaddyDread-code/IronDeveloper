<UserControl x:Class="IronDev.Agent.Views.Workspaces.DecisionsWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             xmlns:controls="http://schemas.irondeveloper.com/controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:DecisionsWorkspaceViewModel, IsDesignTimeCreatable=False}">

    <Grid Background="{StaticResource Background/App}" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="DECISIONS" Style="{StaticResource Typography.Eyebrow}"/>
                <TextBlock Text="Decision Management" Style="{StaticResource Typography.ScreenTitle}"/>
            </StackPanel>
            <Button Grid.Column="1" Content="＋ New Decision"
                    Command="{Binding NewDecisionCommand}"
                    Style="{StaticResource AppButton.Primary}"
                    Padding="20,8" VerticalAlignment="Center"/>
        </Grid>

        <!-- ── Master-Detail ─────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT: Decision List — WorkspaceListPane ═══ -->
            <controls:WorkspaceListPane
                Grid.Column="0"
                Title="DECISIONS"
                Margin="0,0,12,0"
                ItemsSource="{Binding Decisions}"
                SelectedItem="{Binding SelectedDecision, Mode=TwoWay}">

                <controls:WorkspaceListPane.ItemTemplate>
                    <DataTemplate>
                        <controls:WorkspaceListItem
                            Title="{Binding Title}"
                            Subtitle="{Binding Detail}"
                            Metadata="{Binding Status}"
                            IconData="{StaticResource Icon.Nav.Decisions}"/>
                    </DataTemplate>
                </controls:WorkspaceListPane.ItemTemplate>

            </controls:WorkspaceListPane>

            <!-- ═══ RIGHT: Detail/Editor ═══ -->
            <Border Grid.Column="1"
                    Background="{StaticResource Background/Panel}"
                    BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1"
                    CornerRadius="10">

                <Grid>
                    <!-- Empty state: no decision selected -->
                    <controls:EmptyResultsState
                        Title="No Decision Selected"
                        Description="Select a decision or create a new one to capture an architectural choice."
                        Visibility="{Binding HasDetail, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                    <!-- Editor panel -->
                    <ScrollViewer Visibility="{Binding HasDetail, Converter={StaticResource BoolToVisibilityConverter}}"
                                  VerticalScrollBarVisibility="Auto" Padding="24">
                        <StackPanel>

                            <!-- Title -->
                            <TextBlock Text="TITLE" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="16" FontWeight="SemiBold" Padding="10,8"
                                     Margin="0,0,0,16"/>

                            <!-- Status / Category row -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="STATUS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding StatusOptions}"
                                              SelectedItem="{Binding EditStatus}"
                                              Padding="8,6"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="CATEGORY" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding CategoryOptions}"
                                              SelectedItem="{Binding EditCategory}"
                                              Padding="8,6"/>
                                </StackPanel>
                            </Grid>

                            <!-- Detail -->
                            <TextBlock Text="DETAIL" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditDetail, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80"
                                     Padding="10,8" Margin="0,0,0,16"/>

                            <!-- Rationale -->
                            <TextBlock Text="RATIONALE" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditReason, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60"
                                     Padding="10,8" Margin="0,0,0,16"/>

                            <!-- Linked Code Context (collapsible) -->
                            <Expander Header="Linked Code Context"
                                      Foreground="{StaticResource Text/Muted}"
                                      Margin="0,0,0,16">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="LINKED FILE PATHS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditLinkedFilePaths, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36"
                                             Padding="10,8" Margin="0,0,0,12"
                                             FontSize="11" FontFamily="Consolas"/>

                                    <TextBlock Text="LINKED SYMBOLS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditLinkedSymbols, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36"
                                             Padding="10,8"
                                             FontSize="11" FontFamily="Consolas"/>
                                </StackPanel>
                            </Expander>

                            <!-- Actions -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Content="Save Decision"
                                        Command="{Binding SaveDecisionCommand}"
                                        Style="{StaticResource AppButton.Primary}"
                                        Padding="24,8" Margin="0,0,8,0"
                                        IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"/>
                                <Button Grid.Column="1" Content="Cancel"
                                        Command="{Binding CancelEditCommand}"
                                        Style="{StaticResource AppButton.Ghost}"
                                        Padding="16,8" Margin="0,0,8,0"/>

                                <TextBlock Grid.Column="3" Text="{Binding SaveStatus}"
                                           Foreground="{StaticResource StatusReadyBrush}"
                                           VerticalAlignment="Center" FontSize="12"/>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
