<UserControl x:Class="IronDev.Agent.Views.Workspaces.RunReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:RunReportsViewModel, IsDesignTimeCreatable=False}">

    <Grid Background="{StaticResource Background/App}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource Background/Panel}"
                BorderBrush="{StaticResource Border/Subtle}"
                BorderThickness="0,0,1,0"
                Padding="16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="RUN REPORTS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                    <TextBlock Text="Recent runs" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource Text/Primary}"/>
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource AppButton.CompactGhost}"
                            HorizontalAlignment="Left"
                            Margin="0,12,0,0"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding Runs}"
                         SelectedItem="{Binding SelectedRun, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10"
                                    Margin="0,0,0,8"
                                    Background="{StaticResource Background/Interactive}"
                                    BorderBrush="{StaticResource Border/Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock Text="{Binding RunId}" Foreground="{StaticResource Text/Primary}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource Text/Muted}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding Project}" Foreground="{StaticResource Accent/Primary}" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="  " FontSize="11"/>
                                        <TextBlock Text="{Binding Status}" Foreground="{Binding Status, Converter={StaticResource StatusToBrushConverter}}" FontSize="11" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Column="1" Padding="24" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="RUN REPORT" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding RunTitle}" Style="{StaticResource Typography.ScreenTitle}" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding Summary}" Foreground="{StaticResource Text/Muted}" TextWrapping="Wrap" Margin="0,0,0,18"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="12" Margin="0,0,8,0" Background="{StaticResource Background/Panel}" BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="PROJECT" Style="{StaticResource Typography.Eyebrow}"/>
                            <TextBlock Text="{Binding Project}" Foreground="{StaticResource Text/Primary}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="12" Margin="0,0,8,0" Background="{StaticResource Background/Panel}" BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="STATUS" Style="{StaticResource Typography.Eyebrow}"/>
                            <TextBlock Text="{Binding Status}" Foreground="{Binding Status, Converter={StaticResource StatusToBrushConverter}}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="12" Margin="0,0,8,0" Background="{StaticResource Background/Panel}" BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="REAL REPO MUTATION" Style="{StaticResource Typography.Eyebrow}"/>
                            <TextBlock Text="{Binding RealRepoMutationCount}" Foreground="{StaticResource Text/Primary}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Padding="12" Background="{StaticResource Background/Panel}" BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="DISPOSABLE FILES" Style="{StaticResource Typography.Eyebrow}"/>
                            <TextBlock Text="{Binding DisposableFilesChanged}" Foreground="{StaticResource Text/Primary}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Text="STAGES" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding Stages}" Margin="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding StageName}" Foreground="{StaticResource Text/Primary}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{Binding Status, Converter={StaticResource StatusToBrushConverter}}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="2" Text="{Binding Summary}" Foreground="{StaticResource Text/Muted}" TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="ATTEMPTS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding Attempts}" Margin="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding AttemptNumber, StringFormat=Attempt {0}}" Foreground="{StaticResource Text/Primary}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Type}" Foreground="{StaticResource Accent/Primary}"/>
                                <TextBlock Grid.Column="2" Text="{Binding Status}" Foreground="{Binding Status, Converter={StaticResource StatusToBrushConverter}}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="3" Text="{Binding Summary}" Foreground="{StaticResource Text/Muted}" TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="REPAIRS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding Repairs}" Margin="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding RepairAttemptNumber, StringFormat=Repair {0}}" Foreground="{StaticResource Text/Primary}"/>
                                <TextBlock Grid.Column="1" Text="{Binding TriggerFailureClassification}" Foreground="{StaticResource Accent/Primary}"/>
                                <TextBlock Grid.Column="2" Text="{Binding Status}" Foreground="{Binding Status, Converter={StaticResource StatusToBrushConverter}}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="3" Text="{Binding PlannedFix}" Foreground="{StaticResource Text/Muted}" TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="BOUNDARY" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding Boundary}" Foreground="{StaticResource Text/Muted}" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="2"
                Background="{StaticResource Background/Panel}"
                BorderBrush="{StaticResource Border/Subtle}"
                BorderThickness="1,0,0,0"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="220"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="EVIDENCE" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource Text/Muted}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding WorkspacePath}" Foreground="{StaticResource Text/Muted}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0"/>
                </StackPanel>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Evidence}"
                         SelectedItem="{Binding SelectedEvidence, Mode=TwoWay}"
                         Background="{StaticResource Background/App}"
                         BorderBrush="{StaticResource Border/Subtle}"
                         BorderThickness="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding Type}" Foreground="{StaticResource Text/Primary}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Summary}" Foreground="{StaticResource Text/Muted}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="2" Text="PREVIEW" Style="{StaticResource Typography.Eyebrow}" Margin="0,14,0,8"/>

                <TextBox Grid.Row="3"
                         Text="{Binding SelectedEvidenceText}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="11"
                         Background="{StaticResource Background/App}"
                         Foreground="{StaticResource Text/Secondary}"
                         BorderBrush="{StaticResource Border/Subtle}"
                         BorderThickness="1"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
