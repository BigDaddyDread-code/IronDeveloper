<UserControl x:Class="IronDev.Agent.Views.Workspaces.TicketsWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             xmlns:controls="http://schemas.irondeveloper.com/controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TicketsWorkspaceViewModel, IsDesignTimeCreatable=False}">

    <Grid Background="{StaticResource IronDev.Brush.Background.App}"
          AutomationProperties.AutomationId="tickets.workspace">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <controls:WorkspaceHeader Grid.Row="0"
                                  Eyebrow="AI DEVELOPMENT WORKFLOW"
                                  Title="Tickets"
                                  Subtitle="{Binding ActiveProjectName}"
                                  Margin="0"
                                  AutomationProperties.AutomationId="tickets.header">
            <controls:WorkspaceHeader.Actions>
                <controls:CrudCommandBar ShowCreate="True"
                                         CreateText="+ New Ticket"
                                         CreateCommand="{Binding NewTicketCommand}"
                                         CreateToolTip="Create a new draft ticket."
                                         ShowRefresh="False"
                                         AutomationProperties.AutomationId="ticket.commandBar.primary">
                    <controls:CrudCommandBar.SecondaryActions>
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource IronDev.StatusBadge.Host}"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding HasDetail, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Foreground="{StaticResource IronDev.Brush.Text.Secondary}"
                                           FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                           FontWeight="SemiBold"
                                           Text="{Binding Tickets.Count, StringFormat={}{0} tickets}"/>
                            </Border>
                            <Border Style="{StaticResource IronDev.StatusBadge.Host}"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center">
                                <TextBlock Foreground="{StaticResource IronDev.Brush.Accent.Trace}"
                                           FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                           FontWeight="SemiBold"
                                           Text="{Binding BuildReadinessBadgeText, StringFormat='Readiness: {0}'}"/>
                            </Border>
                            <Button Command="{Binding GenerateCodebaseTicketsCommand}"
                                    Style="{StaticResource IronDev.CommandButton.Ghost}"
                                    Margin="0,0,8,0"
                                    AutomationProperties.AutomationId="ticket.generateFromCodebase"
                                    ToolTip="Analyze project context and generate improvement tickets">
                                <TextBlock Text="Analyze Codebase" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGeneratingCodebaseTickets}" Value="True">
                                                    <Setter Property="Text" Value="Analyzing..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                            <Button Content="Open Draft Review"
                                    IsEnabled="{Binding CodexReview.HasTickets}"
                                    Style="{StaticResource IronDev.CommandButton.Ghost}"
                                    AutomationProperties.AutomationId="ticket.review.open"
                                    ToolTipService.ShowOnDisabled="True"
                                    ToolTip="Available when generated draft tickets are waiting for review."/>
                        </StackPanel>
                    </controls:CrudCommandBar.SecondaryActions>
                </controls:CrudCommandBar>
            </controls:WorkspaceHeader.Actions>
        </controls:WorkspaceHeader>
        <!-- Master-Detail -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Ticket List -->
            <controls:WorkspaceListPane Grid.Column="0"
                                        Eyebrow="WORK QUEUE"
                                        Title="Tickets"
                                        Margin="0,0,12,0"
                                        AutomationProperties.AutomationId="ticket.list"
                                        ItemsSource="{Binding Tickets}"
                                        SelectedItem="{Binding SelectedTicket, Mode=TwoWay}">
                <controls:WorkspaceListPane.ItemTemplate>
                    <DataTemplate>
                        <Grid AutomationProperties.AutomationId="ticket.row"
                              Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="3"
                                    Background="{StaticResource IronDev.Brush.Accent.Command}"
                                    CornerRadius="2"
                                    Margin="0,2,8,2">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <controls:SurfacePanel Grid.Column="1"
                                                   Padding="12,10"
                                                   CornerRadius="8">
                                <controls:SurfacePanel.Style>
                                    <Style TargetType="{x:Type controls:SurfacePanel}">
                                        <Setter Property="Variant" Value="Subtle"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="True">
                                                <Setter Property="Variant" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </controls:SurfacePanel.Style>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="{StaticResource Text/Primary}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Summary, Converter={StaticResource MarkdownPreviewConverter}}"
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               MaxHeight="34"
                                               Margin="0,4,0,8"/>
                                    <WrapPanel>
                                        <controls:StatusBadge Text="{Binding Status}" Status="Info" Margin="0,0,6,4"/>
                                        <controls:StatusBadge Text="{Binding Priority}" Status="Warning" Margin="0,0,6,4"/>
                                        <controls:StatusBadge Text="{Binding TicketType}" Status="Neutral" Margin="0,0,6,4"/>
                                        <controls:StatusBadge Text="DRAFT"
                                                              Status="ReviewRequired"
                                                              Margin="0,0,6,4"
                                                              Visibility="{Binding IsDraft, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </controls:SurfacePanel>
                        </Grid>
                    </DataTemplate>
                </controls:WorkspaceListPane.ItemTemplate>
            </controls:WorkspaceListPane>

            <!-- RIGHT: Detail/Editor -->
            <controls:SurfacePanel Grid.Column="1" Variant="Subtle" Padding="0" Margin="0,0,12,0"
                                   AutomationProperties.AutomationId="ticket.detail">
                <Grid>
                    <controls:EmptyResultsState Title="No Ticket Selected" 
                                               Description="Select a ticket from the list or create a new one with IronDev Architect to begin."
                                               AutomationProperties.AutomationId="ticket.emptyState">
                        <controls:EmptyResultsState.Style>
                            <Style TargetType="controls:EmptyResultsState">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding HasDetail}" Value="False"/>
                                            <Condition Binding="{Binding DraftPreflight, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=None}" Value="True"/>
                                            <Condition Binding="{Binding CodexReview.HasTickets}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </controls:EmptyResultsState.Style>
                    </controls:EmptyResultsState>

                    <!-- Preflight: Index Choice Panel -->
                    <!-- Visible when DraftPreflight is NeedsChoice, Indexing, or IndexFailed -->
                    <Grid AutomationProperties.AutomationId="ticket.preflight">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DraftPreflight, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=NeedsChoice}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DraftPreflight, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Indexing}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DraftPreflight, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=IndexFailed}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <controls:SurfacePanel Variant="Subtle" Padding="28" Margin="32"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                               MaxWidth="520"
                                               AutomationProperties.AutomationId="ticket.preflight.panel">
                            <StackPanel>

                                <!-- Header: changes per state -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Margin="0,0,8,0" FontSize="16" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#x26A0;"/>
                                                <Setter Property="Foreground" Value="{StaticResource IronDev.Brush.Status.Warning}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DraftPreflight, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Indexing}" Value="True">
                                                        <Setter Property="Text" Value="&#x23F3;"/>
                                                        <Setter Property="Foreground" Value="{StaticResource Accent/Primary}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DraftPreflight, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=IndexFailed}" Value="True">
                                                        <Setter Property="Text" Value="&#x2716;"/>
                                                        <Setter Property="Foreground" Value="{StaticResource IronDev.Brush.Status.Danger}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Project Not Indexed"/>
                                                <Setter Property="Foreground" Value="{StaticResource IronDev.Brush.Status.Warning}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DraftPreflight, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Indexing}" Value="True">
                                                        <Setter Property="Text" Value="Indexing Project..."/>
                                                        <Setter Property="Foreground" Value="{StaticResource Accent/Primary}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DraftPreflight, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=IndexFailed}" Value="True">
                                                        <Setter Property="Text" Value="Indexing Did Not Complete"/>
                                                        <Setter Property="Foreground" Value="{StaticResource IronDev.Brush.Status.Danger}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Body text: static for NeedsChoice; bound for Indexing/IndexFailed -->
                                <TextBlock TextWrapping="Wrap" FontSize="13"
                                           Foreground="{StaticResource Text/Secondary}"
                                           Margin="0,0,0,20">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"
                                                    Value="This project is not indexed. AI context may be incomplete, reducing draft quality.&#x0a;&#x0a;What would you like to do?"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DraftPreflight, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Indexing}" Value="True">
                                                    <Setter Property="Text" Value="{Binding DraftPreflightMessage}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DraftPreflight, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=IndexFailed}" Value="True">
                                                    <Setter Property="Text" Value="{Binding DraftPreflightMessage}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Action buttons: Index First and Continue disabled while Indexing -->
                                <Button Content="&#x1F5C2; Index Project First"
                                        Command="{Binding PreflightIndexProjectCommand}"
                                        Style="{StaticResource IronDev.CommandButton.Primary}"
                                        Padding="20,10" Margin="0,0,0,8"
                                        HorizontalAlignment="Stretch"
                                        AutomationProperties.AutomationId="ticket.preflight.indexProject"
                                        IsEnabled="{Binding IsDraftIndexing, Converter={StaticResource InverseBoolConverter}}"
                                        ToolTip="Run the local code indexer, then automatically generate the draft with full context"/>
                                <Button Content="&#x26A1; Continue Without Index"
                                        Command="{Binding PreflightContinueCommand}"
                                        Style="{StaticResource IronDev.CommandButton.Secondary}"
                                        Padding="20,10" Margin="0,0,0,8"
                                        HorizontalAlignment="Stretch"
                                        AutomationProperties.AutomationId="ticket.preflight.continueWithoutIndex"
                                        IsEnabled="{Binding IsDraftIndexing, Converter={StaticResource InverseBoolConverter}}"
                                        ToolTip="Generate draft now using limited context (no code snippets)"/>
                                <Button Content="&#x2715; Cancel"
                                        Command="{Binding PreflightCancelCommand}"
                                        Style="{StaticResource IronDev.CommandButton.Ghost}"
                                        Padding="20,8"
                                        HorizontalAlignment="Stretch"
                                        AutomationProperties.AutomationId="ticket.preflight.cancel"
                                        ToolTip="Discard and return to Chat"/>

                            </StackPanel>
                        </controls:SurfacePanel>
                    </Grid>

                    <!-- Codex generated ticket review/import surface -->
                    <Grid Visibility="{Binding CodexReview.HasTickets, Converter={StaticResource BoolToVisibilityConverter}}"
                          AutomationProperties.AutomationId="ticket.review.queue">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                BorderBrush="{StaticResource Border/Subtle}"
                                BorderThickness="0,0,0,1"
                                Padding="18,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="GENERATED CODEX TICKETS"
                                               Style="{StaticResource Typography.Eyebrow}"
                                               Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding CodexReview.ContextBannerText}"
                                               Foreground="{StaticResource Text/Primary}"
                                               FontSize="13"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding CodexReview.ContextWarningText}"
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"
                                               Visibility="{Binding CodexReview.HasContextWarnings, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CodexReview.StatusText}"
                                           Foreground="{StaticResource Text/Muted}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="16,0,0,0"/>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="18"
                                      AutomationProperties.AutomationId="ticket.review.scroll">
                            <ItemsControl ItemsSource="{Binding CodexReview.Tickets}"
                                          AutomationProperties.AutomationId="ticket.review.list">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander IsExpanded="False"
                                                  Margin="0,0,0,10"
                                                  Background="{StaticResource Background/Surface}"
                                                  BorderBrush="{StaticResource Border/Subtle}"
                                                  Foreground="{StaticResource Text/Primary}">
                                            <Expander.Header>
                                                <Grid MinHeight="46" Margin="8,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="34"/>
                                                        <ColumnDefinition Width="42"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="92"/>
                                                        <ColumnDefinition Width="72"/>
                                                        <ColumnDefinition Width="92"/>
                                                        <ColumnDefinition Width="56"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="76"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              VerticalAlignment="Center"
                                                              AutomationProperties.AutomationId="ticket.review.row.select"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding SuggestedBuildOrder}"
                                                               Foreground="{StaticResource Text/Muted}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,12,0">
                                                        <TextBlock Text="{Binding Title}"
                                                                   Foreground="{StaticResource Text/Primary}"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Problem}"
                                                                   Foreground="{StaticResource Text/Muted}"
                                                                   FontSize="11"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="3" Text="{Binding Category}" Foreground="{StaticResource Text/Secondary}" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding RiskLevel}" Foreground="{StaticResource Text/Secondary}" FontSize="11" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="5" Text="{Binding ConfidenceText}" Foreground="{StaticResource Text/Primary}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="6" Text="{Binding FilesCountText}" Foreground="{StaticResource Text/Secondary}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="7" Text="{Binding SymbolsCountText}" Foreground="{StaticResource Text/Secondary}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="8" Text="{Binding WarningsCountText}" Foreground="{StaticResource Text/Secondary}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Expander.Header>
                                            <Grid Margin="20,4,20,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,14">
                                                    <TextBlock Text="PROBLEM" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,5"/>
                                                    <TextBlock Text="{Binding Problem}" Foreground="{StaticResource Text/Primary}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,14">
                                                    <TextBlock Text="PROPOSED CHANGE" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,5"/>
                                                    <TextBlock Text="{Binding ProposedChange}" Foreground="{StaticResource Text/Primary}" TextWrapping="Wrap"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,14">
                                                    <TextBlock Text="AFFECTED FILES" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,5"/>
                                                    <TextBlock Text="{Binding AffectedFilesText}" Foreground="{StaticResource Text/Secondary}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,14">
                                                    <TextBlock Text="AFFECTED SYMBOLS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,5"/>
                                                    <TextBlock Text="{Binding AffectedSymbolsText}" Foreground="{StaticResource Text/Secondary}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,0">
                                                    <TextBlock Text="ACCEPTANCE / TESTS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,5"/>
                                                    <TextBlock Text="{Binding AcceptanceCriteriaText}" Foreground="{StaticResource Text/Primary}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                                    <TextBlock Text="{Binding TestSuggestionsText}" Foreground="{StaticResource Text/Secondary}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="1">
                                                    <TextBlock Text="GROUNDING WARNINGS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,5"/>
                                                    <TextBlock Text="{Binding GroundingWarningsText}" Foreground="{StaticResource Text/Secondary}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <controls:EditorActionBar Grid.Row="2"
                                                  Background="{StaticResource Background/Surface}"
                                                  SeparatorThickness="0,1,0,0"
                                                  BarPadding="16,12"
                                                  StatusText="{Binding CodexReview.StatusText}"
                                                  AutomationProperties.AutomationId="ticket.review.commandBar">
                            <controls:EditorActionBar.LeftActions>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Import Selected"
                                            Command="{Binding CodexReview.ImportSelectedTicketsCommand}"
                                            Style="{StaticResource IronDev.CommandButton.Primary}"
                                            Margin="0,0,8,0"
                                            AutomationProperties.AutomationId="ticket.review.importSelected"
                                            IsEnabled="{Binding CodexReview.IsImporting, Converter={StaticResource InverseBoolConverter}}"/>
                                    <Button Content="Clear Review"
                                            Command="{Binding CodexReview.ClearCommand}"
                                            Style="{StaticResource IronDev.CommandButton.Ghost}"
                                            AutomationProperties.AutomationId="ticket.review.clear"/>
                                </StackPanel>
                            </controls:EditorActionBar.LeftActions>
                            <controls:EditorActionBar.RightActions>
                                <TextBlock Text="{Binding CodexReview.SelectedTicketCount, StringFormat={}{0} selected}"
                                           Foreground="{StaticResource Text/Muted}"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>
                            </controls:EditorActionBar.RightActions>
                        </controls:EditorActionBar>
                    </Grid>

                    <Grid Visibility="{Binding HasDetail, Converter={StaticResource BoolToVisibilityConverter}}"
                          AutomationProperties.AutomationId="ticket.editor">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- 0: draft banner -->
                            <RowDefinition Height="Auto"/>  <!-- 1: tab header -->
                            <RowDefinition Height="*"/>     <!-- 2: content -->
                            <RowDefinition Height="Auto"/>  <!-- 3: footer -->
                        </Grid.RowDefinitions>

                        <!-- Draft Banner: compact single row -->
                        <Border Grid.Row="0"
                                Visibility="{Binding IsDraftMode, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="{StaticResource Brush.Status.Info.Background}" BorderBrush="{StaticResource Brush.Status.Info.Border}" BorderThickness="0,0,0,1"
                                Padding="16,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Icon + label -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Draft" Foreground="{StaticResource Brush.Status.Info.Foreground}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <TextBlock Text="Draft Ticket - review before saving"
                                               Foreground="{StaticResource Brush.Status.Info.Foreground}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Generating / status -->
                                <TextBlock Grid.Column="1"
                                           Foreground="{StaticResource Text/Muted}" FontSize="11" VerticalAlignment="Center" Margin="12,0"
                                           MaxWidth="400" TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding DraftStatusMessage}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDraftGenerating}" Value="True">
                                                    <Setter Property="Text" Value="Generating..."/>
                                                    <Setter Property="FontStyle" Value="Italic"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!-- Limited context inline chip -->
                                <Border Grid.Column="2"
                                        Visibility="{Binding IsContextLimited, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Background="{StaticResource Brush.Status.Warning.Background}" BorderBrush="{StaticResource Brush.Status.Warning.Border}" BorderThickness="1"
                                        CornerRadius="3" Padding="7,2" Margin="0,0,8,0"
                                        ToolTip="Project not indexed - see Code Context tab">
                                    <TextBlock Text="Limited context" Foreground="{StaticResource Brush.Status.Warning.Foreground}" FontSize="10" FontWeight="SemiBold"/>
                                </Border>
                                <!-- AI badge -->
                                <Border Grid.Column="3" Background="{StaticResource Accent/Primary}" CornerRadius="3" Padding="7,2">
                                    <TextBlock Text="AI GENERATED" Foreground="{StaticResource IronDev.Brush.Background.App}" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Ticket workflow identity -->
                        <Border Grid.Row="1" BorderBrush="{StaticResource Border/Subtle}" BorderThickness="0,0,0,1" Padding="18,14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,18,0">
                                    <TextBlock Text="SELECTED TICKET" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding EditTitle, FallbackValue='No ticket selected', TargetNullValue='No ticket selected'}"
                                               Foreground="{StaticResource Text/Primary}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <WrapPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <controls:StatusBadge Text="{Binding EditStatus}" Status="Info" Margin="0,0,6,6"/>
                                    <controls:StatusBadge Text="{Binding EditPriority}" Status="Warning" Margin="0,0,6,6"/>
                                    <controls:StatusBadge Text="{Binding BuildReadinessBadgeText}" Status="{Binding BuildReadinessBadgeStatus}" Margin="0,0,0,6"
                                                          Visibility="{Binding ShowBuildReadiness, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </WrapPanel>

                                <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,14,0,0">
                                    <Border Style="{StaticResource IronDev.StatusBadge.Host}" Margin="0,0,8,8">
                                        <TextBlock Foreground="{StaticResource IronDev.Brush.Text.Secondary}"
                                                   FontSize="{StaticResource IronDev.Font.Size.Caption}"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Next: review brief"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDirtyEditState}" Value="True">
                                                            <Setter Property="Text" Value="Next: save changes"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CanBuildTicket}" Value="True">
                                                            <Setter Property="Text" Value="Next: build ticket"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsDraftMode}" Value="True">
                                                            <Setter Property="Text" Value="Next: review generated draft"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <Border Style="{StaticResource IronDev.StatusBadge.Host}"
                                            Margin="0,0,8,8"
                                            Visibility="{Binding HasDirtyEditState, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="UNSAVED" Foreground="{StaticResource Brush.Status.Warning.Foreground}"
                                                   FontSize="{StaticResource IronDev.Font.Size.Caption}" FontWeight="SemiBold"/>
                                    </Border>
                                    <Border Style="{StaticResource IronDev.StatusBadge.Host}"
                                            Margin="0,0,8,8"
                                            Visibility="{Binding IsContextLimited, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="CONTEXT LIMITED" Foreground="{StaticResource Brush.Status.Warning.Foreground}"
                                                   FontSize="{StaticResource IronDev.Font.Size.Caption}" FontWeight="SemiBold"/>
                                    </Border>

                                    <RadioButton Content="Brief" IsChecked="{Binding ActiveTab, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Overview, Mode=TwoWay}"
                                                 Style="{StaticResource AppRadioTab}"
                                                 AutomationProperties.AutomationId="ticket.tab.overview"/>
                                    <RadioButton Content="Plan" IsChecked="{Binding ActiveTab, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=ImplementationPlan, Mode=TwoWay}"
                                                 Style="{StaticResource AppRadioTab}"
                                                 AutomationProperties.AutomationId="ticket.tab.plan"/>
                                    <RadioButton Content="Context" IsChecked="{Binding ActiveTab, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=CodeContext, Mode=TwoWay}"
                                                 Style="{StaticResource AppRadioTab}"
                                                 AutomationProperties.AutomationId="ticket.tab.codeContext"/>
                                    <RadioButton Content="Tests" IsChecked="{Binding ActiveTab, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Tests, Mode=TwoWay}"
                                                 Style="{StaticResource AppRadioTab}"
                                                 AutomationProperties.AutomationId="ticket.tab.tests"/>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <!-- Content Area -->
                        <ScrollViewer x:Name="TicketDetailScroll"
                                      Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="16"
                                      AutomationProperties.AutomationId="ticket.editor.scroll">
                            <Grid Width="{Binding ViewportWidth, ElementName=TicketDetailScroll}">
                                <!-- TAB: Overview -->
                                <StackPanel AutomationProperties.AutomationId="ticket.detail.brief">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveTab}" Value="Overview">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    
                                    <controls:StatusCallout Title="{Binding BuildReadinessTitle}"
                                                            Message="{Binding BuildReadinessMessage}"
                                                            Details="{Binding BuildReadinessDetails}"
                                                            BadgeText="{Binding BuildReadinessBadgeText}"
                                                            Status="{Binding BuildReadinessBadgeStatus}"
                                                            ActionText="{Binding BuildReadinessActionText}"
                                                            ActionCommand="{Binding RequestIndexCommand}"
                                                            Visibility="{Binding ShowBuildReadiness, Converter={StaticResource BoolToVisibilityConverter}}"
                                                            Margin="0,0,0,16"/>

                                    <controls:SurfacePanel Variant="Subtle" Padding="20,16" Margin="0,0,0,16">
                                        <StackPanel>
                                            <controls:FormField Label="TICKET TITLE">
                                                <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="16"
                                                         FontWeight="SemiBold"
                                                         Style="{StaticResource IronDev.Input.TextBox}"
                                                         AutomationProperties.AutomationId="ticket.editor.title"/>
                                            </controls:FormField>

                                            <!-- Status / Priority / Type - native ComboBox for reliable text display -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                <StackPanel Margin="0,0,16,0">
                                                    <TextBlock Text="STATUS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,6"/>
                                                    <ComboBox ItemsSource="{Binding StatusOptions}"
                                                              SelectedItem="{Binding EditStatus}"
                                                              MinWidth="170" Height="38"
                                                              Style="{StaticResource IronDev.Input.ComboBox}"
                                                              AutomationProperties.AutomationId="ticket.editor.status"
                                                              Foreground="{StaticResource Input.Foreground}"
                                                              Background="{StaticResource Input.Background}"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,16,0">
                                                    <TextBlock Text="PRIORITY" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,6"/>
                                                    <ComboBox ItemsSource="{Binding PriorityOptions}"
                                                              SelectedItem="{Binding EditPriority}"
                                                              MinWidth="170" Height="38"
                                                              Style="{StaticResource IronDev.Input.ComboBox}"
                                                              AutomationProperties.AutomationId="ticket.editor.priority"
                                                              Foreground="{StaticResource Input.Foreground}"
                                                              Background="{StaticResource Input.Background}"/>
                                                </StackPanel>
                                                <StackPanel>
                                                    <TextBlock Text="TYPE" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,6"/>
                                                    <ComboBox ItemsSource="{Binding TypeOptions}"
                                                              SelectedItem="{Binding EditTicketType}"
                                                              MinWidth="170" Height="38"
                                                              Style="{StaticResource IronDev.Input.ComboBox}"
                                                              AutomationProperties.AutomationId="ticket.editor.type"
                                                              Foreground="{StaticResource Input.Foreground}"
                                                              Background="{StaticResource Input.Background}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <controls:FormField Label="SUMMARY">
                                                <TextBox Text="{Binding EditSummary, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60"
                                                         Style="{StaticResource IronDev.Input.TextBox}"
                                                         AutomationProperties.AutomationId="ticket.editor.summary"/>
                                            </controls:FormField>

                                            <controls:FormField Label="ACCEPTANCE CRITERIA">
                                                <TextBox Text="{Binding EditAcceptanceCriteria, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60"
                                                         Style="{StaticResource IronDev.Input.TextBox}"
                                                         AutomationProperties.AutomationId="ticket.editor.acceptanceCriteria"/>
                                            </controls:FormField>
                                        </StackPanel>
                                    </controls:SurfacePanel>
                                </StackPanel>

                                <!-- TAB: Plan -->
                                <StackPanel AutomationProperties.AutomationId="ticket.detail.plan">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveTab}" Value="ImplementationPlan">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    
                                    <!-- No plan yet -->
                                    <controls:SurfacePanel Visibility="{Binding HasPlan, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                                          Variant="Subtle" Padding="48" Margin="0,0,0,16">
                                        <StackPanel HorizontalAlignment="Center">
                                            <controls:EmptyResultsState Title="No Implementation Plan" 
                                                                       Description="Create a plan to outline the technical steps for this ticket."/>
                                            <Button Content="Generate Implementation Plan"
                                                    Command="{Binding GenerateImplementationPlanCommand}"
                                                    Style="{StaticResource IronDev.CommandButton.Primary}"
                                                    Padding="20,10" Margin="0,24,0,0"
                                                    AutomationProperties.AutomationId="ticket.plan.generate"/>
                                        </StackPanel>
                                    </controls:SurfacePanel>

                                    <!-- Plan Editor -->
                                    <StackPanel Visibility="{Binding HasPlan, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <controls:SurfacePanel Variant="Subtle" Padding="24" Margin="0,0,0,16">
                                            <StackPanel>
                                                <!-- Plan Title: full width, no floating button beside it -->
                                                <controls:FormField Label="PLAN TITLE" Margin="0,0,0,8">
                                                    <TextBox Text="{Binding PlanTitle, UpdateSourceTrigger=PropertyChanged}" FontSize="14" FontWeight="SemiBold"/>
                                                </controls:FormField>

                                                <!-- Ask about this plan: secondary action row, sits below title -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16" HorizontalAlignment="Left">
                                                    <Button Content="Ask about this plan"
                                                            Command="{Binding AskAboutPlanCommand}"
                                                            Style="{StaticResource IronDev.CommandButton.Ghost}"
                                                            Padding="12,5"
                                                            AutomationProperties.AutomationId="ticket.plan.ask"/>
                                                </StackPanel>

                                                <controls:FormField Label="PLAN GOAL">
                                                    <TextBox Text="{Binding PlanGoal, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60"/>
                                                </controls:FormField>

                                                <controls:FormField Label="PROPOSED STEPS">
                                                    <TextBox Text="{Binding PlanProposedSteps, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="120" FontFamily="Consolas" FontSize="12"/>
                                                </controls:FormField>

                                                <controls:FormField Label="AFFECTED FILES / CLASSES">
                                                    <TextBox Text="{Binding PlanAffectedContext, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="48"/>
                                                </controls:FormField>

                                                <controls:FormField Label="RISKS &amp; NOTES">
                                                    <TextBox Text="{Binding PlanRisksNotes, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="48"/>
                                                </controls:FormField>
                                            </StackPanel>
                                        </controls:SurfacePanel>

                                        <controls:EditorActionBar StatusText="{Binding PlanSaveStatus}">
                                            <controls:EditorActionBar.LeftActions>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Save Plan"
                                                            Command="{Binding SavePlanCommand}"
                                                            Style="{StaticResource IronDev.CommandButton.Primary}"
                                                            Margin="0,0,8,0"
                                                            AutomationProperties.AutomationId="ticket.plan.save"
                                                            IsEnabled="{Binding IsSavingPlan, Converter={StaticResource InverseBoolConverter}}"/>
                                                    <Button Content="Reset"
                                                            Command="{Binding CancelPlanEditCommand}"
                                                            Style="{StaticResource IronDev.CommandButton.Ghost}"
                                                            AutomationProperties.AutomationId="ticket.plan.reset"/>
                                                </StackPanel>
                                            </controls:EditorActionBar.LeftActions>
                                        </controls:EditorActionBar>
                                    </StackPanel>
                                </StackPanel>

                                <!-- TAB: Code Context -->
                                <StackPanel AutomationProperties.AutomationId="ticket.detail.context">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveTab}" Value="CodeContext">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <!-- Index status card -->
                                    <controls:SurfacePanel Variant="Subtle" Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="OPTIONAL BUILDER CONTEXT" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                                            <!-- Not-indexed warning -->
                                            <Border Visibility="{Binding IsContextLimited, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Background="{StaticResource Brush.Status.Warning.Background}" BorderBrush="{StaticResource Brush.Status.Warning.Border}" BorderThickness="1"
                                                    CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Project is not indexed"
                                                                   Foreground="{StaticResource Brush.Status.Warning.Foreground}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                                                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                                                   Foreground="{StaticResource Text/Muted}"
                                                                   Text="Code context may be incomplete. Index the project to enable code retrieval and improve AI output quality."/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                                        <Button Content="Index Project"
                                                                Command="{Binding RequestIndexCommand}"
                                                                Style="{StaticResource AppButton.Secondary}"
                                                                Padding="14,6" FontSize="12"
                                                                ToolTip="Run the local code indexer on this project"/>
                                                        <TextBlock Text="or continue without index"
                                                                   Foreground="{StaticResource Text/Muted}" FontSize="10"
                                                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <!-- Indexed OK state -->
                                            <Border Visibility="{Binding IsContextLimited, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                                    Background="{StaticResource Brush.Status.Ready.Background}" BorderBrush="{StaticResource Brush.Status.Ready.Border}" BorderThickness="1"
                                                    CornerRadius="6" Padding="12,8">
                                                <TextBlock Text="Project is indexed - code context is available"
                                                           Foreground="{StaticResource Brush.Status.Ready.Foreground}" FontSize="12" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </controls:SurfacePanel>

                                    <!-- File paths + symbols -->
                                    <controls:SurfacePanel Variant="Subtle" Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <controls:FormField Label="AFFECTED FILE PATHS">
                                                <Grid>
                                                    <TextBox Text="{Binding EditLinkedFilePaths, UpdateSourceTrigger=PropertyChanged}"
                                                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="56"
                                                             FontSize="11" FontFamily="Consolas"
                                                             ToolTip="One file path per line. Used by Build This for context retrieval."/>
                                                    <TextBlock Text="No affected files linked yet."
                                                               Foreground="{StaticResource Text/Muted}" FontSize="11" FontStyle="Italic"
                                                               VerticalAlignment="Top" Margin="6,6,0,0"
                                                               IsHitTestVisible="False">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding EditLinkedFilePaths, Converter={StaticResource ValueToVis}}" Value="Collapsed">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </controls:FormField>
                                            <controls:FormField Label="LINKED SYMBOLS / CLASSES">
                                                <Grid>
                                                    <TextBox Text="{Binding EditLinkedSymbols, UpdateSourceTrigger=PropertyChanged}"
                                                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40"
                                                             FontSize="11" FontFamily="Consolas"
                                                             ToolTip="Class names, method names, interfaces relevant to this ticket."/>
                                                    <TextBlock Text="No linked symbols or classes yet."
                                                               Foreground="{StaticResource Text/Muted}" FontSize="11" FontStyle="Italic"
                                                               VerticalAlignment="Top" Margin="6,6,0,0"
                                                               IsHitTestVisible="False">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding EditLinkedSymbols, Converter={StaticResource ValueToVis}}" Value="Collapsed">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </controls:FormField>
                                        </StackPanel>
                                    </controls:SurfacePanel>

                                    <!-- Builder context summary (populated after Build This) -->
                                    <controls:SurfacePanel Variant="Subtle" Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="BUILDER CONTEXT SUMMARY" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                                            <!-- Has preview -->
                                            <TextBlock Text="{Binding CurrentBuildPreview.ContextSummary}"
                                                       Foreground="{StaticResource Text/Muted}" FontSize="12"
                                                       TextWrapping="Wrap" FontStyle="Italic"
                                                       Visibility="{Binding HasBuildPreview, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <!-- No preview yet -->
                                            <TextBlock Foreground="{StaticResource Text/Muted}" FontSize="12" FontStyle="Italic"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding HasBuildPreview, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="No context summary yet. Run Build This to assemble code context."/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsContextLimited}" Value="True">
                                                                <Setter Property="Text" Value="No indexed snippets available. Index the project to enable code retrieval."/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </controls:SurfacePanel>
                                </StackPanel>

                                <!-- TAB: Tests -->
                                <!-- NOTE: Mapped to TechnicalNotes DB field (no schema change). -->
                                <!-- Structure is free-text with labelled sections as a convention. -->
                                <StackPanel AutomationProperties.AutomationId="ticket.detail.tests">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveTab}" Value="Tests">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <controls:SurfacePanel Variant="Subtle" Padding="24" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Tests &amp; Validation"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Text/Primary}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="Define how this ticket will be proven correct. The AI builder uses this section to know what tests to create or verify."
                                                       FontSize="11"
                                                       Foreground="{StaticResource Text/Secondary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,16"/>

                                            <!-- FIELD NOTE: Stored in TechnicalNotes column. -->
                                            <!-- Format convention: each section starts with a label line, e.g. "## Unit Tests" -->
                                            <controls:FormField Label="UNIT TESTS">
                                                <TextBox Text="{Binding EditTestsUnitTests, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80"
                                                         FontFamily="Consolas" FontSize="12"
                                                         ToolTip="Describe unit tests that must pass. One per line."/>
                                            </controls:FormField>

                                            <controls:FormField Label="INTEGRATION TESTS">
                                                <TextBox Text="{Binding EditTestsIntegrationTests, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60"
                                                         FontFamily="Consolas" FontSize="12"
                                                         ToolTip="Integration tests to verify end-to-end flows."/>
                                            </controls:FormField>

                                            <controls:FormField Label="UI / MANUAL TESTS">
                                                <TextBox Text="{Binding EditTestsManualTests, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60"
                                                         ToolTip="Manual or UI verification steps."/>
                                            </controls:FormField>

                                            <controls:FormField Label="REGRESSION TESTS">
                                                <TextBox Text="{Binding EditTestsRegressionTests, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="48"
                                                         ToolTip="Existing tests that must still pass after this change."/>
                                            </controls:FormField>

                                            <controls:FormField Label="BUILD VALIDATION">
                                                <TextBox Text="{Binding EditTestsBuildValidation, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="48"
                                                         ToolTip="Build checks, e.g. 'dotnet build must pass with 0 errors'."/>
                                            </controls:FormField>
                                        </StackPanel>
                                    </controls:SurfacePanel>

                                    <controls:EditorActionBar StatusText="{Binding SaveStatus}">
                                        <controls:EditorActionBar.LeftActions>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Save Tests"
                                                        Command="{Binding SaveTicketCommand}"
                                                        Style="{StaticResource AppButton.Primary}"
                                                        Margin="0,0,8,0"
                                                        IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"/>
                                                <Button Content="Cancel"
                                                        Command="{Binding CancelEditCommand}"
                                                        Style="{StaticResource AppButton.CompactGhost}"/>
                                            </StackPanel>
                                        </controls:EditorActionBar.LeftActions>
                                    </controls:EditorActionBar>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>

                        <!-- Selected Ticket Command Bar -->
                        <controls:EditorActionBar Grid.Row="3"
                                                  Visibility="{Binding IsDraftMode, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                                  Background="{StaticResource Background/Surface}"
                                                  SeparatorThickness="0,1,0,0"
                                                  BarPadding="16,12"
                                                  StatusText="{Binding SaveStatus}"
                                                  AutomationProperties.AutomationId="ticket.editor.commandBar">
                            <controls:EditorActionBar.LeftActions>
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding GenerateImplementationPlanCommand}"
                                            Style="{StaticResource IronDev.CommandButton.Secondary}"
                                            Margin="0,0,8,0"
                                            AutomationProperties.AutomationId="ticket.command.generatePlan"
                                            ToolTipService.ShowOnDisabled="True"
                                            ToolTip="Generate or refresh the implementation plan for this ticket.">
                                        <TextBlock Text="Generate Plan"/>
                                    </Button>
                                    <Button Command="{Binding BuildSelectedTicketProposalCommand}"
                                            Style="{StaticResource IronDev.CommandButton.Primary}"
                                            Margin="0,0,8,0"
                                            AutomationProperties.AutomationId="ticket.command.buildTicket"
                                            ToolTipService.ShowOnDisabled="True"
                                            ToolTip="Generate a build proposal. Disabled until the ticket is saved, ready, and backed by project context.">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Build Ticket"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsBuildingTicket}" Value="True">
                                                            <Setter Property="Text" Value="Building..."/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button>
                                    <Button Content="Review Context"
                                            Command="{Binding ReviewContextCommand}"
                                            Style="{StaticResource IronDev.CommandButton.Ghost}"
                                            AutomationProperties.AutomationId="ticket.command.reviewContext"
                                            ToolTip="Jump to the evidence and code context for this ticket."/>
                                </StackPanel>
                            </controls:EditorActionBar.LeftActions>
                            <controls:EditorActionBar.RightActions>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Save"
                                            Command="{Binding SaveTicketCommand}"
                                            Style="{StaticResource IronDev.CommandButton.Primary}"
                                            Margin="0,0,8,0"
                                            AutomationProperties.AutomationId="ticket.command.save"
                                            ToolTipService.ShowOnDisabled="True"
                                            ToolTip="Save ticket changes. Disabled until there are unsaved edits and the ticket has a title."/>
                                    <Button Content="Cancel"
                                            Command="{Binding CancelEditCommand}"
                                            Style="{StaticResource IronDev.CommandButton.Ghost}"
                                            Margin="0,0,8,0"
                                            AutomationProperties.AutomationId="ticket.command.cancel"
                                            ToolTip="Cancel ticket editing and reload the selected ticket."/>
                                    <Button Content="Copy"
                                            Command="{Binding CopySelectedTicketCommand}"
                                            Style="{StaticResource IronDev.CommandButton.Ghost}"
                                            Margin="0,0,12,0"
                                            AutomationProperties.AutomationId="ticket.command.copy"
                                            ToolTip="Copy this ticket as Markdown."/>
                                    <Border Width="1"
                                            Height="24"
                                            Background="{StaticResource Border/Subtle}"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Center"/>
                                    <Button Content="Archive"
                                            Command="{Binding ArchiveSelectedTicketCommand}"
                                            Style="{StaticResource IronDev.CommandButton.Ghost}"
                                            AutomationProperties.AutomationId="ticket.command.archive"
                                            ToolTipService.ShowOnDisabled="True"
                                            ToolTip="Archive this ticket after confirmation."/>
                                </StackPanel>
                            </controls:EditorActionBar.RightActions>
                        </controls:EditorActionBar>

                        <!-- Draft Action Bar -->
                        <controls:EditorActionBar Grid.Row="3"
                                                  Visibility="{Binding IsDraftMode, Converter={StaticResource BoolToVisibilityConverter}}"
                                                  Background="{StaticResource Background/Surface}"
                                                  SeparatorThickness="0,1,0,0"
                                                  BarPadding="16,12"
                                                  StatusText="{Binding SaveStatus}"
                                                  AutomationProperties.AutomationId="ticket.draft.commandBar">
                            <controls:EditorActionBar.LeftActions>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Regenerate All"
                                            Command="{Binding RegenerateAllCommand}"
                                            Style="{StaticResource IronDev.CommandButton.Ghost}"
                                            IsEnabled="{Binding IsDraftGenerating, Converter={StaticResource InverseBoolConverter}}"
                                            Margin="0,0,6,0"
                                            AutomationProperties.AutomationId="ticket.draft.regenerateAll"
                                            ToolTip="Re-generate all draft fields from the original chat context"/>
                                    <Button Content="Regenerate Tests"
                                            Command="{Binding RegenerateTestsCommand}"
                                            Style="{StaticResource IronDev.CommandButton.Ghost}"
                                            IsEnabled="{Binding IsDraftGenerating, Converter={StaticResource InverseBoolConverter}}"
                                            AutomationProperties.AutomationId="ticket.draft.regenerateTests"
                                            ToolTip="Re-generate only the Tests / Validation fields"/>
                                </StackPanel>
                            </controls:EditorActionBar.LeftActions>
                            <controls:EditorActionBar.RightActions>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Cancel"
                                            Command="{Binding CancelDraftCommand}"
                                            Style="{StaticResource IronDev.CommandButton.Ghost}"
                                            Margin="0,0,8,0"
                                            AutomationProperties.AutomationId="ticket.draft.cancel"
                                            ToolTip="Discard draft and return to Chat"/>
                                     <Button Content="Save Ticket"
                                             Command="{Binding ApproveDraftCommand}"
                                             Style="{StaticResource IronDev.CommandButton.Primary}"
                                             IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"
                                             Margin="0,0,6,0"
                                             AutomationProperties.AutomationId="ticket.draft.save"
                                             ToolTip="Save this ticket to the database"/>
                                     <Button Content="Save All Drafts"
                                             Command="{Binding SaveAllDraftsCommand}"
                                             Style="{StaticResource IronDev.CommandButton.Ghost}"
                                             IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"
                                             Margin="0,0,6,0"
                                             AutomationProperties.AutomationId="ticket.draft.saveAll"
                                             ToolTip="Save all generated draft tickets in the review queue"/>
                                     <Button Content="Save Ticket + Plan"
                                             Command="{Binding ApproveDraftWithPlanCommand}"
                                             Style="{StaticResource IronDev.CommandButton.Ghost}"
                                            IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"
                                            AutomationProperties.AutomationId="ticket.draft.saveWithPlan"
                                            ToolTip="Save ticket and navigate to Plans to create an implementation plan"/>
                                </StackPanel>
                            </controls:EditorActionBar.RightActions>
                        </controls:EditorActionBar>
                    </Grid>

                        <!-- BUILD PREVIEW PANEL -->
                        <controls:SurfacePanel
                            Grid.Row="3"
                            Variant="Subtle"
                            Margin="0,12,0,0"
                            Padding="0"
                            AutomationProperties.AutomationId="ticket.detail.build"
                            Visibility="{Binding HasBuildPreview, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Margin="20,16,20,16">

                                <!-- Panel header -->
                                <TextBlock Text="BUILD PREVIEW" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,10"/>

                                <!-- Ticket name -->
                                <TextBlock Text="{Binding CurrentBuildPreview.TicketTitle, FallbackValue='Ticket'}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource Text/Primary}" Margin="0,0,0,6"/>

                                <!-- Context summary (Phase 2) -->
                                <TextBlock Text="CONTEXT" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CurrentBuildPreview.ContextSummary, FallbackValue=''}"
                                           Foreground="{StaticResource Text/Muted}" FontSize="11"
                                           TextWrapping="Wrap" FontStyle="Italic" Margin="0,0,0,10"/>

                                <!-- Summary -->
                                <TextBlock Text="PROPOSAL" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CurrentBuildPreview.Proposal.Summary, FallbackValue=''}"
                                           Foreground="{StaticResource Text/Primary}" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <!-- Files to change -->
                                <TextBlock Text="FILES TO CHANGE" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                <ItemsControl ItemsSource="{Binding CurrentBuildPreview.Proposal.FileChanges}"
                                              Margin="0,0,0,10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Foreground="{StaticResource Text/Muted}"
                                                       FontSize="11" FontFamily="Consolas">
                                                <Run Text="- "/><Run Text="{Binding FilePath}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Risk -->
                                <TextBlock Text="RISK" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CurrentBuildPreview.Proposal.RiskNotes, FallbackValue=''}"
                                           Foreground="{StaticResource Text/Muted}" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <!-- Test plan -->
                                <TextBlock Text="TEST PLAN" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CurrentBuildPreview.Proposal.TestPlan, FallbackValue=''}"
                                           Foreground="{StaticResource Text/Muted}" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <!-- Per-file diff view -->
                                <TextBlock Text="CHANGES" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                <ItemsControl ItemsSource="{Binding CurrentBuildPreview.Proposal.FileChanges}"
                                              Margin="0,0,0,10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Expander Margin="0,0,0,6"
                                                      Foreground="{StaticResource Text/Muted}">
                                                <Expander.Header>
                                                    <TextBlock FontFamily="Consolas" FontSize="11"
                                                               Foreground="{StaticResource Text/Primary}">
                                                        <Run Text="> "/><Run Text="{Binding FilePath}"/>
                                                    </TextBlock>
                                                </Expander.Header>
                                                <StackPanel Margin="12,6,0,0">
                                                    <!-- Change reason -->
                                                    <TextBlock Text="{Binding ChangeReason}"
                                                               Foreground="{StaticResource Text/Muted}"
                                                               FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                    <!-- Patch / Before+After -->
                                                    <TextBox IsReadOnly="True"
                                                             FontFamily="Consolas" FontSize="11"
                                                             Background="{StaticResource Background/App}"
                                                             Foreground="{StaticResource Text/Primary}"
                                                             BorderThickness="0"
                                                             TextWrapping="NoWrap" MinHeight="60" MaxHeight="280"
                                                             HorizontalScrollBarVisibility="Auto"
                                                             VerticalScrollBarVisibility="Auto">
                                                        <TextBox.Text>
                                                            <MultiBinding StringFormat="{}--- BEFORE ---{0}{1}{0}{0}+++ AFTER ---{0}{2}{0}{0}--- PATCH ---{0}{3}">
                                                                <Binding Source="&#10;"/>
                                                                <Binding Path="BeforeSnippet" FallbackValue="(none)"/>
                                                                <Binding Path="AfterSnippet"  FallbackValue="(none)"/>
                                                                <Binding Path="Patch"          FallbackValue="(no patch)"/>
                                                            </MultiBinding>
                                                        </TextBox.Text>
                                                    </TextBox>
                                                </StackPanel>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Build status -->
                                <TextBlock Text="{Binding BuildStatusMessage}"
                                           Foreground="{StaticResource Text/Muted}" FontSize="11"
                                           FontStyle="Italic" Margin="0,0,0,10"
                                           Visibility="{Binding BuildStatusMessage, Converter={StaticResource ValueToVis}}"/>

                                <!-- Actions -->
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Apply Changes"
                                            Command="{Binding ApplyBuildPreviewCommand}"
                                            Style="{StaticResource AppButton.Primary}"
                                            Padding="20,8" Margin="0,0,8,0"
                                            IsEnabled="False"
                                            ToolTip="Apply not available in Phase 3 - patch execution required (Phase 4)"/>
                                    <Button Content="Cancel"
                                            Command="{Binding CancelBuildPreviewCommand}"
                                            Style="{StaticResource AppButton.Ghost}"
                                            Padding="14,8"/>
                                </StackPanel>

                            </StackPanel>
                        </controls:SurfacePanel>

                </Grid>
            </controls:SurfacePanel>

            <!-- RIGHT: Context Inspector -->
            <controls:SurfacePanel Grid.Column="2"
                                   Variant="Subtle"
                                   Padding="0"
                                   AutomationProperties.AutomationId="ticket.inspector">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="16,18,16,12"
                            BorderBrush="{StaticResource Border/Subtle}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="CONTEXT INSPECTOR" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                            <TextBlock Text="Evidence, readiness, and linked project context"
                                       Foreground="{StaticResource Text/Secondary}"
                                       FontSize="{StaticResource IronDev.Font.Size.Body}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="14">
                        <StackPanel>
                            <Border AutomationProperties.AutomationId="ticket.inspector.evidence"
                                    Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                    BorderBrush="{StaticResource Border/Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="Evidence" Style="{StaticResource Typography.Eyebrow}" DockPanel.Dock="Left"/>
                                        <controls:StatusBadge DockPanel.Dock="Right"
                                                              Text="{Binding BuildReadinessBadgeText}"
                                                              Status="{Binding BuildReadinessBadgeStatus}"
                                                              Visibility="{Binding ShowBuildReadiness, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </DockPanel>
                                    <TextBlock Text="{Binding BuildReadinessMessage, FallbackValue='Select a ticket to inspect readiness.'}"
                                               Foreground="{StaticResource Text/Primary}"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding BuildReadinessDetails}"
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"
                                               Visibility="{Binding BuildReadinessDetails, Converter={StaticResource ValueToVis}}"/>
                                    <TextBlock Text="{Binding SaveStatus}"
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"
                                               Visibility="{Binding SaveStatus, Converter={StaticResource ValueToVis}}"/>
                                </StackPanel>
                            </Border>

                            <Border AutomationProperties.AutomationId="ticket.inspector.linkedDocuments"
                                    Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                    BorderBrush="{StaticResource Border/Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Linked documents" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                                    <TextBlock Text="No linked documents attached to this ticket yet."
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border AutomationProperties.AutomationId="ticket.inspector.decisions"
                                    Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                    BorderBrush="{StaticResource Border/Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Related decisions" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding PlanRisksNotes}"
                                               Foreground="{StaticResource Text/Secondary}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding PlanRisksNotes, Converter={StaticResource ValueToVis}}"/>
                                    <TextBlock Text="No decision notes captured for this ticket."
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="12"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PlanRisksNotes, Converter={StaticResource ValueToVis}}" Value="Collapsed">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border AutomationProperties.AutomationId="ticket.inspector.affectedFiles"
                                    Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                    BorderBrush="{StaticResource Border/Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Affected files" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding EditLinkedFilePaths}"
                                               Foreground="{StaticResource Text/Secondary}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding EditLinkedFilePaths, Converter={StaticResource ValueToVis}}"/>
                                    <TextBlock Text="No affected files linked yet."
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="12"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EditLinkedFilePaths, Converter={StaticResource ValueToVis}}" Value="Collapsed">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border AutomationProperties.AutomationId="ticket.inspector.affectedSymbols"
                                    Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                    BorderBrush="{StaticResource Border/Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Affected symbols" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding EditLinkedSymbols}"
                                               Foreground="{StaticResource Text/Secondary}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding EditLinkedSymbols, Converter={StaticResource ValueToVis}}"/>
                                    <TextBlock Text="No symbols linked yet."
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="12"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EditLinkedSymbols, Converter={StaticResource ValueToVis}}" Value="Collapsed">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border AutomationProperties.AutomationId="ticket.inspector.buildReadiness"
                                    Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                    BorderBrush="{StaticResource Border/Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Build readiness" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding BuildReadinessTitle}"
                                               Foreground="{StaticResource Text/Primary}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding BuildReadinessActionText}"
                                               Foreground="{StaticResource Brush.Status.Warning.Foreground}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"
                                               Visibility="{Binding BuildReadinessActionText, Converter={StaticResource ValueToVis}}"/>
                                    <TextBlock Text="{Binding BuildStatusMessage}"
                                               Foreground="{StaticResource Text/Muted}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"
                                               Visibility="{Binding BuildStatusMessage, Converter={StaticResource ValueToVis}}"/>
                                </StackPanel>
                            </Border>

                            <Border AutomationProperties.AutomationId="ticket.inspector.risks"
                                    Background="{StaticResource IronDev.Brush.Surface.Interactive}"
                                    BorderBrush="{StaticResource Border/Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource IronDev.Radius.Medium}"
                                    Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Risks / warnings" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                                    <TextBlock Foreground="{StaticResource Text/Muted}"
                                               FontSize="12"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="No active warnings."/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsContextLimited}" Value="True">
                                                        <Setter Property="Text" Value="Project context is limited. Index before trusting generated build output."/>
                                                        <Setter Property="Foreground" Value="{StaticResource Brush.Status.Warning.Foreground}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </controls:SurfacePanel>
        </Grid>
    </Grid>
</UserControl>
