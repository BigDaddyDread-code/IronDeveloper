<UserControl x:Class="IronDev.Agent.Views.Workspaces.TicketsWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TicketsWorkspaceViewModel, IsDesignTimeCreatable=False}">

    <Grid Background="{StaticResource AppBackgroundBrush}" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="WORKSPACE" Style="{StaticResource IronEyebrow}"/>
            <TextBlock Text="Tickets" Style="{StaticResource IronSectionTitle}"/>
        </StackPanel>

        <!-- Ticket list -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Tickets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource IronCard}" Margin="0,0,0,8" Padding="20,14"
                                Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Border Style="{StaticResource IronStatusBadge}" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Type}" FontSize="11"
                                                       Foreground="{StaticResource StatusInfoBrush}"/>
                                        </Border>
                                        <Border Style="{StaticResource IronStatusBadge}" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Priority}" FontSize="11"
                                                       Foreground="{StaticResource StatusWarningBrush}"/>
                                        </Border>
                                        <Border Style="{StaticResource IronStatusBadge}">
                                            <TextBlock Text="{Binding Status}" FontSize="11"
                                                       Foreground="{StaticResource StatusReadyBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CreatedDate, StringFormat=d MMM yyyy}"
                                           Style="{StaticResource IronMetaLabel}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
