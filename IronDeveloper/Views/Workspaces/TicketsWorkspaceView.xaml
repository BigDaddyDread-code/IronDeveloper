<UserControl x:Class="IronDev.Agent.Views.Workspaces.TicketsWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             xmlns:controls="http://schemas.irondeveloper.com/controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TicketsWorkspaceViewModel, IsDesignTimeCreatable=False}">

    <Grid Background="{StaticResource Background/App}" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="WORKFLOW" Style="{StaticResource Typography.Eyebrow}"/>
                <TextBlock Text="Ticket Management" Style="{StaticResource Typography.ScreenTitle}"/>
            </StackPanel>
            <Button Grid.Column="1" Content="＋ New Ticket"
                    Command="{Binding NewTicketCommand}"
                    Style="{StaticResource AppButton.Primary}"
                    Padding="20,8" VerticalAlignment="Center"/>
        </Grid>

        <!-- Master-Detail -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT: Ticket List ═══ -->
            <controls:WorkspaceListPane Grid.Column="0" Title="PROJECT TICKETS" Margin="0,0,16,0"
                                        ItemsSource="{Binding Tickets}"
                                        SelectedItem="{Binding SelectedTicket, Mode=TwoWay}">
                <controls:WorkspaceListPane.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10,8" CornerRadius="6" Margin="0,1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource Background/Interactive}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource Text/Primary}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Summary}" FontSize="11"
                                               Foreground="{StaticResource Text/Muted}"
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"
                                               Visibility="{Binding Summary, Converter={StaticResource ValueToVis}}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="6,0,0,0">
                                    <TextBlock Text="{Binding Status}" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{StaticResource Text/Muted}" Opacity="0.8"/>
                                    <TextBlock Text="{Binding Priority}" FontSize="9"
                                               Foreground="{StaticResource Text/Muted}" Opacity="0.6"
                                               Margin="0,1,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </controls:WorkspaceListPane.ItemTemplate>
            </controls:WorkspaceListPane>

            <!-- ═══ RIGHT: Detail/Editor ═══ -->
            <Border Grid.Column="1"
                    Background="{StaticResource Background/Panel}"
                    BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1"
                    CornerRadius="10" Padding="0">
                <Grid>
                    <controls:EmptyResultsState Title="No Ticket Selected" 
                                               Description="Select a ticket from the list or create a new one with IronDev Architect to begin.">
                        <controls:EmptyResultsState.Style>
                            <Style TargetType="controls:EmptyResultsState">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding HasDetail}" Value="False"/>
                                            <Condition Binding="{Binding DraftPreflight, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=None}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </controls:EmptyResultsState.Style>
                    </controls:EmptyResultsState>

                    <!-- ══ PREFLIGHT: Index Choice Panel ══ -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DraftPreflight, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=NeedsChoice}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DraftPreflight, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=ReadyToGenerate}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <controls:SurfacePanel Variant="Subtle" Padding="40" Margin="48"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                               MaxWidth="520">
                            <StackPanel>
                                <TextBlock Text="⚠ Project Not Indexed"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="#F59E0B"
                                           Margin="0,0,0,8"/>
                                <TextBlock TextWrapping="Wrap" FontSize="13"
                                           Foreground="{StaticResource Text/Secondary}"
                                           Margin="0,0,0,20">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"
                                                    Value="This project is not indexed. AI context may be incomplete, reducing draft quality.&#x0a;&#x0a;What would you like to do?"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DraftPreflight, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=ReadyToGenerate}" Value="True">
                                                    <Setter Property="Text"
                                                            Value="✓ Project indexed successfully. The draft will now use full code context."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <StackPanel Orientation="Vertical" Margin="0,0,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DraftPreflight, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=ReadyToGenerate}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Button Content="🗂 Index Project First"
                                            Command="{Binding PreflightIndexProjectCommand}"
                                            Style="{StaticResource AppButton.Primary}"
                                            Padding="20,10" Margin="0,0,0,8"
                                            HorizontalAlignment="Stretch"
                                            ToolTip="Run the local code indexer, then generate the draft with full context"/>
                                    <Button Content="⚡ Continue Without Index"
                                            Command="{Binding PreflightContinueCommand}"
                                            Style="{StaticResource AppButton.Secondary}"
                                            Padding="20,10" Margin="0,0,0,8"
                                            HorizontalAlignment="Stretch"
                                            ToolTip="Generate draft now using limited context (no code snippets)"/>
                                    <Button Content="✕ Cancel"
                                            Command="{Binding PreflightCancelCommand}"
                                            Style="{StaticResource AppButton.Ghost}"
                                            Padding="20,8"
                                            HorizontalAlignment="Stretch"
                                            ToolTip="Discard and return to Chat"/>
                                </StackPanel>

                                <Button Content="✓ Generate Draft"
                                        Command="{Binding PreflightGenerateCommand}"
                                        Padding="20,10"
                                        HorizontalAlignment="Stretch"
                                        ToolTip="Generate the draft ticket with indexed code context">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource AppButton.Primary}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DraftPreflight, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=ReadyToGenerate}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </controls:SurfacePanel>
                    </Grid>

                    <Grid Visibility="{Binding HasDetail, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- 0: draft banner -->
                            <RowDefinition Height="Auto"/>  <!-- 1: tab header -->
                            <RowDefinition Height="*"/>     <!-- 2: content -->
                            <RowDefinition Height="Auto"/>  <!-- 3: footer -->
                        </Grid.RowDefinitions>

                        <!-- ══ Draft Banner: compact single row ══ -->
                        <Border Grid.Row="0"
                                Visibility="{Binding IsDraftMode, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="#1A7C6BE8" BorderBrush="#7C6BE8" BorderThickness="0,0,0,1"
                                Padding="16,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Icon + label -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="✦" Foreground="#7C6BE8" FontSize="13" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <TextBlock Text="Draft Ticket — review before saving"
                                               Foreground="#7C6BE8" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Generating / status -->
                                <TextBlock Grid.Column="1"
                                           Foreground="{StaticResource Text/Muted}" FontSize="11" VerticalAlignment="Center" Margin="12,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding DraftStatusMessage}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDraftGenerating}" Value="True">
                                                    <Setter Property="Text" Value="⟳ Generating…"/>
                                                    <Setter Property="FontStyle" Value="Italic"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!-- Limited context inline chip -->
                                <Border Grid.Column="2"
                                        Visibility="{Binding IsContextLimited, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Background="#18F59E0B" BorderBrush="#F59E0B" BorderThickness="1"
                                        CornerRadius="3" Padding="7,2" Margin="0,0,8,0"
                                        ToolTip="Project not indexed — see Code Context tab">
                                    <TextBlock Text="⚠ Limited context" Foreground="#F59E0B" FontSize="10" FontWeight="SemiBold"/>
                                </Border>
                                <!-- AI badge -->
                                <Border Grid.Column="3" Background="#7C6BE8" CornerRadius="3" Padding="7,2">
                                    <TextBlock Text="AI GENERATED" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Tab Header (shifted to row 1 when draft banner shown) -->
                        <Border Grid.Row="1" BorderBrush="{StaticResource Border/Subtle}" BorderThickness="0,0,0,1" Padding="16,0">
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Resources>
                                    <Style x:Key="TicketTabStyle" TargetType="RadioButton">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="16,10"/>
                                        <Setter Property="Margin" Value="0,0,8,0"/>
                                        <Setter Property="Foreground" Value="{StaticResource Text/Muted}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="RadioButton">
                                                    <Border x:Name="border" Background="Transparent" 
                                                            BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource Text/Primary}"/>
                                                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Accent/Primary}"/>
                                                            <Setter TargetName="border" Property="Background" Value="{StaticResource Background/Interactive}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{StaticResource Background/Interactive}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </StackPanel.Resources>
                                
                                <RadioButton Content="Overview" IsChecked="{Binding ActiveTab, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Overview, Mode=TwoWay}"
                                           Style="{StaticResource TicketTabStyle}"/>
                                <RadioButton Content="Implementation Plan" IsChecked="{Binding ActiveTab, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=ImplementationPlan, Mode=TwoWay}"
                                           Style="{StaticResource TicketTabStyle}"/>
                                <RadioButton Content="Code Context" IsChecked="{Binding ActiveTab, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=CodeContext, Mode=TwoWay}"
                                           Style="{StaticResource TicketTabStyle}"/>
                                <RadioButton Content="Tests" IsChecked="{Binding ActiveTab, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Tests, Mode=TwoWay}"
                                           Style="{StaticResource TicketTabStyle}"/>
                            </StackPanel>
                        </Border>

                        <!-- Content Area -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="16">
                            <Grid>
                                <!-- ═══ TAB: Overview ═══ -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveTab}" Value="Overview">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    
                                    <controls:SurfacePanel Variant="Subtle" Padding="24" Margin="0,0,0,16">
                                        <StackPanel>
                                            <controls:FormField Label="TICKET TITLE">
                                                <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}" FontSize="16" FontWeight="SemiBold"/>
                                            </controls:FormField>

                                            <!-- Status / Priority / Type: fixed-width columns so values never clip -->
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/><!-- absorbs remaining space -->
                                                </Grid.ColumnDefinitions>

                                                <controls:SelectionField Grid.Column="0" Label="STATUS"
                                                                       MinWidth="145" Margin="0,0,12,0"
                                                                       FocusVisualStyle="{x:Null}"
                                                                       ItemsSource="{Binding StatusOptions}"
                                                                       SelectedItem="{Binding EditStatus}"/>

                                                <controls:SelectionField Grid.Column="1" Label="PRIORITY"
                                                                       MinWidth="145" Margin="0,0,12,0"
                                                                       FocusVisualStyle="{x:Null}"
                                                                       ItemsSource="{Binding PriorityOptions}"
                                                                       SelectedItem="{Binding EditPriority}"/>

                                                <controls:SelectionField Grid.Column="2" Label="TYPE"
                                                                       MinWidth="145"
                                                                       FocusVisualStyle="{x:Null}"
                                                                       ItemsSource="{Binding TypeOptions}"
                                                                       SelectedItem="{Binding EditTicketType}"/>
                                            </Grid>

                                            <controls:FormField Label="SUMMARY">
                                                <TextBox Text="{Binding EditSummary, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60"/>
                                            </controls:FormField>

                                            <controls:FormField Label="ACCEPTANCE CRITERIA">
                                                <TextBox Text="{Binding EditAcceptanceCriteria, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60"/>
                                            </controls:FormField>
                                        </StackPanel>
                                    </controls:SurfacePanel>
                                             
                                    <Grid Margin="0,8,0,0"
                                          Visibility="{Binding IsDraftMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" Content="Save Ticket"
                                                Command="{Binding SaveTicketCommand}"
                                                Style="{StaticResource AppButton.Primary}"
                                                Padding="24,8" Margin="0,0,8,0"
                                                IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"/>
                                        <Button Grid.Column="1" Content="Cancel"
                                                Command="{Binding CancelEditCommand}"
                                                Style="{StaticResource AppButton.Secondary}"
                                                Padding="16,8" Margin="0,0,8,0"/>

                                        <!-- Build This -->
                                        <Button Grid.Column="2" Content="⚙ Build This"
                                                Command="{Binding BuildSelectedTicketCommand}"
                                                Style="{StaticResource AppButton.Secondary}"
                                                IsEnabled="{Binding CanBuildTicket}"
                                                Padding="16,8" Margin="0,0,8,0"
                                                ToolTip="Generate a code change proposal for this ticket"/>

                                        <TextBlock Grid.Column="4" Text="{Binding SaveStatus}"
                                                   Foreground="{StaticResource Success}"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                    </Grid>
                                </StackPanel>

                                <!-- ═══ TAB: Plan ═══ -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveTab}" Value="ImplementationPlan">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    
                                    <!-- No plan yet -->
                                    <controls:SurfacePanel Visibility="{Binding HasPlan, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                                          Variant="Subtle" Padding="48" Margin="0,0,0,16">
                                        <StackPanel HorizontalAlignment="Center">
                                            <controls:EmptyResultsState Title="No Implementation Plan" 
                                                                       Description="Create a plan to outline the technical steps for this ticket."/>
                                            <Button Content="＋ Create Implementation Plan"
                                                    Command="{Binding CreatePlanCommand}"
                                                    Style="{StaticResource AppButton.Primary}"
                                                    Padding="20,10" Margin="0,24,0,0"/>
                                        </StackPanel>
                                    </controls:SurfacePanel>

                                    <!-- Plan Editor -->
                                    <StackPanel Visibility="{Binding HasPlan, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <controls:SurfacePanel Variant="Subtle" Padding="24" Margin="0,0,0,16">
                                            <StackPanel>
                                                <!-- Plan Title: full width, no floating button beside it -->
                                                <controls:FormField Label="PLAN TITLE" Margin="0,0,0,8">
                                                    <TextBox Text="{Binding PlanTitle, UpdateSourceTrigger=PropertyChanged}" FontSize="14" FontWeight="SemiBold"/>
                                                </controls:FormField>

                                                <!-- Ask about this plan: secondary action row, sits below title -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16" HorizontalAlignment="Left">
                                                    <Button Content="💬 Ask about this plan"
                                                            Command="{Binding AskAboutPlanCommand}"
                                                            Style="{StaticResource AppButton.Ghost}"
                                                            Padding="12,5"/>
                                                </StackPanel>

                                                <controls:FormField Label="PLAN GOAL">
                                                    <TextBox Text="{Binding PlanGoal, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60"/>
                                                </controls:FormField>

                                                <controls:FormField Label="PROPOSED STEPS">
                                                    <TextBox Text="{Binding PlanProposedSteps, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="120" FontFamily="Consolas" FontSize="12"/>
                                                </controls:FormField>

                                                <controls:FormField Label="AFFECTED FILES / CLASSES">
                                                    <TextBox Text="{Binding PlanAffectedContext, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="48"/>
                                                </controls:FormField>

                                                <controls:FormField Label="RISKS &amp; NOTES">
                                                    <TextBox Text="{Binding PlanRisksNotes, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="48"/>
                                                </controls:FormField>
                                            </StackPanel>
                                        </controls:SurfacePanel>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="Save Plan"
                                                    Command="{Binding SavePlanCommand}"
                                                    Style="{StaticResource AppButton.Primary}"
                                                    Padding="24,8" Margin="0,0,8,0"
                                                    IsEnabled="{Binding IsSavingPlan, Converter={StaticResource InverseBoolConverter}}"/>
                                            <Button Grid.Column="1" Content="Reset"
                                                    Command="{Binding CancelPlanEditCommand}"
                                                    Style="{StaticResource AppButton.Secondary}"
                                                    Padding="16,8"/>
                                            <TextBlock Grid.Column="3" Text="{Binding PlanSaveStatus}"
                                                       Foreground="{StaticResource Success}"
                                                       VerticalAlignment="Center" FontSize="12"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>

                                <!-- ═══ TAB: Code Context ═══ -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveTab}" Value="CodeContext">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <!-- Index status card -->
                                    <controls:SurfacePanel Variant="Subtle" Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <!-- Not-indexed warning -->
                                            <Border Visibility="{Binding IsContextLimited, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Background="#18F59E0B" BorderBrush="#F59E0B" BorderThickness="1"
                                                    CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="⚠️ Project is not indexed"
                                                                   Foreground="#F59E0B" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                                                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                                                   Foreground="{StaticResource Text/Muted}"
                                                                   Text="Code context may be incomplete. Index the project to enable code retrieval and improve AI output quality."/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                                        <Button Content="🗂 Index Project"
                                                                Command="{Binding RequestIndexCommand}"
                                                                Style="{StaticResource AppButton.Secondary}"
                                                                Padding="14,6" FontSize="12"
                                                                ToolTip="Run the local code indexer on this project"/>
                                                        <TextBlock Text="or continue without index"
                                                                   Foreground="{StaticResource Text/Muted}" FontSize="10"
                                                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <!-- Indexed OK state -->
                                            <Border Visibility="{Binding IsContextLimited, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                                    Background="#1234D16A" BorderBrush="#34D16A" BorderThickness="1"
                                                    CornerRadius="6" Padding="12,8">
                                                <TextBlock Text="✓ Project is indexed — code context is available"
                                                           Foreground="#34D16A" FontSize="12" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </controls:SurfacePanel>

                                    <!-- File paths + symbols -->
                                    <controls:SurfacePanel Variant="Subtle" Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <controls:FormField Label="AFFECTED FILE PATHS">
                                                <TextBox Text="{Binding EditLinkedFilePaths, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="56"
                                                         FontSize="11" FontFamily="Consolas"
                                                         ToolTip="One file path per line. Used by Build This for context retrieval."/>
                                            </controls:FormField>
                                            <controls:FormField Label="LINKED SYMBOLS / CLASSES">
                                                <TextBox Text="{Binding EditLinkedSymbols, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40"
                                                         FontSize="11" FontFamily="Consolas"
                                                         ToolTip="Class names, method names, interfaces relevant to this ticket."/>
                                            </controls:FormField>
                                        </StackPanel>
                                    </controls:SurfacePanel>

                                    <!-- Builder context summary (populated after Build This) -->
                                    <controls:SurfacePanel Variant="Subtle" Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="BUILDER CONTEXT SUMMARY" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                                            <!-- Has preview -->
                                            <TextBlock Text="{Binding CurrentBuildPreview.ContextSummary}"
                                                       Foreground="{StaticResource Text/Muted}" FontSize="12"
                                                       TextWrapping="Wrap" FontStyle="Italic"
                                                       Visibility="{Binding HasBuildPreview, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <!-- No preview yet -->
                                            <TextBlock Foreground="{StaticResource Text/Muted}" FontSize="12" FontStyle="Italic"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding HasBuildPreview, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="No context summary yet. Run ⚙ Build This to assemble code context."/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsContextLimited}" Value="True">
                                                                <Setter Property="Text" Value="No indexed snippets available. Index the project to enable code retrieval."/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </controls:SurfacePanel>
                                </StackPanel>

                                <!-- ═══ TAB: Tests ═══ -->
                                <!-- NOTE: Mapped to TechnicalNotes DB field (no schema change). -->
                                <!-- Structure is free-text with labelled sections as a convention. -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveTab}" Value="Tests">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <controls:SurfacePanel Variant="Subtle" Padding="24" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Tests &amp; Validation"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Text/Primary}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="Define how this ticket will be proven correct. The AI builder uses this section to know what tests to create or verify."
                                                       FontSize="11"
                                                       Foreground="{StaticResource Text/Secondary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,16"/>

                                            <!-- FIELD NOTE: Stored in TechnicalNotes column. -->
                                            <!-- Format convention: each section starts with a label line, e.g. "## Unit Tests" -->
                                            <controls:FormField Label="UNIT TESTS">
                                                <TextBox Text="{Binding EditTestsUnitTests, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80"
                                                         FontFamily="Consolas" FontSize="12"
                                                         ToolTip="Describe unit tests that must pass. One per line."/>
                                            </controls:FormField>

                                            <controls:FormField Label="INTEGRATION TESTS">
                                                <TextBox Text="{Binding EditTestsIntegrationTests, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60"
                                                         FontFamily="Consolas" FontSize="12"
                                                         ToolTip="Integration tests to verify end-to-end flows."/>
                                            </controls:FormField>

                                            <controls:FormField Label="UI / MANUAL TESTS">
                                                <TextBox Text="{Binding EditTestsManualTests, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60"
                                                         ToolTip="Manual or UI verification steps."/>
                                            </controls:FormField>

                                            <controls:FormField Label="REGRESSION TESTS">
                                                <TextBox Text="{Binding EditTestsRegressionTests, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="48"
                                                         ToolTip="Existing tests that must still pass after this change."/>
                                            </controls:FormField>

                                            <controls:FormField Label="BUILD VALIDATION">
                                                <TextBox Text="{Binding EditTestsBuildValidation, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="48"
                                                         ToolTip="Build checks, e.g. 'dotnet build must pass with 0 errors'."/>
                                            </controls:FormField>
                                        </StackPanel>
                                    </controls:SurfacePanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Save Tests"
                                                Command="{Binding SaveTicketCommand}"
                                                Style="{StaticResource AppButton.Primary}"
                                                Padding="24,8" Margin="0,0,8,0"
                                                IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"/>
                                        <Button Grid.Column="1" Content="Cancel"
                                                Command="{Binding CancelEditCommand}"
                                                Style="{StaticResource AppButton.Secondary}"
                                                Padding="16,8"/>
                                        <TextBlock Grid.Column="3" Text="{Binding SaveStatus}"
                                                   Foreground="{StaticResource Success}"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>

                        <!-- ══ Draft Action Bar (Grid.Row 3, visible only in IsDraftMode) ══ -->
                        <Border Grid.Row="3"
                                Visibility="{Binding IsDraftMode, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="{StaticResource Background/Surface}"
                                BorderBrush="{StaticResource Border/Subtle}"
                                BorderThickness="0,1,0,0"
                                Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Regenerate buttons -->
                                <Button Grid.Column="0" Content="↺ Regenerate All"
                                        Command="{Binding RegenerateAllCommand}"
                                        Style="{StaticResource AppButton.Ghost}"
                                        IsEnabled="{Binding IsDraftGenerating, Converter={StaticResource InverseBoolConverter}}"
                                        Padding="14,7" Margin="0,0,6,0"
                                        ToolTip="Re-generate all draft fields from the original chat context"/>
                                <Button Grid.Column="1" Content="↺ Regenerate Tests"
                                        Command="{Binding RegenerateTestsCommand}"
                                        Style="{StaticResource AppButton.Ghost}"
                                        IsEnabled="{Binding IsDraftGenerating, Converter={StaticResource InverseBoolConverter}}"
                                        Padding="14,7" Margin="0,0,0,0"
                                        ToolTip="Re-generate only the Tests / Validation fields"/>

                                <!-- Status -->
                                <TextBlock Grid.Column="2" Text="{Binding SaveStatus}"
                                           Foreground="{StaticResource Success}"
                                           VerticalAlignment="Center" FontSize="12"
                                           HorizontalAlignment="Center"/>

                                <!-- Approve buttons -->
                                <Button Grid.Column="3" Content="✕ Cancel"
                                        Command="{Binding CancelDraftCommand}"
                                        Style="{StaticResource AppButton.Secondary}"
                                        Padding="14,7" Margin="0,0,8,0"
                                        ToolTip="Discard draft and return to Chat"/>
                                <StackPanel Grid.Column="4" Orientation="Horizontal">
                                    <Button Content="✓ Create Ticket"
                                            Command="{Binding ApproveDraftCommand}"
                                            Style="{StaticResource AppButton.Primary}"
                                            IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"
                                            Padding="18,7" Margin="0,0,6,0"
                                            ToolTip="Save this ticket to the database"/>
                                    <Button Content="✓ Create Ticket + Plan"
                                            Command="{Binding ApproveDraftWithPlanCommand}"
                                            Style="{StaticResource AppButton.Secondary}"
                                            IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"
                                            Padding="18,7"
                                            ToolTip="Save ticket and navigate to Plans to create an implementation plan"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                        <!-- ═══ BUILD PREVIEW PANEL ═══ -->
                        <controls:SurfacePanel
                            Grid.Row="3"
                            Variant="Subtle"
                            Margin="0,12,0,0"
                            Padding="0"
                            Visibility="{Binding HasBuildPreview, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Margin="20,16,20,16">

                                <!-- Panel header -->
                                <TextBlock Text="BUILD PREVIEW" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,10"/>

                                <!-- Ticket name -->
                                <TextBlock Text="{Binding CurrentBuildPreview.TicketTitle, FallbackValue='Ticket'}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource Text/Primary}" Margin="0,0,0,6"/>

                                <!-- Context summary (Phase 2) -->
                                <TextBlock Text="CONTEXT" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CurrentBuildPreview.ContextSummary, FallbackValue=''}"
                                           Foreground="{StaticResource Text/Muted}" FontSize="11"
                                           TextWrapping="Wrap" FontStyle="Italic" Margin="0,0,0,10"/>

                                <!-- Summary -->
                                <TextBlock Text="PROPOSAL" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CurrentBuildPreview.Proposal.Summary, FallbackValue=''}"
                                           Foreground="{StaticResource Text/Primary}" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <!-- Files to change -->
                                <TextBlock Text="FILES TO CHANGE" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                <ItemsControl ItemsSource="{Binding CurrentBuildPreview.Proposal.FileChanges}"
                                              Margin="0,0,0,10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Foreground="{StaticResource Text/Muted}"
                                                       FontSize="11" FontFamily="Consolas">
                                                <Run Text="• "/><Run Text="{Binding FilePath}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Risk -->
                                <TextBlock Text="RISK" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CurrentBuildPreview.Proposal.RiskNotes, FallbackValue=''}"
                                           Foreground="{StaticResource Text/Muted}" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <!-- Test plan -->
                                <TextBlock Text="TEST PLAN" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CurrentBuildPreview.Proposal.TestPlan, FallbackValue=''}"
                                           Foreground="{StaticResource Text/Muted}" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <!-- Per-file diff view -->
                                <TextBlock Text="CHANGES" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
                                <ItemsControl ItemsSource="{Binding CurrentBuildPreview.Proposal.FileChanges}"
                                              Margin="0,0,0,10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Expander Margin="0,0,0,6"
                                                      Foreground="{StaticResource Text/Muted}">
                                                <Expander.Header>
                                                    <TextBlock FontFamily="Consolas" FontSize="11"
                                                               Foreground="{StaticResource Text/Primary}">
                                                        <Run Text="▸ "/><Run Text="{Binding FilePath}"/>
                                                    </TextBlock>
                                                </Expander.Header>
                                                <StackPanel Margin="12,6,0,0">
                                                    <!-- Change reason -->
                                                    <TextBlock Text="{Binding ChangeReason}"
                                                               Foreground="{StaticResource Text/Muted}"
                                                               FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                    <!-- Patch / Before+After -->
                                                    <TextBox IsReadOnly="True"
                                                             FontFamily="Consolas" FontSize="11"
                                                             Background="{StaticResource Background/App}"
                                                             Foreground="{StaticResource Text/Primary}"
                                                             BorderThickness="0"
                                                             TextWrapping="NoWrap" MinHeight="60" MaxHeight="280"
                                                             HorizontalScrollBarVisibility="Auto"
                                                             VerticalScrollBarVisibility="Auto">
                                                        <TextBox.Text>
                                                            <MultiBinding StringFormat="{}--- BEFORE ---{0}{1}{0}{0}+++ AFTER ---{0}{2}{0}{0}--- PATCH ---{0}{3}">
                                                                <Binding Source="&#10;"/>
                                                                <Binding Path="BeforeSnippet" FallbackValue="(none)"/>
                                                                <Binding Path="AfterSnippet"  FallbackValue="(none)"/>
                                                                <Binding Path="Patch"          FallbackValue="(no patch)"/>
                                                            </MultiBinding>
                                                        </TextBox.Text>
                                                    </TextBox>
                                                </StackPanel>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Build status -->
                                <TextBlock Text="{Binding BuildStatusMessage}"
                                           Foreground="{StaticResource Text/Muted}" FontSize="11"
                                           FontStyle="Italic" Margin="0,0,0,10"
                                           Visibility="{Binding BuildStatusMessage, Converter={StaticResource ValueToVis}}"/>

                                <!-- Actions -->
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Apply Changes"
                                            Command="{Binding ApplyBuildPreviewCommand}"
                                            Style="{StaticResource AppButton.Primary}"
                                            Padding="20,8" Margin="0,0,8,0"
                                            IsEnabled="False"
                                            ToolTip="Apply not available in Phase 3 — patch execution required (Phase 4)"/>
                                    <Button Content="Cancel"
                                            Command="{Binding CancelBuildPreviewCommand}"
                                            Style="{StaticResource AppButton.Ghost}"
                                            Padding="14,8"/>
                                </StackPanel>

                            </StackPanel>
                        </controls:SurfacePanel>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
