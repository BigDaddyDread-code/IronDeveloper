<UserControl x:Class="IronDev.Agent.Views.Workspaces.LlmConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:LlmConsoleViewModel, IsDesignTimeCreatable=False}">

    <Grid Margin="24,0,24,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*" MinHeight="120"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="3*" MinHeight="160"/>
        </Grid.RowDefinitions>

        <!-- ── Header & toolbar ──────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,20,0,12">
            <TextBlock Text="DEVELOPER TOOLS" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
            <TextBlock Text="LLM Console" Style="{StaticResource IronSectionTitle}" Margin="0,0,0,6"/>
            <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.55"
                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,8">
                Monitor all LLM calls in real time. Traces are stored in memory and redacted automatically.
            </TextBlock>

            <!-- Tracing status badge -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Border CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#2266BB66"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTracingEnabled}" Value="False">
                                    <Setter Property="Background" Value="#22888888"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock FontSize="11" FontWeight="SemiBold" FontFamily="Consolas">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="● TRACING: ON"/>
                                <Setter Property="Foreground" Value="#FF88DD88"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTracingEnabled}" Value="False">
                                        <Setter Property="Text" Value="○ TRACING: OFF"/>
                                        <Setter Property="Foreground" Value="#FF888888"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
                <TextBlock Text="Tracing is disabled. Enable it in Settings → Behaviour."
                           FontSize="12" Opacity="0.5" VerticalAlignment="Center"
                           Foreground="{StaticResource TextBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTracingEnabled}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Filter traces..."
                         MinWidth="280" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Refresh"    Command="{Binding RefreshCommand}"   Style="{StaticResource IronSecondaryButton}" Margin="0,0,6,0"/>
                    <Button Content="Export All" Command="{Binding ExportAllCommand}" Style="{StaticResource IronSecondaryButton}" Margin="0,0,6,0"/>
                    <Button Content="Clear"      Command="{Binding ClearCommand}"     Style="{StaticResource IronSecondaryButton}"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- ── Trace list (ListBox — no DataGrid fighting) ───────────────────── -->
        <Border Grid.Row="1" Style="{StaticResource IronCard}" Padding="0">
            <ListBox ItemsSource="{Binding Traces}"
                     SelectedItem="{Binding SelectedTrace, Mode=TwoWay}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True">
                <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            BorderThickness="0,0,0,1"
                                            BorderBrush="#12FFFFFF"
                                            Padding="12,8">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Time -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding CreatedAt, StringFormat={}{0:HH:mm:ss}}"
                                       FontSize="12" FontFamily="Consolas"
                                       Foreground="{StaticResource TextBrush}" Opacity="0.7"/>
                            <!-- Status -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding WasSuccessful, Converter={StaticResource BoolToStringConverter}, ConverterParameter='OK|FAIL'}"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{Binding WasSuccessful, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#66BB66|#EE6666'}"/>
                            <!-- Feature -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding FeatureName}"
                                       FontSize="12" Foreground="{StaticResource TextBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <!-- Duration -->
                            <TextBlock Grid.Column="3"
                                       Text="{Binding DurationMs, StringFormat={}{0}ms}"
                                       FontSize="12" Foreground="{StaticResource TextBrush}" Opacity="0.6"/>
                            <!-- Summary -->
                            <TextBlock Grid.Column="4"
                                       Text="{Binding ParsedResponseSummary}"
                                       FontSize="12" Foreground="{StaticResource TextBrush}" Opacity="0.55"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch" Background="Transparent"/>

        <!-- ── Detail panel ──────────────────────────────────────────────────── -->
        <Border Grid.Row="3" Style="{StaticResource IronCard}" Padding="16" Margin="0,10,0,0">
            <Grid>
                <!-- "No trace selected" placeholder -->
                <TextBlock Text="Select a trace above to inspect it."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Opacity="0.3" FontSize="13"
                           Visibility="{Binding SelectedTrace, Converter={StaticResource ValueToVis}, ConverterParameter=Inverse}"/>

                <!-- Detail content (visible only when trace selected) -->
                <Grid Visibility="{Binding SelectedTrace, Converter={StaticResource ValueToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Detail header with action buttons -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="TRACE DETAILS" Style="{StaticResource IronEyebrow}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Copy Prompt"    Command="{Binding CopyPromptCommand}"    Style="{StaticResource IronSecondaryButton}" Padding="8,2" Margin="0,0,6,0"/>
                            <Button Content="Copy Response"  Command="{Binding CopyResponseCommand}"  Style="{StaticResource IronSecondaryButton}" Padding="8,2" Margin="0,0,6,0"/>
                            <Button Content="Copy Full Trace" Command="{Binding CopyFullTraceCommand}" Style="{StaticResource IronSecondaryButton}" Padding="8,2"/>
                        </StackPanel>
                    </Grid>

                    <!-- Tabbed detail -->
                    <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border x:Name="Border" Padding="12,6" Margin="0,0,4,0"
                                                    CornerRadius="4,4,0,0" BorderThickness="0,0,0,2">
                                                <ContentPresenter ContentSource="Header"
                                                                  TextBlock.FontSize="12"
                                                                  TextBlock.FontWeight="SemiBold"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#15FFFFFF"/>
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource FocusBorderBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#08FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <!-- SUMMARY tab -->
                        <TabItem Header="SUMMARY">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,10,0,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="Feature:" Style="{StaticResource IronMetaLabel}"     Grid.Row="0" Margin="0,0,8,6"/>
                                        <TextBlock Text="{Binding SelectedTrace.FeatureName}"                 Grid.Row="0" Grid.Column="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>

                                        <TextBlock Text="Model:"    Style="{StaticResource IronMetaLabel}"    Grid.Row="1" Margin="0,0,8,6"/>
                                        <TextBlock Text="{Binding SelectedTrace.Model, FallbackValue='(unknown)'}" Grid.Row="1" Grid.Column="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>

                                        <TextBlock Text="Status:"   Style="{StaticResource IronMetaLabel}"    Grid.Row="2" Margin="0,0,8,6"/>
                                        <TextBlock Text="{Binding SelectedTrace.WasSuccessful, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Success|Failed'}"
                                                   Foreground="{Binding SelectedTrace.WasSuccessful, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#66BB66|#EE6666'}"
                                                   FontWeight="Bold"
                                                   Grid.Row="2" Grid.Column="1" Margin="0,0,0,6"/>

                                        <TextBlock Text="Duration:" Style="{StaticResource IronMetaLabel}"    Grid.Row="3" Margin="0,0,8,6"/>
                                        <TextBlock Text="{Binding SelectedTrace.DurationMs, StringFormat={}{0}ms}" Grid.Row="3" Grid.Column="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>

                                        <TextBlock Text="Project:"  Style="{StaticResource IronMetaLabel}"    Grid.Row="4" Margin="0,0,8,6"/>
                                        <TextBlock Text="{Binding SelectedTrace.ProjectId, FallbackValue='—'}" Grid.Row="4" Grid.Column="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>

                                        <TextBlock Text="Time:"     Style="{StaticResource IronMetaLabel}"    Grid.Row="5" Margin="0,0,8,6"/>
                                        <TextBlock Text="{Binding SelectedTrace.CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Grid.Row="5" Grid.Column="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                                    </Grid>

                                    <!-- User message (if available) -->
                                    <TextBlock Text="USER MESSAGE" Style="{StaticResource IronEyebrow}" Margin="0,8,0,6"
                                               Visibility="{Binding SelectedTrace.CurrentUserMessage, Converter={StaticResource ValueToVis}}"/>
                                    <TextBlock Text="{Binding SelectedTrace.CurrentUserMessage}"
                                               TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" Opacity="0.8" Margin="0,0,0,12"
                                               Visibility="{Binding SelectedTrace.CurrentUserMessage, Converter={StaticResource ValueToVis}}"/>

                                    <!-- Parsed summary (if available) -->
                                    <TextBlock Text="PARSED RESULT" Style="{StaticResource IronEyebrow}" Margin="0,8,0,6"
                                               Visibility="{Binding SelectedTrace.ParsedResponseSummary, Converter={StaticResource ValueToVis}}"/>
                                    <TextBlock Text="{Binding SelectedTrace.ParsedResponseSummary}"
                                               TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" Opacity="0.8"
                                               Visibility="{Binding SelectedTrace.ParsedResponseSummary, Converter={StaticResource ValueToVis}}"/>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- PROMPT tab -->
                        <TabItem Header="PROMPT">
                            <TextBox Margin="0,10,0,0"
                                     Text="{Binding SelectedTrace.RequestText, Mode=OneWay}"
                                     IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                     FontFamily="Consolas" FontSize="12" Padding="12"
                                     Background="#0AFFFFFF"
                                     VerticalScrollBarVisibility="Auto"/>
                        </TabItem>

                        <!-- RAW RESPONSE tab -->
                        <TabItem Header="RAW RESPONSE">
                            <TextBox Margin="0,10,0,0"
                                     Text="{Binding SelectedTrace.RawResponseText, Mode=OneWay}"
                                     IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                     FontFamily="Consolas" FontSize="12" Padding="12"
                                     Background="#0AFFFFFF"
                                     VerticalScrollBarVisibility="Auto"/>
                        </TabItem>

                        <!-- WARNINGS tab -->
                        <TabItem Header="WARNINGS">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,10,0,0">
                                <StackPanel>
                                    <!-- Warnings (amber) -->
                                    <Border Background="#22FFCC44" CornerRadius="4" Padding="12" Margin="0,0,0,12"
                                            Visibility="{Binding SelectedTrace.Warnings, Converter={StaticResource ValueToVis}}">
                                        <StackPanel>
                                            <TextBlock Text="WARNING" Style="{StaticResource IronEyebrow}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding SelectedTrace.Warnings}"
                                                       Foreground="#FFFFCC66" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Errors (red) -->
                                    <Border Background="#33EE6666" CornerRadius="4" Padding="12"
                                            Visibility="{Binding SelectedTrace.ErrorMessage, Converter={StaticResource ValueToVis}}">
                                        <StackPanel>
                                            <TextBlock Text="ERROR" Style="{StaticResource IronEyebrow}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding SelectedTrace.ErrorMessage}"
                                                       Foreground="#FFEE8888" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Empty state -->
                                    <TextBlock Text="No warnings or errors for this trace."
                                               HorizontalAlignment="Center" Opacity="0.3" FontSize="12" Margin="0,24,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding SelectedTrace.Warnings,
                                                                Converter={StaticResource ValueToVis},
                                                                ConverterParameter=Inverse}" Value="Visible"/>
                                                            <Condition Binding="{Binding SelectedTrace.ErrorMessage,
                                                                Converter={StaticResource ValueToVis},
                                                                ConverterParameter=Inverse}" Value="Visible"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                    </TabControl>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
