<Window x:Class="IronDev.Agent.Views.Workspaces.TestingSidekickWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Testing Sidekick"
        Width="390"
        Height="236"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="{StaticResource Background/App}">
    <Border BorderBrush="{StaticResource Border/Subtle}"
            BorderThickness="1"
            Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                <Button DockPanel.Dock="Right"
                        Content="x"
                        Width="28"
                        Height="24"
                        Click="Close_Click"
                        Style="{StaticResource AppButton.CompactGhost}"/>
                <StackPanel>
                    <TextBlock Text="Testing Sidekick"
                               Foreground="{StaticResource Text/Primary}"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding RunStatusText}"
                               Foreground="{StaticResource Text/Muted}"
                               FontSize="11"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </DockPanel>

            <StackPanel Grid.Row="1">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource Text/Secondary}"
                           TextWrapping="Wrap"
                           MaxHeight="44"
                           Margin="0,0,0,12"/>
                <TextBlock Text="{Binding Moments.Count, StringFormat=Captured moments: {0}}"
                           Foreground="{StaticResource Text/Muted}"
                           FontSize="11"/>
                <TextBlock Text="Ctrl+Shift+M captures the current screen."
                           Foreground="{StaticResource Text/Muted}"
                           FontSize="11"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Mark"
                        Click="Mark_Click"
                        Style="{StaticResource AppButton.CompactGhost}"
                        Margin="0,0,8,0"/>
                <Button Content="Copy Last"
                        Click="CopyLast_Click"
                        Style="{StaticResource AppButton.CompactGhost}"
                        Margin="0,0,8,0"/>
                <Button Content="Bundle"
                        Click="CopyBundle_Click"
                        Style="{StaticResource AppButton.CompactGhost}"
                        Margin="0,0,8,0"/>
                <Button Content="Report"
                        Click="OpenReport_Click"
                        Style="{StaticResource AppButton.CompactGhost}"
                        Margin="0,0,8,0"/>
                <Button Content="Finish"
                        Click="Finish_Click"
                        Style="{StaticResource AppButton.Primary}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
