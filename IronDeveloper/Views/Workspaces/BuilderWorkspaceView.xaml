<UserControl x:Class="IronDev.Agent.Views.Workspaces.BuilderWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workspaces"
             xmlns:controls="http://schemas.irondeveloper.com/controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:BuilderWorkspaceViewModel, IsDesignTimeCreatable=False}">

    <Grid Background="{StaticResource Background/App}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <controls:WorkspaceHeader Grid.Row="0"
                                  Eyebrow="BUILDER"
                                  Title="Builder Workbench"
                                  Subtitle="{Binding ProjectRoot}"
                                  Margin="0">
            <controls:WorkspaceHeader.Actions>
                <StackPanel Orientation="Horizontal">
                    <controls:StatusBadge Text="{Binding ApplyModeLabel, FallbackValue=PROPOSAL-ONLY, TargetNullValue=PROPOSAL-ONLY}"
                                          Status="Ready"
                                          Margin="0,0,8,0"
                                          Visibility="{Binding IsApplyEnabled, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <controls:StatusBadge Text="{Binding ApplyModeLabel, FallbackValue=PROPOSAL-ONLY, TargetNullValue=PROPOSAL-ONLY}"
                                          Status="Info"
                                          Margin="0,0,8,0"
                                          Visibility="{Binding IsApplyEnabled, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    <Button Content="Close Workbench"
                            Command="{Binding DataContext.NavigateWorkspaceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="Tickets"
                            Style="{StaticResource AppButton.CompactGhost}"/>
                </StackPanel>
            </controls:WorkspaceHeader.Actions>
        </controls:WorkspaceHeader>
        <!-- Workbench Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="240"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360" MinWidth="270"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Proposed Files -->
            <controls:WorkspaceListPane Grid.Column="0" Title="PROPOSED CHANGES" Margin="0,0,12,0"
                                        ItemsSource="{Binding ProposedFiles}"
                                        SelectedItem="{Binding SelectedFileChange, Mode=TwoWay}">
                <controls:WorkspaceListPane.ItemTemplate>
                    <DataTemplate>
                        <controls:WorkspaceListItem Title="{Binding FilePath}"
                                                    Subtitle="{Binding Description}"
                                                    IconData="{StaticResource Icon.Action.Build}"/>
                    </DataTemplate>
                </controls:WorkspaceListPane.ItemTemplate>
            </controls:WorkspaceListPane>

            <!-- CENTRE: Body (Diff / Output) -->
            <controls:SurfacePanel Grid.Column="1" Variant="Subtle" Margin="0,0,12,0">
                <Grid>
                    <TabControl Background="Transparent" BorderThickness="0"
                                ItemContainerStyle="{StaticResource AppTabItem.Workspace}">
                        <TabItem Header="FILE DIFF">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Diff Header -->
                                <Border Grid.Row="0" Background="{StaticResource Background/Surface}" 
                                        BorderBrush="{StaticResource Border/Subtle}" BorderThickness="0,0,0,1"
                                        Padding="16,10" CornerRadius="10,10,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding SelectedFileChange.FilePath}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Border Visibility="{Binding SelectedFileChange.IsNewFile, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Background="{StaticResource Brush.Status.Ready.Background}" BorderBrush="{StaticResource Brush.Status.Ready.Border}" BorderThickness="1"
                                                CornerRadius="3" Padding="6,1" Margin="8,0,0,0">
                                            <TextBlock Text="NEW" FontSize="9" FontWeight="Bold" Foreground="{StaticResource Brush.Status.Ready.Foreground}"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Diff Content -->
                                <ScrollViewer Grid.Row="1" Background="{StaticResource Background/App}" Padding="16">
                                    <TextBox Text="{Binding SelectedFileChange.Diff, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Background="Transparent"
                                             Foreground="{StaticResource Text/Primary}"
                                             BorderThickness="0"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             AcceptsReturn="True"
                                             TextWrapping="NoWrap"/>
                                </ScrollViewer>
                            </Grid>
                        </TabItem>

                        <TabItem Header="BUILD &amp; TEST OUTPUT">
                            <ScrollViewer Background="{StaticResource Background/App}" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="BUILD OUTPUT" Foreground="{StaticResource Accent/Primary}" FontWeight="Bold" FontSize="11" Margin="0,0,0,8"/>
                                    <Border Background="{StaticResource Background/Panel}" BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,24">
                                        <TextBox Text="{Binding BuildOutput, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 Background="Transparent"
                                                 Foreground="{StaticResource Text/Primary}"
                                                 BorderThickness="0"
                                                 FontFamily="Consolas"
                                                 FontSize="12"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 MinHeight="150"/>
                                    </Border>

                                    <TextBlock Text="TEST OUTPUT" Foreground="{StaticResource Accent/Primary}" FontWeight="Bold" FontSize="11" Margin="0,0,0,8"/>
                                    <Border Background="{StaticResource Background/Panel}" BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1" CornerRadius="6" Padding="12">
                                        <TextBox Text="{Binding TestOutput, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 Background="Transparent"
                                                 Foreground="{StaticResource Text/Primary}"
                                                 BorderThickness="0"
                                                 FontFamily="Consolas"
                                                 FontSize="12"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 MinHeight="150"/>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>

                    <!-- Processing Overlay -->
                    <Border Grid.RowSpan="2" Background="#CC000000" CornerRadius="10"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Processing..." Foreground="White" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource Text/Secondary}" FontSize="13" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </controls:SurfacePanel>

            <!-- RIGHT: Agent Info -->
            <controls:SurfacePanel Grid.Column="2" Variant="Subtle">
                <ScrollViewer Padding="20">
                    <StackPanel>
                        <!-- BUILD READINESS SECTION -->
                        <TextBlock Text="BUILD READINESS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,12"/>
                        <controls:StatusCallout Title="{Binding ReadinessTitle}"
                                                Message="{Binding ReadinessMessage}"
                                                Details="{Binding ReadinessDetails}"
                                                BadgeText="{Binding ReadinessBadgeText}"
                                                Status="{Binding ReadinessBadgeStatus}"
                                                Visibility="{Binding ShowReadinessCallout, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Margin="0,0,0,20"/>

                        <TextBlock Text="AI PROPOSAL SUMMARY" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,12"/>
                        
                        <controls:SurfacePanel Variant="Subtle" Padding="16" Margin="0,0,0,20">
                            <TextBlock Text="{Binding CurrentProposal.Summary}" TextWrapping="Wrap" FontSize="14" Foreground="{StaticResource Text/Primary}"/>
                        </controls:SurfacePanel>

                        <TextBlock Text="RATIONALE" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding CurrentProposal.Rationale}" TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource Text/Secondary}" Margin="0,0,0,20"/>

                        <TextBlock Text="VALIDATION STATUS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding CurrentProposal.ValidationIssues}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Brush.Status.Danger.Background}" BorderBrush="{StaticResource Brush.Status.Danger.Border}" BorderThickness="1"
                                            CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding}" Foreground="{StaticResource Brush.Status.Danger.Foreground}" FontSize="11" TextWrapping="Wrap"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding CurrentProposal.ValidationWarnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Brush.Status.Warning.Background}" BorderBrush="{StaticResource Brush.Status.Warning.Border}" BorderThickness="1"
                                            CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding}" Foreground="{StaticResource Brush.Status.Warning.Foreground}" FontSize="11" TextWrapping="Wrap"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding ProposedFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Visibility="{Binding IsValid, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                            Background="{StaticResource Brush.Status.Danger.Background}" BorderBrush="{StaticResource Brush.Status.Danger.Border}" BorderThickness="1"
                                            CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FilePath}" FontWeight="Bold" Foreground="{StaticResource Brush.Status.Danger.Foreground}" FontSize="12"/>
                                            <TextBlock Text="{Binding ValidationMessage}" Foreground="{StaticResource Brush.Status.Danger.Foreground}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <Border Visibility="{Binding CurrentProposal.IsAllValid, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="{StaticResource Brush.Status.Ready.Background}" BorderBrush="{StaticResource Brush.Status.Ready.Border}" BorderThickness="1"
                                CornerRadius="6" Padding="12,10">
                            <TextBlock Text="All proposed changes pass security validation." Foreground="{StaticResource Brush.Status.Ready.Foreground}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </Border>

                        <!-- RECONCILIATION SECTION -->
                        <Border Visibility="{Binding HasReconciliation, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="{StaticResource Brush.Status.Warning.Background}" BorderBrush="{StaticResource Brush.Status.Warning.Border}" BorderThickness="1"
                                CornerRadius="6" Padding="16,16" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="ARCHITECTURE RECONCILIATION" Foreground="{StaticResource Brush.Status.Warning.Foreground}" FontWeight="Bold" FontSize="12" Margin="0,0,0,8"/>
                                <TextBlock Text="Build failed because project architecture/profile information is missing or inconsistent." Foreground="{StaticResource Text/Primary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                
                                <TextBlock Text="Category:" Foreground="{StaticResource Text/Secondary}" FontSize="11"/>
                                <TextBlock Text="{Binding Reconciliation.FailureCategory}" Foreground="{StaticResource Text/Primary}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                
                                <TextBlock Text="Evidence:" Foreground="{StaticResource Text/Secondary}" FontSize="11"/>
                                <TextBlock Text="{Binding Reconciliation.Evidence}" Foreground="{StaticResource Text/Primary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                
                                <TextBlock Text="Current Profile:" Foreground="{StaticResource Text/Secondary}" FontSize="11"/>
                                <TextBlock Text="{Binding Reconciliation.CurrentProfileValue}" Foreground="{StaticResource Text/Primary}" FontSize="12" Margin="0,0,0,8"/>
                                
                                <TextBlock Text="Detected Facts:" Foreground="{StaticResource Text/Secondary}" FontSize="11"/>
                                <TextBlock Text="{Binding Reconciliation.DetectedProjectFacts}" Foreground="{StaticResource Text/Primary}" FontSize="12" Margin="0,0,0,16"/>
                                
                                <TextBlock Text="Recommended Actions:" Foreground="{StaticResource Brush.Status.Warning.Foreground}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                
                                <ItemsControl ItemsSource="{Binding Reconciliation.AvailableActions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Title}"
                                                    Command="{Binding DataContext.HandleReconciliationActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,0,8" Padding="12,6"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- APPLY SECTION -->
                        <Button Content="Apply Proposal" 
                                Command="{Binding ApplyProposalCommand}"
                                Style="{StaticResource AppButton.Primary}"
                                Margin="0,24,0,0"
                                Padding="24,12"
                                Height="48"/>
                        
                        <TextBlock Text="EXECUTION STATUS" Style="{StaticResource Typography.Eyebrow}" Margin="0,24,0,8"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Apply:" Foreground="{StaticResource Text/Muted}" Margin="0,0,12,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ApplyStatus}" FontWeight="SemiBold" Foreground="{StaticResource Text/Primary}"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Build:" Foreground="{StaticResource Text/Muted}" Margin="0,0,12,4"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding BuildStatus}" FontWeight="SemiBold" Foreground="{StaticResource Text/Primary}" VerticalAlignment="Center"/>
                                <Button Content="Details" Command="{Binding ViewBuildDetailsCommand}" 
                                        Style="{StaticResource AppButton.Secondary}" Height="18" Padding="6,0" Margin="8,0,0,0" FontSize="10"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Tests:" Foreground="{StaticResource Text/Muted}" Margin="0,0,12,4"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding TestStatus}" FontWeight="SemiBold" Foreground="{StaticResource Text/Primary}" VerticalAlignment="Center"/>
                                <Button Content="Details" Command="{Binding ViewTestDetailsCommand}" 
                                        Style="{StaticResource AppButton.Secondary}" Height="18" Padding="6,0" Margin="8,0,0,0" FontSize="10"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="ORIGINAL REQUEST" Style="{StaticResource Typography.Eyebrow}" Margin="0,24,0,8" Opacity="0.6"/>
                        <TextBlock Text="{Binding CurrentProposal.OriginalRequest}" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource Text/Muted}" FontStyle="Italic"/>
                    </StackPanel>
                </ScrollViewer>
            </controls:SurfacePanel>
        </Grid>
    </Grid>
</UserControl>
