<UserControl x:Class="IronDev.Agent.Views.Workflow.ProjectOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workflow"
             xmlns:controls="http://schemas.irondeveloper.com/controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ProjectOverviewViewModel, IsDesignTimeCreatable=False}">

    <ScrollViewer Background="{StaticResource Background/App}">
        <StackPanel Margin="32,24,32,32">

            <!-- Page header -->
            <TextBlock Text="PROJECT OVERVIEW" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding ProjectName}" Style="{StaticResource Typography.ScreenTitle}" Margin="0,0,0,6"/>
            <TextBlock Text="{Binding Description}"
                       Foreground="{StaticResource Text/Muted}"
                       FontSize="13" TextWrapping="Wrap" Margin="0,0,0,18"/>

            <controls:StatusCallout Title="{Binding IndexHealthTitle}"
                                    Message="{Binding IndexHealthMessage}"
                                    BadgeText="{Binding IndexHealthBadgeText}"
                                    Status="{Binding IndexHealthBadgeStatus}"
                                    ActionText="Index Project"
                                    ActionCommand="{Binding IndexProjectCommand}"
                                    Visibility="{Binding ShowIndexHealthCallout, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Margin="0,0,0,24"/>

            <controls:CompactStatsStrip Title="Index"
                                        StatusText="{Binding Status}"
                                        StatusBrush="{Binding Status, Converter={StaticResource StatusToBrushConverter}}"
                                        MetricText="{Binding FileCount, StringFormat={}{0} files}"
                                        TimestampText="{Binding LastIndexed, StringFormat=Last indexed {0}}"
                                        ScopeText="{Binding ProjectPath}"
                                        PrimaryActionText="Re-index"
                                        PrimaryActionCommand="{Binding IndexProjectCommand}"
                                        PrimaryActionEnabled="{Binding IsIndexing, Converter={StaticResource InverseBoolConverter}}"
                                        SecondaryActionText="Details"
                                        SecondaryActionCommand="{Binding ViewDetailsCommand}"
                                        TertiaryActionText="Export context"
                                        TertiaryActionCommand="{Binding ExportProjectContextPackCommand}"
                                        Margin="0,0,0,20"/>

            <controls:StatusCallout Title="{Binding IndexDetailsTitle}"
                                    Message="{Binding IndexDetailsMessage}"
                                    Details="{Binding LastIndexingDetails}"
                                    BadgeText="{Binding IndexDetailsBadgeText}"
                                    Status="{Binding IndexDetailsBadgeStatus}"
                                    Visibility="{Binding ShowIndexDetails, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Margin="0,0,0,28"/>

            <!-- Current State Panel -->
            <Border Background="{StaticResource Background/Panel}"
                    BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1"
                    CornerRadius="8" Padding="14,12" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="PROJECT CONTEXT" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Left column -->
                        <StackPanel Grid.Column="0">
                            <!-- User -->
                            <Grid Margin="0,0,0,8" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="User" Foreground="{StaticResource Text/Muted}" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentUserDisplayName, FallbackValue='Unknown'}"
                                           Foreground="{StaticResource Text/Primary}" FontSize="12" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                            <!-- Email -->
                            <Grid Margin="0,0,0,8" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Email" Foreground="{StaticResource Text/Muted}" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentUserEmail, FallbackValue='Not available'}"
                                           Foreground="{StaticResource Text/Muted}" FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                            <!-- Tenant -->
                            <Grid Margin="0,0,0,8" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Tenant" Foreground="{StaticResource Text/Muted}" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentTenantName, FallbackValue='No tenant'}"
                                           Foreground="{StaticResource Accent/Primary}" FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                            <!-- Project -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Project" Foreground="{StaticResource Text/Muted}" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding ProjectName}"
                                           Foreground="{StaticResource Text/Primary}" FontSize="12" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                            <!-- Path -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Path" Foreground="{StaticResource Text/Muted}" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding ProjectPath}"
                                           Foreground="{StaticResource Text/Muted}" FontSize="11" FontFamily="Consolas"
                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding ProjectPath}"/>
                            </Grid>
                        </StackPanel>
                        <!-- Right column -->
                        <StackPanel Grid.Column="2">
                            <!-- Model -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Model" Foreground="{StaticResource Text/Muted}" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding Model}"
                                           Foreground="{StaticResource Accent/Primary}" FontSize="12" FontWeight="SemiBold"/>
                            </Grid>
                            <!-- Index Status -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Index Status" Foreground="{StaticResource Text/Muted}" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding Status}"
                                           Foreground="{Binding Status, Converter={StaticResource StatusToBrushConverter}}"
                                           FontSize="12" FontWeight="SemiBold"/>
                            </Grid>
                            <!-- Last Indexed -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Last Indexed" Foreground="{StaticResource Text/Muted}" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding LastIndexed}"
                                           Foreground="{StaticResource Text/Muted}" FontSize="12"/>
                            </Grid>
                            <!-- Last Ticket -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Last Ticket" Foreground="{StaticResource Text/Muted}" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding LastTicketTitle}"
                                           Foreground="{StaticResource Text/Primary}" FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                            <!-- Last Decision -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Last Decision" Foreground="{StaticResource Text/Muted}" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding LastDecisionTitle}"
                                           Foreground="{StaticResource Text/Primary}" FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Project Profile Panel -->
            <Border Background="{StaticResource Background/Panel}"
                    BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1"
                    CornerRadius="8" Padding="14,12" Margin="0,0,0,20">
                <StackPanel>
                    <controls:SectionHeaderActions Eyebrow="PROJECT PROFILE"
                                                   Title="{Binding ProfileSaveStatus}"
                                                   SecondaryActionText="Detect"
                                                   SecondaryActionCommand="{Binding DetectProfileCommand}"
                                                   PrimaryActionText="Save"
                                                   PrimaryActionCommand="{Binding SaveProfileCommand}"
                                                   Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Left column -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="BASICS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                            <!-- Application Type -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Application Type" Foreground="{StaticResource Text/Muted}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ProfileApplicationType, UpdateSourceTrigger=PropertyChanged}" Padding="4" FontSize="12"/>
                            </Grid>
                            
                            <!-- Primary Language -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Primary Language" Foreground="{StaticResource Text/Muted}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ProfilePrimaryLanguage, UpdateSourceTrigger=PropertyChanged}" Padding="4" FontSize="12"/>
                            </Grid>
                            
                            <!-- Framework / Runtime -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Framework" Foreground="{StaticResource Text/Muted}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ProfileFramework, UpdateSourceTrigger=PropertyChanged}" Padding="4" FontSize="12"/>
                            </Grid>
                            
                            <!-- Database Engine -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Database Engine" Foreground="{StaticResource Text/Muted}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ProfileDatabaseEngine, UpdateSourceTrigger=PropertyChanged}" Padding="4" FontSize="12"/>
                            </Grid>
                            
                            <!-- Data Access Style -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Data Access Style" Foreground="{StaticResource Text/Muted}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ProfileDataAccessStyle, UpdateSourceTrigger=PropertyChanged}" Padding="4" FontSize="12"/>
                            </Grid>
                        </StackPanel>
                        
                        <!-- Right column -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="BUILD, TEST, SAFETY" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,8"/>
                            <!-- Test Framework -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Test Framework" Foreground="{StaticResource Text/Muted}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ProfileTestFramework, UpdateSourceTrigger=PropertyChanged}" Padding="4" FontSize="12"/>
                            </Grid>
                            
                            <!-- Solution File -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Solution File" Foreground="{StaticResource Text/Muted}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ProfileSolutionFile, UpdateSourceTrigger=PropertyChanged}" Padding="4" FontSize="11" FontFamily="Consolas"/>
                            </Grid>
                            
                            <!-- Build Command -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Build Command" Foreground="{StaticResource Text/Muted}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ProfileBuildCommand, UpdateSourceTrigger=PropertyChanged}" Padding="4" FontSize="11" FontFamily="Consolas"/>
                            </Grid>
                            
                            <!-- Test Command -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Test Command" Foreground="{StaticResource Text/Muted}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ProfileTestCommand, UpdateSourceTrigger=PropertyChanged}" Padding="4" FontSize="11" FontFamily="Consolas"/>
                            </Grid>
                            
                            <!-- Safe Write Root -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Safe Write Root" Foreground="{StaticResource Text/Muted}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ProfileSafeWriteRoot, UpdateSourceTrigger=PropertyChanged}" Padding="4" FontSize="11" FontFamily="Consolas"/>
                            </Grid>
                            
                            <!-- Allow Builder Apply -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Allow Builder Apply" Foreground="{StaticResource Text/Muted}" FontSize="12" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding ProfileAllowBuilderApply}" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Allow Writes Outside Root -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Allow External Writes" Foreground="{StaticResource Text/Muted}" FontSize="12" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding ProfileAllowWritesOutsideProjectRoot}" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Profile Notes -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Profile Notes" Foreground="{StaticResource Text/Muted}" FontSize="12" VerticalAlignment="Top" Margin="0,4,0,0"/>
                                <TextBox Grid.Column="1" Text="{Binding ProfileNotes, UpdateSourceTrigger=PropertyChanged}" 
                                         Padding="4" FontSize="11" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Two-column: recent tickets + decisions -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Tickets -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="RECENT TICKETS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding RecentTickets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="16,12"
                                        Background="{StaticResource Background/Panel}"
                                        BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1"
                                        CornerRadius="8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="{Binding Title}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource Text/Primary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding Priority}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Warning}"
                                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{Binding Status, Converter={StaticResource StatusToBrushConverter}}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Recent Decisions -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="RECENT DECISIONS" Style="{StaticResource Typography.Eyebrow}" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding RecentDecisions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="16,12"
                                        Background="{StaticResource Background/Panel}"
                                        BorderBrush="{StaticResource Border/Subtle}" BorderThickness="1"
                                        CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource Text/Primary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Detail}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource Text/Muted}"
                                                   TextWrapping="Wrap" Margin="0,6,0,0"
                                                   MaxHeight="36"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
