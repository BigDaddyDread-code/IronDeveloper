<UserControl x:Class="IronDev.Agent.Views.Workflow.ProjectOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workflow"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ProjectOverviewViewModel, IsDesignTimeCreatable=False}">

    <ScrollViewer Background="{StaticResource AppBackgroundBrush}">
        <StackPanel Margin="40,36,40,40">

            <!-- Page header -->
            <TextBlock Text="PROJECT OVERVIEW" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding ProjectName}" Style="{StaticResource IronSectionTitle}" Margin="0,0,0,6"/>
            <TextBlock Text="{Binding Description}" Style="{StaticResource IronMetaLabel}"
                       Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,32"/>

            <!-- Meta strip -->
            <Border Style="{StaticResource IronMetalPanel}" Margin="0,0,0,28" Padding="22,14">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="PATH" Style="{StaticResource IronMetaLabel}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding ProjectPath}" Style="{StaticResource IronMetaValue}"/>
                    <TextBlock Text="MODEL" Style="{StaticResource IronMetaLabel}" Margin="16,0,8,0"/>
                    <TextBlock Text="{Binding Model}" Style="{StaticResource IronMetaValue}"/>
                    <TextBlock Text="STATUS" Style="{StaticResource IronMetaLabel}" Margin="16,0,8,0"/>
                    <Border Style="{StaticResource IronStatusBadge}">
                        <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource StatusWarningBrush}"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Two-column: recent tickets + decisions -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Tickets -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="RECENT TICKETS" Style="{StaticResource IronEyebrow}" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding RecentTickets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource IronCard}" Margin="0,0,0,8" Padding="16,12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="{Binding Title}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                                            <Border Style="{StaticResource IronStatusBadge}" Margin="0,0,6,0">
                                                <TextBlock Text="{Binding Priority}" FontSize="10"
                                                           Foreground="{StaticResource StatusWarningBrush}"/>
                                            </Border>
                                            <Border Style="{StaticResource IronStatusBadge}">
                                                <TextBlock Text="{Binding Status}" FontSize="10"
                                                           Foreground="{StaticResource StatusReadyBrush}"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Recent Decisions -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="RECENT DECISIONS" Style="{StaticResource IronEyebrow}" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding RecentDecisions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource IronCard}" Margin="0,0,0,8" Padding="16,12">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Detail}"
                                                   Style="{StaticResource IronMetaLabel}"
                                                   TextWrapping="Wrap" Margin="0,6,0,0"
                                                   Opacity="0.65"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
