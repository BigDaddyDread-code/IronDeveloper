<UserControl x:Class="IronDev.Agent.Views.Workflow.ProjectHubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workflow"
             xmlns:controls="http://schemas.irondeveloper.com/controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ProjectHubViewModel, IsDesignTimeCreatable=False}">
    <UserControl.Resources>
        <Style x:Key="ProjectHubCardButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Grid.Column="0" Margin="32,30,32,0">
            <TextBlock Text="PROJECT HUB" Style="{StaticResource Typography.Eyebrow}"/>
            <TextBlock Text="Your Projects" Style="{StaticResource Typography.ScreenTitle}"/>
        </StackPanel>

        <!-- Project tiles -->
        <ScrollViewer Grid.Row="1" Grid.Column="0" Margin="22,22,30,30" VerticalScrollBarVisibility="Auto">
            <WrapPanel>
                <Button
                    Width="318"
                    MinHeight="156"
                    Margin="10"
                    Command="{Binding CreateNewProjectCommand}"
                    Style="{StaticResource ProjectHubCardButton}">
                    <controls:ActionCard
                        MinHeight="156"
                        IsHitTestVisible="False"
                        Title="Create New Project"
                        Description="Start a new project workspace."
                        IconData="{StaticResource Icon.Action.Add}"
                        ActionText=""/>
                </Button>

                <ItemsControl ItemsSource="{Binding RecentProjects}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button
                                Width="318"
                                MinHeight="156"
                                Margin="10"
                                Command="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource ProjectHubCardButton}">
                                <controls:ActionCard
                                    MinHeight="156"
                                    IsHitTestVisible="False"
                                    Title="{Binding Name}"
                                    Description="{Binding Description}"
                                    StatusText="{Binding IndexingStatus, TargetNullValue='Needs Index', FallbackValue='Needs Index'}"
                                    IconData="{StaticResource Icon.Nav.Projects}"
                                    ActionText=""/>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>
        </ScrollViewer>

        <!-- Embedded project wizard -->
        <controls:SurfacePanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                Width="420"
                Margin="0,22,28,28"
                Visibility="{Binding IsProjectWizardOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                Variant="Elevated">
            <ContentControl Content="{Binding ProjectWizard}"/>
        </controls:SurfacePanel>
    </Grid>
</UserControl>
