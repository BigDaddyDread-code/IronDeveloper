<UserControl x:Class="IronDev.Agent.Views.Workflow.CreateProjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IronDev.Agent.ViewModels.Workflow"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CreateProjectViewModel, IsDesignTimeCreatable=False}">

    <Grid Background="{StaticResource AppBackgroundBrush}">

        <Border Style="{StaticResource IronCard}"
                Width="500" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>

                <!-- Header -->
                <TextBlock Text="NEW PROJECT" Style="{StaticResource IronEyebrow}" Margin="0,0,0,4"/>
                <TextBlock Text="Create Project" Style="{StaticResource IronSectionTitle}" Margin="0,0,0,28"/>

                <!-- Project Name -->
                <TextBlock Text="PROJECT NAME" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                <TextBox Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,18"/>

                <!-- Local Path -->
                <TextBlock Text="LOCAL PATH" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                <TextBox Text="{Binding ProjectPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,18"/>

                <CheckBox IsChecked="{Binding CreateNewProjectSkeleton}"
                          Content="Create a new .NET skeleton if this folder is empty"
                          Margin="0,0,0,18"/>

                <!-- Model Selector -->
                <TextBlock Text="AI MODEL" Style="{StaticResource IronMetaLabel}" Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding AvailableModels}"
                          SelectedItem="{Binding SelectedModel}"
                          Margin="0,0,0,24"/>

                <!-- Error -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource StatusErrorBrush}"
                           FontSize="12" Margin="0,0,0,16" TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Margin="0,0,12,0" Padding="24,12"/>
                    <Button Content="Create Project"
                            Command="{Binding CreateCommand}"
                            Style="{StaticResource IronPrimaryButton}"
                            Padding="24,12"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
