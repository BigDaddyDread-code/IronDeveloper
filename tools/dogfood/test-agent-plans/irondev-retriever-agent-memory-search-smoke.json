{
  "test_run_id": "IronDev024-RetrieverAgentMemorySearch",
  "goal_id": "retriever-agent-real-path-024",
  "project_id": 2,
  "description": "Prove RetrieverAgent wraps the real memory search path and returns a project-scoped context package with source and ranking evidence.",
  "max_turns": 2,
  "early_stop_on_failure": true,
  "steps": [
    {
      "step": 1,
      "action": "agent_retriever_search",
      "params": {
