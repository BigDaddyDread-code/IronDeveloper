        "expect_weighted_context_bundle": true,
        "expect_weighted_reason_contains": [
          "accepted project memory",
          "current source"
        ],
        "expect_top_guidance": "use_this"
      }
    },
    {
      "step": 2,
      "action": "agent_retriever_search",
      "params": {
        "project": "BookSeller",
        "query": "BookSeller current architecture SQL inventory with IronDev governance",
        "take": 5,
        "expect_project": "BookSeller",
        "expect_model_profile": "cheap-runner",
        "expect_provider": "OpenAI",
        "expect_top_title_contains": "BOOKSELLER",
