{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "IronDeveloperDb": "Server=(localdb)\\MSSQLLocalDB;Database=IronDeveloper_Test;Integrated Security=True;Encrypt=True;TrustServerCertificate=True;"
  },
  "Ai": {
    "Provider": "Fake"
  },
  "RunAgents": {
    "LocalTestDeterministicConnectionEnabled": true
  },
  "AlphaSmoke": {
    "Responses": {
      "Builder": "{\"summary\":\"Create a LocalTest proposal marker.\",\"rationale\":\"Exercise the real proposal, disposable workspace, build, test, and evidence path without mutating the source repository.\",\"changes\":[{\"filePath\":\"irondev-localtest-proposal.txt\",\"description\":\"Add a disposable LocalTest proposal marker.\",\"diff\":\"+IronDev LocalTest deterministic proposal.\",\"fullContentAfter\":\"IronDev LocalTest deterministic proposal.\\n\",\"isNewFile\":true,\"isDeletion\":false}]}",
      "Tester": "[]",
      "Critic": "{\"verdict\":\"NoObjection\",\"findings\":[]}"
    }
  },
  "LocalTest": {
    "WeaviatePrefix": "irondev_test",
    "WorkspaceRoot": "C:\\IronDevTestWorkspaces\\",
    "LogsRoot": "C:\\IronDevTestLogs\\",
    "DangerRealRepoWritesEnabled": false,
    "ResetAllowed": true
  },
  "WorkbenchV2": {
    "Version": "0.1.0-preview.1",
    "Enabled": true,
    "V1FallbackEnabled": true,
    "PreviewId": "default"
  },
  "Jwt": {
    "Issuer": "irondev-api",
    "Audience": "irondev-client",
    "ExpiryMinutes": "60"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:1420",
      "http://127.0.0.1:1420"
    ]
  },
  "CodeProposal": {
    "Mode": "Deterministic"
  },
  "Weaviate": {
    "Enabled": false,
    "Endpoint": "http://localhost:8080",
    "GrpcPort": 50051,
    "ApiKey": "",
    "CollectionPrefix": "IronDevContextChunks"
  }
}
